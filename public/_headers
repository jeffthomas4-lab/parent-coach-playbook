# Static HTML: edge-cache for a day, browser-cache for 5 minutes, serve stale
# while revalidating in the background. New deploys auto-purge the CF edge so
# readers always see fresh content. Cuts Asia/India TTFB from ~750ms to ~80ms
# on cache hits.
/*.html
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=86400

/
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=86400

# Hashed asset bundles (Astro's _astro/ output) carry content hashes in the
# filename, so they're safe to cache for a year at the edge and in the browser.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Long-lived static assets that we update in place (no content hash). One day
# at the edge, an hour in the browser, allow stale-while-revalidate.
/og-default.jpg
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400
/og-default.webp
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400
/favicon.svg
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400

# PDFs: same as static assets, cache aggressively at the edge.
/*.pdf
  Cache-Control: public, max-age=3600, s-maxage=86400

# Lock down admin paths even at the header layer. Belt-and-suspenders on top
# of the Cloudflare Access policy. Admin pages should never be edge-cached.
/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: private, no-store

/api/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: private, no-store

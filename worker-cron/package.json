{
  "name": "parent-coach-playbook-cron",
  "version": "0.1.0",
  "private": true,
  "description": "Daily scheduler for the Parent Coach Desk camps quality sweep.",
  "scripts": {
    "deploy": "wrangler deploy --config ./wrangler.toml",
    "tail": "wrangler tail   --config ./wrangler.toml",
    "dev": "wrangler dev    --config ./wrangler.toml",
    "secret:cron": "wrangler secret put CRON_KEY           --config ./wrangler.toml",
    "secret:list": "wrangler secret list --config ./wrangler.toml"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "wrangler": "^4.88.0"
  }
}

# Public site URL — set in Cloudflare Pages
PUBLIC_SITE_URL=https://parentcoachplaybook.com

# Kit (formerly ConvertKit) — paste form ID when ready
PUBLIC_KIT_FORM_ID=
PUBLIC_KIT_LEAD_MAGNET_FORM_ID=

# Sanity — fill in after running `sanity init` inside studio/
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Plausible (optional) — domain you registered with Plausible
PUBLIC_PLAUSIBLE_DOMAIN=parentcoachplaybook.com

# OpenAI — for scripts/build-illustrations.py
# Get a key at https://platform.openai.com/api-keys
# Used to generate hero illustrations from IMAGE_NEEDS.md
# DALL-E 3 standard pricing as of May 2026: ~$0.04 per image at 1024x1024,
# ~$0.08 per image at 1792x1024 (the size we use for hero/landscape).
# 83 images at 1792x1024 ≈ $6.64 one-time.
OPENAI_API_KEY=

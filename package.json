{
  "name": "parent-coach-desk",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "The Parent Coach Desk. Editorial content for parents who coach their own kid.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:manifest": "node scripts/build-link-manifest.mjs",
    "build:og": "python3 scripts/build-og-images.py",
    "build:og:force": "python3 scripts/build-og-images.py --force",
    "build:og:safe": "python3 scripts/build-og-images.py || echo 'OG image build skipped (python/Pillow unavailable). Existing committed cards in public/og/ will ship.'",
    "build": "npm run build:manifest && npm run build:og:safe && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "illustrations:dry": "python3 scripts/build-illustrations.py --dry-run",
    "illustrations:prompts": "python3 scripts/build-illustrations.py --print-prompts",
    "illustrations:generate": "python3 scripts/build-illustrations.py",
    "imports:process": "python3 scripts/process-imports.py",
    "imports:dry": "python3 scripts/process-imports.py --dry-run",
    "illustrations:wire": "python3 scripts/wire-illustrations.py",
    "illustrations:wire:dry": "python3 scripts/wire-illustrations.py --dry-run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/tailwind": "^5.1.0",
    "@fontsource/fraunces": "^5.0.20",
    "@fontsource/inter": "^5.0.20",
    "@fontsource/jetbrains-mono": "^5.0.20",
    "@fontsource/mulish": "^5.0.20",
    "astro": "^4.16.0",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@types/node": "^22.7.5",
    "wrangler": "^4.88.0"
  }
}

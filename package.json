{
  "name": "parent-coach-desk",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "The Parent Coach Desk. Editorial content for parents who coach their own kid.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:manifest": "node scripts/build-link-manifest.mjs",
    "build:coverage": "node scripts/build-content-coverage.mjs",
    "check:coverage": "node scripts/build-content-coverage.mjs --check",
    "check:directory-remediation": "node scripts/check-directory-remediation-packet.mjs",
    "build:og": "python3 scripts/build-og-images.py",
    "build:og:force": "python3 scripts/build-og-images.py --force",
    "build:og:safe": "python3 scripts/build-og-images.py || echo 'OG image build skipped (python/Pillow unavailable). Existing committed cards in public/og/ will ship.'",
    "build": "npm run build:manifest && npm run build:og:safe && astro build",
    "build:production": "node scripts/build-production.mjs",
    "deploy:staging:verified": "node scripts/deploy-staging-verified.mjs",
    "check:production-manifest": "npm run build:production && node scripts/check-deployment-manifest.mjs",
    "check:staging-manifest": "npm run build && node scripts/check-staging-deployment-manifest.mjs",
    "check:secrets": "node scripts/scan-secrets.mjs --history",
    "check:protected-routes": "node scripts/check-protected-routes.mjs",
    "check:public-policy": "node scripts/check-public-policy-contract.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "illustrations:dry": "python3 scripts/build-illustrations.py --dry-run",
    "illustrations:prompts": "python3 scripts/build-illustrations.py --print-prompts",
    "illustrations:generate": "python3 scripts/build-illustrations.py",
    "imports:process": "python3 scripts/process-imports.py",
    "imports:dry": "python3 scripts/process-imports.py --dry-run",
    "illustrations:wire": "python3 scripts/wire-illustrations.py",
    "illustrations:wire:dry": "python3 scripts/wire-illustrations.py --dry-run",
    "check": "astro check",
    "check:workflow-pins": "node scripts/check-workflow-action-pins.mjs",
    "check:release-evidence": "node scripts/check-release-evidence.mjs coordination/release-evidence/rc01.json --structure-only",
    "check:rollback-target": "node scripts/check-worker-rollback-target.mjs coordination/release-evidence/worker-rollback-target-2026-07-16.json",
    "check:recovery-tabletop": "node scripts/check-recovery-tabletop.mjs coordination/release-evidence/recovery-tabletop-2026-07-16.json",
    "check:failure-isolation": "node scripts/check-failure-isolation-evidence.mjs coordination/release-evidence/integrated-failure-isolation-2026-07-16.json",
    "check:access-evidence": "node scripts/check-access-evidence.mjs coordination/release-evidence/access-policy-export-pending.json coordination/release-evidence/authenticated-access-probes-pending.json",
    "check:trust-migration-rehearsal": "node scripts/check-trust-migration-rehearsal.mjs coordination/release-evidence/trust-migration-rehearsal-2026-07-16.json",
    "check:production-schema-compatibility": "node scripts/check-production-schema-compatibility.mjs coordination/release-evidence/production-schema-compatibility-2026-07-16.json",
    "check:staging-pcd-ops-rehearsal": "node scripts/check-staging-pcd-ops-rehearsal.mjs coordination/release-evidence/staging-pcd-ops-rehearsal-2026-07-16.json",
    "proof:workos:preflight": "node scripts/workos-authkit-proof-preflight.mjs",
    "check:public-intake": "node scripts/check-public-intake-contract.mjs",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:links": "node scripts/check-customer-artifact.mjs",
    "check:customer-artifact": "node scripts/check-customer-artifact.mjs",
    "check:affiliates": "node scripts/check-affiliate-inventory.mjs",
    "report:affiliates": "node scripts/check-affiliate-inventory.mjs --report",
    "check:newsletter-proof": "node scripts/newsletter-provider-proof.mjs coordination/release-evidence/newsletter-provider-proof-pending.json",
    "monitor:customer-journey": "node scripts/run-customer-journey-monitor.mjs",
    "recovery:manifest": "node scripts/build-recovery-batch-manifest.mjs",
    "drill:staging-notification": "node scripts/run-staging-notification-drill.mjs --confirm",
    "audit:gate": "npm audit --audit-level=high",
    "ci:release": "npm run audit:gate && npm run check:workflow-pins && npm run check:secrets && npm run check:protected-routes && npm run check:public-policy && npm run check:coverage && npm run check:directory-remediation && npm run check:public-intake && npm run check:affiliates && npm run check:newsletter-proof && npm run check:release-evidence && npm run check:rollback-target && npm run check:recovery-tabletop && npm run check:failure-isolation && npm run check:access-evidence && npm run check:trust-migration-rehearsal && npm run check:production-schema-compatibility && npm run check:staging-pcd-ops-rehearsal && npm run check:production-manifest && npm run check:customer-artifact && npm run test:integration && npm run check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.18",
    "@fontsource/fraunces": "^5.0.20",
    "@fontsource/jetbrains-mono": "^5.0.20",
    "@fontsource/mulish": "^5.0.20",
    "@sentry/astro": "^10.66.0",
    "@sentry/cloudflare": "^10.66.0",
    "@tailwindcss/vite": "^4.1.0",
    "@workos-inc/node": "10.7.0",
    "@workos/authkit-astro": "0.2.0",
    "astro": "^7.0.9",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "tailwindcss": "^4.1.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@babel/parser": "^7.29.3",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.7.5",
    "@vitest/coverage-v8": "4.1.10",
    "linkinator": "^7.6.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.88.0"
  }
}

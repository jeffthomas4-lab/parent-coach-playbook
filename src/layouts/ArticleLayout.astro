---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import BuyingGuideDisclosure from '../components/BuyingGuideDisclosure.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { PILLARS, SPORTS, AGE_BANDS, SITE, EDITORIAL, authorEntity, themeFor } from '../data/site';
import { isLive } from '../lib/publishFilter';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, id: slug } = article;
// FTC 16 CFR Part 255: affiliate disclosure must be clear, conspicuous, and
// placed before the first affiliate link. Computed from the raw body so it
// only renders on articles that actually contain /go/ redirect links.
const hasAffiliateLinks = (article.body ?? '').includes('/go/');
const pillar = PILLARS[data.phase];
const sportLabel = SPORTS.find(s => s.slug === data.sport)?.label;
const ageLabel = AGE_BANDS.find(a => a.slug === data.age)?.label;

// Related: same phase, exclude this article, top 3
const related = (await getCollection('articles', ({ data: d, id: s }) =>
  isLive(d) && d.phase === data.phase && s !== slug
)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// JSON-LD: Article schema. Author entity is resolved via authorEntity()
// — Organization while AUTHOR_REVEALED is false, Person after the November
// flip. Visible bylines stay editorial-branded either way. Publisher is the
// Organization. Image upgraded to a full ImageObject for image search.
// Dimensions are omitted unless we're sure of them (og-default is the only
// file at a known aspect ratio); hero illustrations vary in size and lying
// to Google about dimensions hurts more than helps.
const reviewedAt = data.editorial?.jeffReviewedAt ?? data.editorial?.claudeReviewedAt;
const hasOgOverride = !!(data as any).ogImage;
// Per-article OG image generated by scripts/build-og-images.py at
// /og/{slug}.jpg. Slug-keyed and committed to the repo so social
// previews are unique per article without a runtime image service.
const ogImagePath = (data as any).ogImage ?? `/og/${slug}.jpg`;
const ogImageUrl = new URL(ogImagePath, SITE.url).toString();
const heroImage = (data as any).ogImage ?? (data.hero ? data.hero : '/og-default.jpg');
const heroImageUrl = new URL(heroImage, SITE.url).toString();
const heroAlt = (data as any).heroAlt ?? data.title.replace(/\*/g, '');
const imageObject: Record<string, unknown> = {
  '@type': 'ImageObject',
  url: heroImageUrl,
  caption: heroAlt,
  representativeOfPage: true,
  creator: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  copyrightHolder: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  copyrightNotice: `© ${new Date().getFullYear()} ${SITE.name}`,
  creditText: SITE.name,
  acquireLicensePage: `${SITE.url}/terms/`,
  license: `${SITE.url}/terms/`,
  contentUrl: heroImageUrl,
};
// Only assert dimensions when we're confident: ogImage overrides go through
// the Open Graph 1200x630 mold; hero illustrations vary, so let Google infer.
if (hasOgOverride || heroImage === '/og-default.jpg') {
  imageObject.width = 1200;
  imageObject.height = 630;
}
// Description preference: bluf (snippet-shaped) > seoDescription > dek. The bluf
// is the answer-first 30-50 word paragraph parents will see in a featured snippet,
// so it's also the strongest signal to Google about what this article answers.
const articleDescription = data.bluf ?? (data as any).seoDescription ?? data.dek;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title.replace(/\*/g, ''),
  description: articleDescription,
  image: imageObject,
  author: authorEntity(),
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/og-default.jpg` },
  },
  datePublished: data.publishedAt.toISOString(),
  dateModified: new Date(reviewedAt ?? data.publishedAt).toISOString(),
  mainEntityOfPage: `${SITE.url}/${data.phase}/${slug}/`,
  articleSection: pillar.label,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: pillar.label, item: `${SITE.url}/${data.phase}/` },
    { '@type': 'ListItem', position: 3, name: data.title.replace(/\*/g, '') },
  ],
};

// FAQPage schema — only rendered when the article frontmatter includes a `faqs` array.
// Targets Google's FAQ rich result (collapsible Q&A in SERPs).
// Limit: Google renders at most 3 Q&A pairs in the rich result, but all pairs are
// indexed. Optimal: 3-5 questions that are genuinely distinct and under 300 chars each.
const faqSchema = data.faqs && data.faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faqs.map(({ question, answer }) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: answer,
        },
      })),
    }
  : null;

const tagBits = [
  pillar.label,
  sportLabel,
  ageLabel ? `age ${ageLabel}` : null,
].filter(Boolean);
const titleHtml = data.title.replace(/\*([^*]+)\*/g, '<em>$1</em>');
const isShort = data.format === 'note';

// Theme for the topic chip in the article header. Prefer the explicit topic
// taxonomy when present, fall back to the phase pillar.
const articleTheme = themeFor(data.topic ?? data.phase);
const topicChipLabel = data.topic ? articleTheme.label : pillar.label;

// Sidebar rail. Top 4 related links (vertical list). Reuse the `related`
// query already computed above. Surface the title and a short tag suffix.
const sidebarRelated = related.slice(0, 4);

// Last reviewed: surface the most recent editorial review date if it exceeds publishedAt.
const reviewedRaw = data.editorial?.jeffReviewedAt ?? data.editorial?.claudeReviewedAt;
const reviewedDate = reviewedRaw ? new Date(reviewedRaw) : null;
const showReviewed = reviewedDate !== null && reviewedDate.getTime() > data.publishedAt.getTime();
// timeZone: 'UTC' is required because publishedAt parses to midnight UTC and
// the build runs in the deployer's local TZ. Without it, dates render one day
// early for any deployer west of UTC.
const dateOpts = { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' } as const;
---
<BaseLayout
  title={(data as any).seoTitle ?? data.title.replace(/\*/g, '')}
  description={(data as any).seoDescription ?? data.dek ?? SITE.description}
  ogType="article"
  ogImage={ogImagePath}
  publishedAt={data.publishedAt.toISOString()}
  modifiedAt={showReviewed && reviewedDate ? reviewedDate.toISOString() : undefined}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Soft pillar tint as the page accent -->
  <div style={`background: ${pillar.accentBg};`}>
    <div class="container-px pt-6 pb-4">
      <!-- Visible breadcrumb: Home › Pillar › Article -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="flex flex-wrap items-center gap-1 font-display italic text-ink-soft font-medium" style="font-size: 0.82rem;">
          <li><a href="/" class="hover:text-rust">Home</a></li>
          <li aria-hidden="true" class="mx-1">›</li>
          <li><a href={`/${data.phase}/`} class="hover:text-rust">{pillar.label}</a></li>
          {data.sport && sportLabel && (
            <>
              <li aria-hidden="true" class="mx-1">›</li>
              <li><a href={`/sports/${data.sport}/`} class="hover:text-rust">{sportLabel}</a></li>
            </>
          )}
        </ol>
      </nav>
      <span
        class="tag-pill"
        style={`--pill-accent: ${articleTheme.accent}; --pill-bg: ${articleTheme.accentBg};`}
      >
        {topicChipLabel}
      </span>
      {sportLabel && (
        <a
          href={`/sports/${data.sport}/`}
          class="font-display italic text-ink-soft hover:text-rust ml-3 transition-colors"
          style="font-size: 0.95rem;"
        >
          {sportLabel}
        </a>
      )}
      {ageLabel && (
        <span class="font-display italic text-ink-soft ml-2" style="font-size: 0.95rem;">
          {sportLabel ? '·' : ''} age {ageLabel}
        </span>
      )}
    </div>
  </div>

  <div class="container-px py-10 md:py-14">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14">
      <article class="lg:col-span-8">
        <header>
          <h1
            class={`font-display text-ink leading-[1.05] font-medium ${isShort ? 'text-[2rem] md:text-[2.75rem]' : 'text-[2.25rem] md:text-[3.75rem]'}`}
            set:html={titleHtml}
          />
          {data.dek && !isShort && (
            <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 leading-snug">
              {data.dek}
            </p>
          )}

          <!-- Byline -->
          <div class="mt-8 pt-5 border-t border-bone">
            <div class="font-display italic text-rust font-medium">
              {EDITORIAL.byline}
            </div>
            <div class="font-display italic text-ink-soft text-sm mt-1">
              Published {data.publishedAt.toLocaleDateString('en-US', dateOpts)}
              {showReviewed && reviewedDate && (
                <span> · Last reviewed {reviewedDate.toLocaleDateString('en-US', dateOpts)}</span>
              )}
              {' · '}
              {isShort ? 'short read' : 'longer read'}
            </div>
          </div>
        </header>

        {data.hero && (
          <div class="mt-10 rounded-lg overflow-hidden">
            <img
              src={data.hero}
              alt={data.heroAlt ?? data.title}
              class="w-full object-cover"
              style="max-height: 480px;"
              loading="eager"
            />
          </div>
        )}

        {data.bluf && (
          <aside class="mt-10 border-l-4 border-rust pl-5 py-1" aria-label="Quick answer">
            <p class="font-mono text-rust uppercase text-[0.7rem] tracking-label mb-2 font-medium">
              The short version
            </p>
            <p class="font-display text-ink text-lg md:text-xl leading-snug" style="font-weight: 500;">
              {data.bluf}
            </p>
          </aside>
        )}

        <div class={`article-body ${isShort ? 'mt-8' : 'mt-12'}`}>
          {hasAffiliateLinks && <BuyingGuideDisclosure />}
          <slot />
        </div>

        <!-- Editorial note at the bottom -->
        <aside class="mt-16 pt-8 border-t border-bone">
          <p class="font-display italic text-rust mb-2 font-medium">About this piece</p>
          <p class="font-display text-ink-soft text-sm leading-snug">
            Written and edited by {EDITORIAL.byline}. Sources reviewed against governing-body guidance where possible. Corrections welcome at <a href={`mailto:${SITE.email}`} class="hover:text-rust underline-offset-2 hover:underline">{SITE.email}</a>.
          </p>
          {hasAffiliateLinks && (
            <p class="font-display italic text-ink-soft text-sm leading-snug mt-3">
              Some links in this piece are affiliate links. <a href="/disclosure/" class="hover:text-rust underline-offset-2 hover:underline">Read our disclosure</a>.
            </p>
          )}
        </aside>
      </article>

      <!-- Right rail. Hidden on mobile, drops below the article on smaller
           screens. Holds the compact newsletter signup and a vertical list of
           more reads from the same phase. Ad slot wiring will land when an
           ad network goes live (months out). -->
      <aside class="lg:col-span-4 lg:sticky lg:top-8 lg:self-start space-y-6">
        <NewsletterSignup
          variant="compact"
          headline="Slide into the inbox"
          blurb="One short read a week. Easy unsubscribe."
          buttonLabel="Subscribe"
        />

        {sidebarRelated.length > 0 && (
          <div class="border border-bone bg-paper-warm rounded-lg p-5">
            <p class="font-display italic text-rust mb-3 font-medium" style="font-size: 0.95rem;">
              More from {pillar.label.toLowerCase()}
            </p>
            <ul class="space-y-3">
              {sidebarRelated.map((r) => (
                <li>
                  <a
                    href={`/${r.data.phase}/${r.id}/`}
                    class="font-display text-ink hover:text-rust block leading-snug"
                    style="font-size: 1rem; font-weight: 500;"
                    set:html={r.data.title.replace(/\*([^*]+)\*/g, '<em>$1</em>')}
                  />
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>

  <RelatedArticles articles={related} pillarLabel={pillar.label} />
</BaseLayout>

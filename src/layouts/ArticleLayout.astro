---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { PILLARS, SPORTS, AGE_BANDS, SITE } from '../data/site';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, slug } = article;
const pillar = PILLARS[data.phase];
const sportLabel = SPORTS.find(s => s.slug === data.sport)?.label;
const ageLabel = AGE_BANDS.find(a => a.slug === data.age)?.label;

// "More from this drive" — same pillar, exclude this article, top 3
const related = (await getCollection('articles', ({ data: d, slug: s }) =>
  !d.draft && d.phase === data.phase && s !== slug
)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Article JSON-LD
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title.replace(/\*/g, ''),
  description: data.dek,
  author: { '@type': data.author === 'Jeff Thomas' ? 'Person' : 'Organization', name: data.author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/og-default.png` },
  },
  datePublished: data.publishedAt.toISOString(),
  mainEntityOfPage: `${SITE.url}/${data.phase}/${slug}/`,
};

// Breadcrumb JSON-LD
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: pillar.label, item: `${SITE.url}/${data.phase}/` },
    { '@type': 'ListItem', position: 3, name: data.title.replace(/\*/g, '') },
  ],
};

const filedUnder = [pillar.label, sportLabel, ageLabel].filter(Boolean).join(' / ');
const titleHtml = data.title.replace(/\*([^*]+)\*/g, '<em>$1</em>');
---
<BaseLayout
  title={data.title.replace(/\*/g, '')}
  description={data.dek ?? SITE.description}
  ogType="article"
  publishedAt={data.publishedAt.toISOString()}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Top metadata rule -->
  <div class="border-t border-ink">
    <div class="container-px py-3 flex flex-wrap justify-between gap-2">
      <span class="t-label text-ink">
        {data.issue ? `Issue ${String(data.issue).padStart(3, '0')}` : 'Editorial'} / Filed under {filedUnder}
      </span>
      <span class="t-label text-ink-soft">
        {data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>
  </div>

  <article class="container-px py-12 md:py-20">
    <header class="max-w-prose mx-auto">
      <h1
        class="font-display text-ink font-semibold text-[2.25rem] md:text-[3.75rem] leading-[1.0]"
        set:html={titleHtml}
      />
      {data.dek && (
        <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 leading-snug">
          {data.dek}
        </p>
      )}
      <div class="t-label text-ink-soft mt-8 flex items-center gap-3">
        <span>By {data.author}</span>
        <span aria-hidden="true">·</span>
        <span>{data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
      </div>
    </header>

    <div class="article-body mx-auto mt-12">
      <slot />
    </div>
  </article>

  <RelatedArticles articles={related} pillarLabel={pillar.label} />
  <LeadMagnetCTA />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ThreeDrivesNav from '../components/ThreeDrivesNav.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { PILLARS, SPORTS, AGE_BANDS, type PillarSlug } from '../data/site';
import { isLive } from '../lib/publishFilter';

interface Props {
  pillar: PillarSlug;
}

const { pillar } = Astro.props;
const meta = PILLARS[pillar];

const articles = (await getCollection('articles', ({ data }) => isLive(data) && data.phase === pillar))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Collect tags actually used in this pillar
const sportsUsed = [...new Set(articles.map(a => a.data.sport).filter(Boolean))] as string[];
const agesUsed = [...new Set(articles.map(a => a.data.age).filter(Boolean))] as string[];
---
<BaseLayout
  title={meta.label}
  description={meta.blurb}
>
  <section
    class="border-b border-bone"
    style={`background: ${meta.accentBg};`}
  >
    <div class="container-px py-16 md:py-20 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8">
        <div
          class="font-display italic"
          style={`color: ${meta.accent}; font-weight: 500; font-size: 1rem;`}
        >
          {meta.eyebrow}
        </div>
        <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] mt-4 font-medium">
          {meta.label}
        </h1>
        <p class="font-display text-ink-soft text-xl mt-6 max-w-2xl leading-snug">
          {meta.blurb}
        </p>
        {pillar === 'drive-there' && (
          <figure class="mt-10">
            <img
              src="/illustrations/pillar-drive-there.webp"
              alt="Interior of a car at dawn — a parent's hands on the wheel, sport bag and water bottle visible, sunrise through the windshield."
              class="w-full max-w-2xl border border-bone"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </figure>
        )}
        {pillar === 'drive-home' && (
          <figure class="mt-10">
            <img
              src="/illustrations/pillar-drive-home.webp"
              alt="Same car interior at dusk — kid asleep in back seat with a helmet in their lap, warm streetlight glow, parent visible only as a shoulder."
              class="w-full max-w-2xl border border-bone"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </figure>
        )}
      </div>
      <aside class="lg:col-span-4 lg:pl-8 lg:border-l lg:border-bone">
        <ThreeDrivesNav active={pillar} />
      </aside>
    </div>
  </section>

  {articles.length > 0 && (
    <section>
      <div class="container-px py-12">
        <div
          class="flex flex-wrap gap-2 mb-2"
          data-filter-bar
          style={`--pill-accent: ${meta.accent}; --pill-bg: ${meta.accentBg};`}
        >
          <button data-filter="all" class="tag-pill tag-pill-active" type="button">All issues</button>
          {sportsUsed.map(s => (
            <button data-filter-sport={s} class="tag-pill tag-pill-outline" type="button">
              {SPORTS.find(x => x.slug === s)?.label ?? s}
            </button>
          ))}
          {agesUsed.map(a => (
            <button data-filter-age={a} class="tag-pill tag-pill-outline" type="button">
              Age {AGE_BANDS.find(x => x.slug === a)?.label ?? a}
            </button>
          ))}
        </div>

        <div data-article-list>
          {articles.map((a) => (
            <div data-sport={a.data.sport ?? ''} data-age={a.data.age ?? ''}>
              <ArticleCard
                href={`/${a.data.phase}/${a.slug}/`}
                contributor={a.data.contributor}
                format={a.data.format}
                sport={a.data.sport}
                age={a.data.age}
                phase={a.data.phase}
                topic={a.data.topic}
                title={a.data.title}
                dek={a.data.dek}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {articles.length === 0 && (
    <section>
      <div class="container-px py-20">
        <p class="font-display text-ink-soft text-xl">First issue is in the chamber. Subscribe below to get it.</p>
      </div>
    </section>
  )}

  <NewsletterSignup />
</BaseLayout>

<script>
  const bar = document.querySelector('[data-filter-bar]');
  const list = document.querySelector('[data-article-list]');
  if (bar && list) {
    bar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'BUTTON') return;

      // Reset visual state. Every chip back to outline.
      bar.querySelectorAll('button').forEach((b) => {
        b.classList.remove('tag-pill-active');
        b.classList.add('tag-pill-outline');
      });
      target.classList.remove('tag-pill-outline');
      target.classList.add('tag-pill-active');

      const sport = target.getAttribute('data-filter-sport');
      const age = target.getAttribute('data-filter-age');
      const all = target.getAttribute('data-filter') === 'all';

      list.querySelectorAll('[data-sport]').forEach((row) => {
        const r = row as HTMLElement;
        if (all) {
          r.style.display = '';
          return;
        }
        if (sport) {
          r.style.display = r.dataset.sport === sport ? '' : 'none';
        } else if (age) {
          r.style.display = r.dataset.age === age ? '' : 'none';
        }
      });
    });
  }
</script>

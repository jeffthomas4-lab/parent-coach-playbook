---
// Rounded sentence-case pill. Auto-tints to the topic / phase / sport accent
// when a `tone` slug is passed (looked up via themeFor). Falls back to the
// neutral cream-on-walnut look otherwise.
//
// Variant is preserved for backwards compatibility with any older callers,
// but `tone` is the new way to drive color.
import { themeFor, type Theme } from '../data/site';

interface Props {
  label: string;
  href?: string;
  tone?: string;                            // section/topic/phase slug
  variant?: 'default' | 'phase' | 'sport' | 'age' | 'topic';
  style?: 'soft' | 'outline' | 'active';    // soft fill (default), outline, or active
}

const {
  label,
  href,
  tone,
  variant = 'default',
  style = 'soft',
} = Astro.props;

// Variant -> tone fallback when tone isn't passed explicitly. Keeps the
// previous semantic API working while we migrate callers.
const variantToneFallback: Record<string, string | undefined> = {
  phase: 'game',
  sport: undefined,    // sports don't have themes; render neutral
  age: undefined,
  topic: undefined,
};

const resolvedTone = tone ?? variantToneFallback[variant];
const theme: Theme = themeFor(resolvedTone);

const cls = [
  'tag-pill',
  style === 'outline' ? 'tag-pill-outline' : '',
  style === 'active' ? 'tag-pill-active' : '',
].filter(Boolean).join(' ');

// Inline style supplies the per-topic colors via CSS variables. Falls back to
// the neutral pill colors when no tone is provided.
const inlineStyle = resolvedTone
  ? `--pill-accent: ${theme.accent}; --pill-bg: ${theme.accentBg};`
  : '';
---
{href ? (
  <a href={href} class={cls} style={inlineStyle}>{label}</a>
) : (
  <span class={cls} style={inlineStyle}>{label}</span>
)}

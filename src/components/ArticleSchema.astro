---
// JSON-LD Article schema for individual reads.
// Drop into any [slug].astro page that renders article-shaped content.
//
// The site is intentionally anonymous. Author is the publishing Organization,
// not a named Person. This is the trade-off of an editorial brand: weaker
// E-E-A-T Person signal, but no individual identity exposed.

import { SITE } from '../data/site';

interface Props {
  title: string;
  description?: string;
  publishedAt: Date;
  modifiedAt?: Date;
  image?: string;
  url: string;
  articleSection?: string;
}

const {
  title,
  description,
  publishedAt,
  modifiedAt,
  image,
  url,
  articleSection,
} = Astro.props;

const imageUrl = image
  ? new URL(image, SITE.url).toString()
  : new URL('/og-default.jpg', SITE.url).toString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description ?? SITE.description,
  image: imageUrl,
  datePublished: publishedAt.toISOString(),
  dateModified: (modifiedAt ?? publishedAt).toISOString(),
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-default.jpg', SITE.url).toString(),
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  ...(articleSection ? { articleSection } : {}),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

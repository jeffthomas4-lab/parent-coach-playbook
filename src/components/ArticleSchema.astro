---
// JSON-LD Article schema for individual reads.
// Drop into any [slug].astro page that renders article-shaped content.
//
// Author entity is resolved through authorEntity() in site.ts. While
// AUTHOR_REVEALED is false the author is the editorial Organization;
// after the November flip, it becomes the named Person (Jeff). Visible
// bylines on cards and articles always stay editorial-branded — only
// the JSON-LD author identity flips.

import { SITE, SCHEMA_IDS, authorEntity } from '../data/site';
import { serializeJsonLd } from '../lib/jsonld';

interface Props {
  title: string;
  description?: string;
  publishedAt: Date;
  modifiedAt?: Date;
  image?: string;
  url: string;
  articleSection?: string;
}

const {
  title,
  description,
  publishedAt,
  modifiedAt,
  image,
  url,
  articleSection,
} = Astro.props;

const imageUrl = image
  ? new URL(image, SITE.url).toString()
  : new URL('/og-default.jpg', SITE.url).toString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description ?? SITE.description,
  image: {
    '@type': 'ImageObject',
    url: imageUrl,
    copyrightNotice: `© ${new Date().getFullYear()} ${SITE.name}`,
    creditText: SITE.name,
    acquireLicensePage: `${SITE.url}/terms/`,
    license: `${SITE.url}/terms/`,
  },
  datePublished: publishedAt.toISOString(),
  dateModified: (modifiedAt ?? publishedAt).toISOString(),
  author: authorEntity(),
  publisher: {
    '@type': 'Organization',
    '@id': SCHEMA_IDS.organization,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  ...(articleSection ? { articleSection } : {}),
};
---
<script type="application/ld+json" set:html={serializeJsonLd(schema)} />

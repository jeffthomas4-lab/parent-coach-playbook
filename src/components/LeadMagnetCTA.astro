---
import NewsletterSignup from './NewsletterSignup.astro';

interface Props {
  title?: string;
  blurb?: string;
  formId?: string;
}

const {
  title = 'The Drive Home Playbook',
  blurb = 'A free 10-page guide. The exact words to say in the first 90 seconds after a youth game, by sport and by age. Plus the practice plan template, the next playbook, and one short read a week.',
  formId = import.meta.env.PUBLIC_KIT_LEAD_MAGNET_FORM_ID,
} = Astro.props;
---
<aside class="bg-rust text-paper py-14">
  <div class="container-px grid md:grid-cols-12 gap-8 items-end">
    <div class="md:col-span-7">
      <p class="font-display italic text-trophy mb-3" style="font-weight: 500;">Free downloads</p>
      <h2 class="font-display text-paper text-4xl md:text-5xl leading-[1.05]" style="font-weight: 500;">
        {title}
      </h2>
      <p class="font-display text-paper-warm mt-4 text-lg max-w-xl leading-snug">
        {blurb}
      </p>
    </div>
    <div class="md:col-span-5">
      <NewsletterSignup
        variant="card"
        headline="Subscribe to get them"
        blurb="One subscribe, every download we ship. One short read a week. Easy unsubscribe."
        buttonLabel="Send the downloads"
        formId={formId}
      />
    </div>
  </div>
</aside>

---
import NewsletterSignup from './NewsletterSignup.astro';

interface Props {
  title?: string;
  blurb?: string;
  formId?: string;
}

const {
  title = 'What to Say When',
  blurb = 'A free 28-page field guide. Twenty-three scripts for the moments before and after the game, and the hard ones in between. Plus the practice plan template, the next playbook, and one short read a week.',
  formId = import.meta.env.PUBLIC_KIT_LEAD_MAGNET_FORM_ID,
} = Astro.props;
---
<aside class="bg-rust text-paper py-14">
  <div class="container-px grid md:grid-cols-12 gap-8 items-end">
    <div class="md:col-span-7">
      <p class="font-display italic text-trophy mb-3 font-medium">Free downloads</p>
      <h2 class="font-display text-paper text-4xl md:text-5xl leading-[1.05] font-medium">
        {title}
      </h2>
      <p class="font-display text-paper-warm mt-4 text-lg max-w-xl leading-snug">
        {blurb}
      </p>
      {/* Field-guide thumbnail. Hand-illustrated family calendar previewing the
          kind of templates inside the download. Hidden on small screens to keep
          the CTA tight on mobile. */}
      <div class="hidden md:block mt-7 max-w-md">
        <img
          src="/illustrations/family-season-calendar.webp"
          alt="A hand-illustrated family wall calendar with color-coded kids, sports, and activities — a preview of the templates inside the field guide."
          class="w-full h-auto rounded-sm shadow-lg border-2 border-paper-warm"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
    <div class="md:col-span-5">
      <NewsletterSignup
        variant="card"
        headline="Get the Friday Letter to get them"
        blurb="One subscribe, every download we ship. One short read a week. Easy unsubscribe."
        buttonLabel="Send the downloads"
        formId={formId}
      />
    </div>
  </div>
</aside>

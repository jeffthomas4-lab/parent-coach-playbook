---
// Steering wheel mark inside a dark circle.
// Three spokes (top, left, right) with a center dot.
// Optional dashed rust ring as a "road" reference.
//
// Variants:
//   variant="dark"   — ink fill, paper spokes (default)
//   variant="light"  — paper fill, ink spokes (use on dark surfaces)
//   variant="accent" — rust fill, paper spokes
//
// Pass `withRing` to render the dashed road ring outside the wheel.

interface Props {
  variant?: 'dark' | 'light' | 'accent';
  size?: number;
  withRing?: boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  variant = 'dark',
  size = 56,
  withRing = false,
  ariaLabel = 'The Parent-Coach Playbook',
  class: className = '',
} = Astro.props;

const fill =
  variant === 'light' ? '#F7F3EC' :
  variant === 'accent' ? '#B54422' :
  '#1A1F2E';

const spoke =
  variant === 'light' ? '#1A1F2E' :
  '#F7F3EC';

const ringColor = '#B54422';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  width={size}
  height={size}
  role="img"
  aria-label={ariaLabel}
  class={className}
>
  {withRing && (
    <circle
      cx="32"
      cy="32"
      r="30"
      fill="none"
      stroke={ringColor}
      stroke-width="1"
      stroke-dasharray="2 3"
    />
  )}
  <circle cx="32" cy="32" r="26" fill={fill} />
  {/* Outer thin ring (rim) */}
  <circle cx="32" cy="32" r="22.5" fill="none" stroke={spoke} stroke-width="1.5" />
  {/* Spokes — top, left, right (no bottom spoke per brand spec) */}
  <line x1="32" y1="9.5" x2="32" y2="22.5" stroke={spoke} stroke-width="2" stroke-linecap="round" />
  <line x1="9.5" y1="32" x2="22.5" y2="32" stroke={spoke} stroke-width="2" stroke-linecap="round" />
  <line x1="54.5" y1="32" x2="41.5" y2="32" stroke={spoke} stroke-width="2" stroke-linecap="round" />
  {/* Center dot (hub) */}
  <circle cx="32" cy="32" r="3.25" fill={spoke} />
</svg>

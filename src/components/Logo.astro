---
// Wordmark for Parent Coach Playbook.
// Three words. "Parent Coach" warm ink, "Playbook" terracotta italic.
//
// Variants:
//   variant="dark"   — warm-ink + terracotta (default, on cream)
//   variant="light"  — paper + honey (use on dark surfaces)
//   variant="solid"  — single-color warm-ink (subtle contexts)

interface Props {
  variant?: 'dark' | 'light' | 'solid';
  size?: number;        // px font-size for the mark
  ariaLabel?: string;
  class?: string;
}

const {
  variant = 'dark',
  size = 22,
  ariaLabel = 'Parent Coach Playbook',
  class: className = '',
} = Astro.props;

const baseColor =
  variant === 'light' ? '#FAF6EE' :
  '#2D2520';

const accentColor =
  variant === 'light' ? '#D4AB6A' :
  variant === 'solid' ? '#2D2520' :
  '#C5713D';
---
<a
  href="/"
  aria-label={ariaLabel}
  class={`group inline-flex items-baseline ${className}`}
  style="text-decoration: none; white-space: nowrap;"
>
  <span
    style={`
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-weight: 500;
      font-size: ${size}px;
      line-height: 1;
      letter-spacing: -0.005em;
      color: ${baseColor};
    `}
  >Parent Coach </span><span
    style={`
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-weight: 500;
      font-size: ${size}px;
      line-height: 1;
      letter-spacing: -0.005em;
      color: ${accentColor};
    `}
  >Playbook</span>
</a>

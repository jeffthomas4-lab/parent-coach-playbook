---
// Pure typographic wordmark. No icon.
// Italic Fraunces "Pcp" with the lowercase letters in terracotta.
// This is the brand mark across the whole site.
//
// Variants:
//   variant="dark"   — warm-ink P, terracotta cp (default, on cream)
//   variant="light"  — paper P, honey cp (use on warm-ink surfaces)
//   variant="solid"  — all warm-ink (single-color contexts)
//
// `size` controls the font-size in pixels of the mark.
// `withTitle` shows the full wordmark beside the monogram.

interface Props {
  variant?: 'dark' | 'light' | 'solid';
  size?: number;
  withTitle?: boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  variant = 'dark',
  size = 40,
  withTitle = false,
  ariaLabel = 'The Parent-Coach Playbook',
  class: className = '',
} = Astro.props;

const inkColor =
  variant === 'light' ? '#FAF6EE' :
  variant === 'solid' ? '#2D2520' :
  '#2D2520';

const accentColor =
  variant === 'light' ? '#D4AB6A' :
  variant === 'solid' ? '#2D2520' :
  '#C5713D';

const titleColor =
  variant === 'light' ? '#FAF6EE' : '#2D2520';

const subtitleColor =
  variant === 'light' ? '#DDD2BD' : '#8A7E6E';
---
<a
  href="/"
  aria-label={ariaLabel}
  class={`flex items-center gap-3 group ${className}`}
  style="text-decoration: none;"
>
  <span
    style={`
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-weight: 500;
      font-size: ${size}px;
      line-height: 0.9;
      letter-spacing: -0.01em;
    `}
  >
    <span style={`color: ${inkColor};`}>P</span><span style={`color: ${accentColor};`}>cp</span>
  </span>
  {withTitle && (
    <span
      style={`
        border-left: 0.5px solid ${variant === 'light' ? '#5F5448' : '#C5B8A0'};
        padding-left: 12px;
        line-height: 1.15;
      `}
      class="hidden sm:flex flex-col"
    >
      <span
        style={`
          font-family: 'Fraunces', Georgia, serif;
          font-weight: 500;
          font-size: 0.95rem;
          color: ${titleColor};
          letter-spacing: -0.005em;
        `}
      >The Parent-Coach Playbook</span>
      <span
        style={`
          font-family: 'JetBrains Mono', Menlo, monospace;
          font-size: 0.6rem;
          letter-spacing: 0.16em;
          text-transform: uppercase;
          color: ${subtitleColor};
          margin-top: 2px;
        `}
      >Field & Forge Press</span>
    </span>
  )}
</a>

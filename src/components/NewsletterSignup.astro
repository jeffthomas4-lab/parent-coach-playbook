---
// Kit (formerly ConvertKit) inline signup form.
//
// IMPORTANT: 9388648 is the form's NUMERIC ID — that's what the
// /forms/<id>/subscriptions endpoint expects. The hash 4b28f916b5 you'll
// see on the hosted form (parent-coach-playbook.kit.com/4b28f916b5) is
// the form's data-uid, used for styling/tracking only. Don't swap them
// or POSTs get silently rejected. Override via PUBLIC_KIT_FORM_ID for
// branch previews. Lead-magnet flows can pass a different formId prop.

interface Props {
  variant?: 'inline' | 'card' | 'compact';
  headline?: string;
  blurb?: string;
  formId?: string;
  buttonLabel?: string;
  collectFirstName?: boolean;
}

const {
  variant = 'inline',
  headline = 'Slide into the inbox',
  blurb = 'One short read a week from the Parent Coach Playbook Editorial. Easy unsubscribe.',
  formId = import.meta.env.PUBLIC_KIT_FORM_ID || '9388648',
  buttonLabel = 'Subscribe',
  collectFirstName = true,
} = Astro.props;

const action = `https://app.kit.com/forms/${formId}/subscriptions`;
const isCard = variant === 'card';
const isCompact = variant === 'compact';
---
{isCompact ? (
  <aside class="border border-bone bg-paper-warm rounded-lg p-5">
    <p class="font-display italic text-rust mb-1 font-medium" style="font-size: 0.95rem;">
      Newsletter
    </p>
    <h3 class="font-display text-ink text-xl leading-tight font-medium">
      {headline}
    </h3>
    <p class="font-display text-ink-soft text-sm mt-2 leading-snug">
      {blurb}
    </p>
    <form
      action={action}
      method="POST"
      data-newsletter-form
      class="mt-4 grid gap-2"
    >
      {collectFirstName && (
        <div>
          <label class="sr-only" for="ns-first-name-compact">First name</label>
          <input
            type="text"
            id="ns-first-name-compact"
            name="fields[first_name]"
            placeholder="First name"
            autocomplete="given-name"
            class="w-full px-3 py-2 font-body border border-bone bg-paper text-ink rounded focus:outline-none focus:border-rust"
            style="font-size: 0.95rem;"
          />
        </div>
      )}
      <label class="sr-only" for="ns-email-compact">Email address</label>
      <input
        type="email"
        id="ns-email-compact"
        name="email_address"
        required
        placeholder="you@example.com"
        autocomplete="email"
        class="w-full px-3 py-2 font-body border border-bone bg-paper text-ink rounded focus:outline-none focus:border-rust"
        style="font-size: 0.95rem;"
      />
      <button type="submit" class="btn-soft mt-1">
        {buttonLabel}
      </button>
      <p class="font-display italic text-ink-soft text-xs mt-1">
        Easy unsubscribe.
      </p>
    </form>
  </aside>
) : (
  <section class={`${isCard ? 'border border-ink bg-ink text-paper p-10' : 'border-t border-b border-bone py-14'}`}>
    <div class={`${isCard ? '' : 'container-px'} grid md:grid-cols-12 gap-8 items-end`}>
      <div class="md:col-span-6">
        <p
          class="font-display italic mb-3"
          style={`font-weight: 500; color: ${isCard ? '#D4AB6A' : '#C5713D'};`}
        >
          Newsletter
        </p>
        <h3
          class={`font-display text-3xl md:text-[2.5rem] leading-[1.07] ${isCard ? 'text-paper' : 'text-ink'}`}
          class="font-medium"
        >
          {headline}
        </h3>
        <p class={`font-display mt-3 leading-snug ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
          {blurb}
        </p>
      </div>

      <form
        action={action}
        method="POST"
        data-newsletter-form
        class="md:col-span-6 grid gap-3"
      >
        {collectFirstName && (
          <div>
            <label class="sr-only" for="ns-first-name">First name</label>
            <input
              type="text"
              id="ns-first-name"
              name="fields[first_name]"
              placeholder="First name"
              autocomplete="given-name"
              class={`w-full px-4 py-3 font-body border rounded ${isCard ? 'bg-paper text-ink border-paper' : 'bg-paper text-ink border-bone'} focus:outline-none focus:border-rust`}
            />
          </div>
        )}
        <div class="flex flex-col sm:flex-row gap-2">
          <label class="sr-only" for="ns-email">Email address</label>
          <input
            type="email"
            id="ns-email"
            name="email_address"
            required
            placeholder="you@example.com"
            autocomplete="email"
            class={`flex-1 px-4 py-3 font-body border rounded ${isCard ? 'bg-paper text-ink border-paper' : 'bg-paper text-ink border-bone'} focus:outline-none focus:border-rust`}
          />
          <button type="submit" class="btn-soft">
            {buttonLabel}
          </button>
        </div>
        <p class={`font-display italic text-xs mt-1 ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
          We won't send you spam. Unsubscribe whenever.
        </p>
      </form>
    </div>
  </section>
)}

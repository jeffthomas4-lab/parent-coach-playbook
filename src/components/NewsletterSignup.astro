---
// Newsletter signup CTA.
//
// We link out to Kit's hosted form rather than embed our own. Kit's own
// page handles the subscription end-to-end (validation, confirmation
// email, redirect to /welcome/) which is more reliable than posting to
// their endpoint ourselves. The visitor briefly sees a Kit-hosted page,
// then lands back on parentcoachplaybook.com/welcome/ with the downloads.
//
// To swap the destination form, change KIT_HOSTED_URL.

interface Props {
  variant?: 'inline' | 'card' | 'compact';
  headline?: string;
  blurb?: string;
  buttonLabel?: string;
  /** kept for back-compat with callers; not currently used */
  formId?: string;
  /** kept for back-compat with callers; not currently used */
  collectFirstName?: boolean;
}

const {
  variant = 'inline',
  headline = 'Slide into the inbox',
  blurb = 'One short read a week from the Parent Coach Playbook Editorial. Easy unsubscribe.',
  buttonLabel = 'Subscribe',
} = Astro.props;

const KIT_HOSTED_URL = 'https://parent-coach-playbook.kit.com/4b28f916b5';
const isCard = variant === 'card';
const isCompact = variant === 'compact';
---
{isCompact ? (
  <aside class="border border-bone bg-paper-warm rounded-lg p-5">
    <p class="font-display italic text-rust mb-1 font-medium" style="font-size: 0.95rem;">
      Newsletter
    </p>
    <h3 class="font-display text-ink text-xl leading-tight font-medium">
      {headline}
    </h3>
    <p class="font-display text-ink-soft text-sm mt-2 leading-snug">
      {blurb}
    </p>
    <a
      href={KIT_HOSTED_URL}
      class="btn-soft mt-4 inline-block"
    >
      {buttonLabel}
    </a>
    <p class="font-display italic text-ink-soft text-xs mt-3">
      Easy unsubscribe.
    </p>
  </aside>
) : (
  <section class={`${isCard ? 'border border-ink bg-ink text-paper p-10' : 'border-t border-b border-bone py-14'}`}>
    <div class={`${isCard ? '' : 'container-px'} grid md:grid-cols-12 gap-8 items-end`}>
      <div class="md:col-span-6">
        <p
          class="font-display italic mb-3"
          style={`font-weight: 500; color: ${isCard ? '#D4AB6A' : '#C5713D'};`}
        >
          Newsletter
        </p>
        <h3
          class={`font-display text-3xl md:text-[2.5rem] leading-[1.07] font-medium ${isCard ? 'text-paper' : 'text-ink'}`}
        >
          {headline}
        </h3>
        <p class={`font-display mt-3 leading-snug ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
          {blurb}
        </p>
      </div>

      <div class="md:col-span-6">
        <a
          href={KIT_HOSTED_URL}
          class={`btn-soft inline-block ${isCard ? '' : ''}`}
        >
          {buttonLabel}
        </a>
        <p class={`font-display italic text-xs mt-3 ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
          We won't send you spam. Unsubscribe whenever.
        </p>
      </div>
    </div>
  </section>
)}

---
// Kit (formerly ConvertKit) inline signup form.
//
// Form ID 9388648 is the main newsletter form.
// Override via PUBLIC_KIT_FORM_ID env var for branch previews if needed.
// Lead-magnet flows can pass a different formId prop.

interface Props {
  variant?: 'inline' | 'card';
  headline?: string;
  blurb?: string;
  formId?: string;
  buttonLabel?: string;
  collectFirstName?: boolean;
}

const {
  variant = 'inline',
  headline = 'Slide into the inbox',
  blurb = 'One short read a week from the Parent Coach Playbook Editorial. Easy unsubscribe.',
  formId = import.meta.env.PUBLIC_KIT_FORM_ID || '9388648',
  buttonLabel = 'Subscribe',
  collectFirstName = true,
} = Astro.props;

const action = `https://app.kit.com/forms/${formId}/subscriptions`;
const isCard = variant === 'card';
---
<section class={`${isCard ? 'border border-ink bg-ink text-paper p-10' : 'border-t border-b border-bone py-14'}`}>
  <div class={`${isCard ? '' : 'container-px'} grid md:grid-cols-12 gap-8 items-end`}>
    <div class="md:col-span-6">
      <p
        class="font-display italic mb-3"
        style={`font-weight: 500; color: ${isCard ? '#D4AB6A' : '#C5713D'};`}
      >
        Newsletter
      </p>
      <h3
        class={`font-display text-3xl md:text-[2.5rem] leading-[1.07] ${isCard ? 'text-paper' : 'text-ink'}`}
        style="font-weight: 500;"
      >
        {headline}
      </h3>
      <p class={`font-display mt-3 leading-snug ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
        {blurb}
      </p>
    </div>

    <form
      action={action}
      method="POST"
      data-newsletter-form
      class="md:col-span-6 grid gap-3"
    >
      {collectFirstName && (
        <div>
          <label class="sr-only" for="ns-first-name">First name</label>
          <input
            type="text"
            id="ns-first-name"
            name="fields[first_name]"
            placeholder="First name"
            autocomplete="given-name"
            class={`w-full px-4 py-3 font-body border ${isCard ? 'bg-paper text-ink border-paper' : 'bg-paper text-ink border-bone'} focus:outline-none focus:border-rust`}
          />
        </div>
      )}
      <div class="flex flex-col sm:flex-row gap-0">
        <label class="sr-only" for="ns-email">Email address</label>
        <input
          type="email"
          id="ns-email"
          name="email_address"
          required
          placeholder="you@example.com"
          autocomplete="email"
          class={`flex-1 px-4 py-3 font-body border ${isCard ? 'bg-paper text-ink border-paper' : 'bg-paper text-ink border-bone'} focus:outline-none focus:border-rust`}
        />
        <button
          type="submit"
          class="btn"
          style="border-radius: 0;"
        >
          {buttonLabel}
        </button>
      </div>
      <p class={`font-display italic text-xs mt-1 ${isCard ? 'text-paper-warm' : 'text-ink-soft'}`}>
        We won't send you spam. Unsubscribe whenever.
      </p>
    </form>
  </div>
</section>

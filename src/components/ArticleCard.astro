---
import { PILLARS, SPORTS, AGE_BANDS, EDITORIAL, themeFor } from '../data/site';

interface Props {
  href: string;
  format?: 'note' | 'essay';
  sport?: string;
  age?: string;
  phase?: keyof typeof PILLARS;
  topic?: string;
  title: string;
  dek?: string;
  publishedAt?: Date | string;
  variant?: 'list' | 'grid' | 'compact';
}

const {
  href,
  format = 'note',
  sport,
  age,
  phase,
  topic,
  title,
  dek,
  publishedAt,
  variant = 'list',
} = Astro.props;

const sportLabel = SPORTS.find(s => s.slug === sport)?.label;
const ageLabel = AGE_BANDS.find(a => a.slug === age)?.label;

// Topic pill: prefer explicit topic, fall back to phase (always present on
// articles). themeFor() returns the rust default if neither resolves.
const chipTone  = topic ?? phase;
const chipTheme = themeFor(chipTone);
const chipLabel = chipTheme.label ?? (phase ? PILLARS[phase as keyof typeof PILLARS]?.label : null);

const fmtDate = (d: Date | string | undefined) => {
  if (!d) return null;
  const dt = typeof d === 'string' ? new Date(d) : d;
  return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
};

const dateLabel = fmtDate(publishedAt);
const tagBits = [
  format === 'essay' ? 'Longer read' : null,
  sportLabel,
  ageLabel ? `age ${ageLabel}` : null,
  dateLabel,
].filter(Boolean);

// Italicize the conceptual hinge in the headline
const renderTitle = (t: string) => t.replace(/\*([^*]+)\*/g, '<em>$1</em>');

const titleSize = format === 'essay'
  ? 'text-2xl md:text-[1.65rem]'
  : 'text-xl md:text-[1.4rem]';
---
<article class={`card-hover border-b border-bone py-6 ${variant === 'grid' ? 'border border-bone p-6' : ''}`}>
  <a href={href} class="block group">
    {chipLabel && (
      <span
        class="tag-pill mb-3"
        style={`--pill-accent: ${chipTheme.accent}; --pill-bg: ${chipTheme.accentBg};`}
      >
        {chipLabel}
      </span>
    )}
    <div class="mb-3">
      <div class="font-display italic text-rust font-medium" style="font-size: 0.85rem">
        {EDITORIAL.byline}
      </div>
      {tagBi
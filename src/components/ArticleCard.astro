---
import { PILLARS, SPORTS, AGE_BANDS, EDITORIAL } from '../data/site';

interface Props {
  href: string;
  format?: 'note' | 'essay';
  sport?: string;
  age?: string;
  phase?: keyof typeof PILLARS;
  title: string;
  dek?: string;
  publishedAt?: Date | string;
  variant?: 'list' | 'grid' | 'compact';
}

const {
  href,
  format = 'note',
  sport,
  age,
  phase,
  title,
  dek,
  publishedAt,
  variant = 'list',
} = Astro.props;

const sportLabel = SPORTS.find(s => s.slug === sport)?.label;
const ageLabel = AGE_BANDS.find(a => a.slug === age)?.label;

const fmtDate = (d: Date | string | undefined) => {
  if (!d) return null;
  const dt = typeof d === 'string' ? new Date(d) : d;
  return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const dateLabel = fmtDate(publishedAt);
const tagBits = [
  format === 'essay' ? 'Longer read' : null,
  sportLabel,
  ageLabel ? `age ${ageLabel}` : null,
  dateLabel,
].filter(Boolean);

// Italicize the conceptual hinge in the headline
const renderTitle = (t: string) => t.replace(/\*([^*]+)\*/g, '<em>$1</em>');

const titleSize = format === 'essay'
  ? 'text-2xl md:text-[1.65rem]'
  : 'text-xl md:text-[1.4rem]';
---
<article class={`card-hover border-b border-bone py-6 ${variant === 'grid' ? 'border border-bone p-6' : ''}`}>
  <a href={href} class="block group">
    <div class="mb-3">
      <div class="font-display italic text-rust" style="font-size: 0.85rem; font-weight: 500;">
        {EDITORIAL.byline}
      </div>
      {tagBits.length > 0 && (
        <div class="font-display italic text-ink-soft mt-0.5" style="font-size: 0.8rem;">
          {tagBits.join(' · ')}
        </div>
      )}
    </div>
    <h3
      class={`font-display text-ink ${titleSize} leading-tight group-hover:text-rust transition-colors`}
      style="font-weight: 500;"
      set:html={renderTitle(title)}
    />
    {dek && (
      <p class="font-display text-ink-soft text-base mt-2 leading-snug max-w-2xl">
        {dek}
      </p>
    )}
    <div class="t-cta mt-3">Keep reading →</div>
  </a>
</article>

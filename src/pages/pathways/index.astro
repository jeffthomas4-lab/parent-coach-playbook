---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { SPORTS } from '../../data/site';

const pathways = (await getCollection('pathways', ({ data }) => isLive(data)));
const sportLabel = (s: string) => SPORTS.find(x => x.slug === s)?.label ?? s;
---
<BaseLayout
  title="Age pathways"
  description="What good looks like at 7, 10, 13, 15. Per sport. Skill milestones, practice shape, social and emotional markers, and the parent decision points that come up at each age."
>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/tools/" class="hover:underline">Tools</a> · Age pathways
      </p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl" style="font-weight: 500;">
        What "<em class="text-rust">good</em>" looks like at every age.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Most parents have no calibration. Per sport, per age band: skill milestones, practice shape, social markers, and the decision points that actually matter this year.
      </p>
      <p class="font-display italic text-ink-soft text-sm mt-6 max-w-2xl leading-snug" style="font-weight: 500;">
        Each pathway is built on Long-Term Athlete Development frameworks (Canadian Sport for Life, USA Hockey ADM, US Soccer Player Development, USA Basketball Player Development) and 25+ years of coaching observation.
      </p>
    </div>
  </section>

  <section class="border-b border-bone">
    <div class="container-px py-12">
      {pathways.length === 0 ? (
        <p class="font-display italic text-ink-soft" style="font-weight: 500;">
          The first wave of pathways ships this month. Check back.
        </p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-bone">
          {pathways.map((p) => (
            <a href={`/pathways/${p.data.sport}/`} class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
              <p class="font-display italic text-rust text-xs mb-2" style="font-weight: 500;">{sportLabel(p.data.sport)}</p>
              <h2 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors" style="font-weight: 500;">
                {p.data.title}
              </h2>
              <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{p.data.summary}</p>
              <p class="t-cta mt-3">Open the pathway →</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

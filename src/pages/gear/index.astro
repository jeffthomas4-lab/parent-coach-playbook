---
// /gear/ has moved to /what-to-buy/.
// This page is a static meta-refresh redirect for any older inbound links.
const target = '/what-to-buy/';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex" />
  <title>Moved · The Parent-Coach Playbook</title>
  <script set:html={`window.location.replace(${JSON.stringify(target)});`} />
</head>
<body>
  <p>This page has moved. <a href={target}>Continue to What to Buy</a>.</p>
</body>
</html>

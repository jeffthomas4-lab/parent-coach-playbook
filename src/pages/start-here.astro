---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';

// Six reader-state themes. Pick the moment that fits the week. Bigger type per card,
// curated reads, brand color accent at the top edge.
const themes = [
  {
    label: 'My kid had a hard day at practice.',
    blurb: 'The drive home is the moment. The first ninety seconds matter more than the next ninety minutes.',
    accent: '#C5713D', // rust
    bg: '#F2E2D5',
    icon: 'drive-home',
    links: [
      { text: 'What you say in the *first 90 seconds*', href: '/drive-home/the-90-second-rule/' },
      { text: 'Why I stopped asking "did you have fun?"', href: '/drive-home/why-i-stopped-asking-did-you-have-fun/' },
      { text: 'When she says "*I hate this sport*"', href: '/drive-home/when-she-says-i-hate-this-sport/' },
      { text: 'When they ask "*am I any good?*"', href: '/drive-home/when-they-ask-am-i-any-good/' },
    ],
  },
  {
    label: 'Tryouts are this week.',
    blurb: 'The night before, the morning of, the wait for the list. The version that does not make tryouts the only story in the house.',
    accent: '#8FA68C', // sage
    bg: '#EAEFE7',
    icon: 'tryouts',
    links: [
      { text: 'The night before tryouts', href: '/drive-there/night-before-tryouts/' },
      { text: 'Pre-tryout dinner. *What works*', href: '/drive-there/pre-tryout-dinner/' },
      { text: 'How to *read the tryout drill*', href: '/drive-there/how-to-read-the-tryout-drill/' },
      { text: 'After the cut. *The 24-hour rule*', href: '/drive-home/after-the-cut-the-24-hour-rule/' },
    ],
  },
  {
    label: 'I am new to this sport.',
    blurb: 'What to buy. What to skip. The first parent meeting. The questions to ask before you sign up.',
    accent: '#D4AB6A', // honey
    bg: '#F2E5C9',
    icon: 'equipment',
    links: [
      { text: 'Browse all sport guides', href: '/what-to-buy/' },
      { text: 'Used vs new gear. *The actual math*', href: '/drive-there/used-gear-rules/' },
      { text: 'The first parent meeting', href: '/drive-there/first-parent-meeting/' },
      { text: 'The 8-10 *cleat conversation*', href: '/drive-there/8-10-cleat-conversation/' },
    ],
  },
  {
    label: 'We are picking a summer camp.',
    blurb: 'How to evaluate one in ten minutes. The safety questions to ask. Day vs overnight. What to pack.',
    accent: '#B8908F', // rose
    bg: '#EDDBD9',
    icon: 'summer-camps',
    links: [
      { text: 'How to *evaluate a summer camp* in 10 minutes', href: '/drive-there/how-to-evaluate-a-summer-camp/' },
      { text: 'How to *vet a camp for safety*', href: '/drive-there/how-to-vet-a-camp-for-safety/' },
      { text: 'Day camp or overnight. *The real age cutoff*', href: '/drive-home/day-camp-vs-overnight-camp/' },
      { text: 'The summer camp *packing list* that actually works', href: '/drive-there/summer-camp-packing-list/' },
    ],
  },
  {
    label: 'Travel ball is on the table.',
    blurb: 'The recruiter at rec ball. The cost. The schedule. The signs your kid is, or is not, ready.',
    accent: '#C5713D', // rust
    bg: '#F2E2D5',
    icon: 'rec-vs-travel',
    links: [
      { text: 'The *recruiter at rec ball* promising the sun', href: '/drive-home/the-recruiter-at-rec-ball/' },
      { text: 'The cost of *travel ball*. Actual annual breakdown', href: '/drive-home/the-cost-of-travel-ball/' },
      { text: 'The *11-year-old who is not ready* for travel', href: '/drive-home/the-11-year-old-whos-not-ready-for-travel/' },
      { text: 'When you *say no to travel* and feel guilty', href: '/drive-home/when-you-say-no-to-travel/' },
    ],
  },
  {
    label: 'Game day stuff.',
    blurb: 'The thirty minutes before kickoff. The bench reaction your kid will remember. The bad call that did not go your way.',
    accent: '#8FA68C', // sage
    bg: '#EAEFE7',
    icon: 'game-day',
    links: [
      { text: 'What to do in the *30 minutes before kickoff*', href: '/drive-there/what-to-do-in-the-30-minutes-before-kickoff/' },
      { text: 'The *bench reaction* your kid will remember', href: '/game/the-bench-reaction-your-kid-will-remember/' },
      { text: 'The *cheer that embarrasses* your kid', href: '/game/the-cheer-that-embarrasses-your-kid/' },
      { text: 'The bad call that *did not go your way*', href: '/drive-home/the-bad-call-that-didnt-go-your-way/' },
    ],
  },
];
---
<BaseLayout
  title="Start here"
  description="Six reader-state themes. Pick the moment that fits your week, and we'll route you to the right reading. The drive home, tryouts week, summer camps, travel ball, and the rest."
>
  <section class="border-b border-bone">
    <div class="container-px py-16 md:py-20">
      <p class="font-display-soft text-rust mb-4" style="font-weight: 600; letter-spacing: 0.04em;">Start here</p>
      <h1 class="font-display-soft text-ink text-[2.5rem] md:text-[4.5rem] leading-[1.05] max-w-3xl" style="font-weight: 700;">
        What's happening <span class="text-rust italic font-display" style="font-weight: 500;">this week</span>?
      </h1>
      <p class="font-display-soft text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-relaxed" style="font-weight: 400;">
        Pick the moment that fits your family right now. We'll route you to the right reads. Most are short. A few are longer. None waste your time.
      </p>
    </div>
  </section>

  <!-- ROSE SECTION DIVIDER -->
  <section style="background: #EDDBD9; height: 4px;"></section>

  <!-- SIX THEME CARDS -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-14">
      <div class="grid md:grid-cols-2 gap-6">
        {themes.map((t) => (
          <article
            class="p-8 md:p-10 transition-shadow hover:shadow-md"
            style={`background: ${t.bg}; border-top: 5px solid ${t.accent};`}
          >
            <h2
              class="font-display-soft text-ink text-2xl md:text-3xl leading-tight"
              style="font-weight: 700;"
              set:html={t.label}
            />
            <p class="font-display-soft text-ink-soft mt-4 leading-relaxed text-base md:text-lg" style="font-weight: 400;">
              {t.blurb}
            </p>
            <ul class="grid gap-2.5 mt-6">
              {t.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="font-display-soft hover:underline transition-colors text-base"
                    style={`color: ${t.accent}; font-weight: 600;`}
                    set:html={`→ ${l.text.replace(/\*([^*]+)\*/g, '<em class="italic font-display" style="font-weight: 500;">$1</em>')}`}
                  />
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ROSE SECTION DIVIDER -->
  <section style="background: #EDDBD9; height: 4px;"></section>

  <!-- DON'T SEE YOUR SITUATION -->
  <section class="border-b border-bone">
    <div class="container-px py-14 max-w-3xl">
      <p class="font-display-soft text-rust mb-3" style="font-weight: 600;">Don't see your situation?</p>
      <p class="font-display-soft text-ink-soft text-lg md:text-xl leading-relaxed" style="font-weight: 400;">
        Email us at <a href="mailto:parentcoachplaybook@gmail.com" class="text-rust hover:underline">parentcoachplaybook@gmail.com</a> and tell us what's happening this week. If we've written it, we'll send the link. If we haven't, we'll add it to the list.
      </p>
    </div>
  </section>

  <LeadMagnetCTA />
  <NewsletterSignup
    headline="One short note a week"
    blurb="One short read a week from the Parent Coach Playbook Editorial. Friday morning. Easy unsubscribe."
  />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { isLive } from '../lib/publishFilter';
import { renderTitle } from '../lib/title';

// Pull the cornerstone content. Editorial principle: when a new piece earns
// cornerstone status, surface it here. See REVIEW.md for the curation rule.
const articles   = await getCollection('articles',  ({ data }) => isLive(data));
const scripts    = await getCollection('scripts',   ({ data }) => isLive(data));
const decisions  = await getCollection('decisions', ({ data }) => isLive(data));
const recruiting = await getCollection('recruiting',({ data }) => isLive(data));
const body       = await getCollection('body',      ({ data }) => isLive(data));

// CURATED LISTS — editorial picks, not auto-generated.
// When a new article belongs here, add the slug. When a piece falls out of relevance, remove it.

// Cornerstone pillar pieces — the deepest, most-shared content.
const cornerstoneSlugs = [
  'the-recruiting-process',
  'football',
  'are-youth-sports-worth-it',
  'why-kids-quit-sports',
  'what-age-should-kids-start-sports',
];
const cornerstone = [
  ...recruiting.filter(r => cornerstoneSlugs.includes(r.slug)).map(r => ({ kind: 'recruiting' as const, slug: r.slug, title: r.data.title, summary: r.data.summary, href: `/recruiting/${r.slug}/` })),
  ...articles.filter(a => cornerstoneSlugs.includes(a.slug)).map(a => ({ kind: 'article' as const, slug: a.slug, title: a.data.title, summary: a.data.dek ?? '', href: `/${a.data.phase}/${a.slug}/` })),
];

// "If you're new" — quick-orient pieces.
const newToThis = [
  { title: 'The Recruiting Process: what parents actually need to know',         href: '/recruiting/the-recruiting-process/', dek: 'No-hype guide to how college recruiting really works.' },
  { title: 'Are youth sports worth it? An honest answer.',                       href: '/drive-there/are-youth-sports-worth-it/', dek: 'The real math, by what you\'re actually paying for.' },
  { title: 'What age should kids start sports?',                                 href: '/drive-there/what-age-should-kids-start-sports/', dek: 'Earlier than you think for movement. Later than you think for competition.' },
  { title: 'The youth sports pendulum',                                          href: '/youth-sports-pendulum/', dek: 'Where is your family on the fun-to-performance spectrum right now?' },
];

// "The big decisions" — pulled from the decisions collection, featured ones.
const bigDecisions = decisions.filter(d => d.data.featured).slice(0, 4);

// "What to say in the moment" — top scripts.
const topScripts = scripts.filter(s => s.data.featured).slice(0, 6);

// "Common parent searches" — high-search-volume articles.
const commonSearchSlugs = [
  'sideline-etiquette-for-youth-sports-parents',
  'what-parents-shouldnt-do-at-youth-sports-games',
  'benefits-of-multi-sport-athletes',
];
const commonSearches = articles.filter(a => commonSearchSlugs.includes(a.slug));

// Body topics with the highest parent-search interest.
const bodyTopicSlugs = ['concussion-protocol-basics', 'youth-pitcher-arm-care', 'burnout-signs', 'sleep-targets-by-age'];
const topBodyTopics = body.filter(b => bodyTopicSlugs.includes(b.slug));
---
<BaseLayout
  title="Start here — the parents' guide to youth sports"
  description="If you're new to youth sports — or in the middle of a hard moment — start here. The cornerstone pieces, the big decisions, the scripts for the car ride, and the searches every parent runs."
>
  <!-- Hero -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-16">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Start here</p>
      <h1 class="font-display text-ink text-[2rem] md:text-[4rem] leading-[1.05] max-w-3xl" style="font-weight: 500;">
        The <em class="text-rust">parents' guide</em> to youth sports.
      </h1>
      <p class="font-display text-ink-soft text-lg md:text-2xl mt-5 max-w-2xl leading-snug">
        If you're new to youth sports, or in the middle of a hard moment, this page routes you to the right pieces. Cornerstone reads, big decisions, scripts for the car ride, and the questions every parent ends up Googling.
      </p>
    </div>
  </section>

  <!-- Quick anchor nav -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-5">
      <p class="font-display italic text-ink-soft text-xs mb-3" style="font-weight: 500;">Jump to</p>
      <div class="flex flex-wrap gap-2">
        <a href="#cornerstone"      class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">Cornerstone reads</a>
        <a href="#new-to-this"      class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">New to this</a>
        <a href="#big-decisions"    class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">Big decisions</a>
        <a href="#scripts"          class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">Scripts for the car</a>
        <a href="#parent-searches"  class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">Common searches</a>
        <a href="#the-body"         class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper transition-colors text-sm" style="font-weight: 500;">The body</a>
      </div>
    </div>
  </section>

  <!-- Cornerstone -->
  {cornerstone.length > 0 && (
    <section id="cornerstone" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">If you only read a few</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
          The <em class="text-rust">cornerstone</em> pieces.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {cornerstone.map((c) => (
            <li>
              <a href={c.href} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;" set:html={renderTitle(c.title)} />
                {c.summary && <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{c.summary}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- New to this -->
  <section id="new-to-this" class="border-b border-bone scroll-mt-16">
    <div class="container-px py-8 md:py-10">
      <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">If this is all new</p>
      <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
        Get the <em class="text-rust">lay of the land</em>.
      </h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
        {newToThis.map((p) => (
          <li>
            <a href={p.href} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
              <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;">{p.title}</span>
              <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{p.dek}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Big decisions -->
  {bigDecisions.length > 0 && (
    <section id="big-decisions" class="border-b border-bone bg-paper-warm scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">The conversations every family has</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
          The <em class="text-rust">big decisions</em>.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {bigDecisions.map((d) => (
            <li>
              <a href={`/decisions/${d.slug}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;" set:html={renderTitle(d.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{d.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4" style="font-weight: 500;">
          <a href="/decisions/" class="hover:underline">→ All decision pages</a>
        </p>
      </div>
    </section>
  )}

  <!-- Scripts -->
  {topScripts.length > 0 && (
    <section id="scripts" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">For the moment in the car</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
          <em class="text-rust">What to say</em> when it counts.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {topScripts.map((s) => (
            <li>
              <a href={`/scripts/${s.slug}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;" set:html={renderTitle(s.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{s.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4" style="font-weight: 500;">
          <a href="/scripts/" class="hover:underline">→ All scripts</a>
        </p>
      </div>
    </section>
  )}

  <!-- Common parent searches -->
  {commonSearches.length > 0 && (
    <section id="parent-searches" class="border-b border-bone bg-paper-warm scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">The questions every parent Googles</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
          <em class="text-rust">Common searches</em>, real answers.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {commonSearches.map((a) => (
            <li>
              <a href={`/${a.data.phase}/${a.slug}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;" set:html={renderTitle(a.data.title)} />
                {a.data.dek && <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{a.data.dek}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- The body -->
  {topBodyTopics.length > 0 && (
    <section id="the-body" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">What parents Google at 11pm</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4" style="font-weight: 500;">
          <em class="text-rust">The body</em>: concussion, arm care, sleep, burnout.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {topBodyTopics.map((b) => (
            <li>
              <a href={`/body/${b.slug}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust" style="font-weight: 500;" set:html={renderTitle(b.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug" style="font-weight: 500;">{b.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4" style="font-weight: 500;">
          <a href="/body/" class="hover:underline">→ All body topics</a>
        </p>
      </div>
    </section>
  )}

  <LeadMagnetCTA />
  <NewsletterSignup
    headline="One short note a week"
    blurb="One read every Friday from the editorial desk. No spam."
  />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { isLive } from '../lib/publishFilter';
import { renderTitle } from '../lib/title';
import { SPORTS, TOOLS_NAV } from '../data/site';

const articles   = await getCollection('articles',  ({ data }) => isLive(data));
const scripts    = await getCollection('scripts',   ({ data }) => isLive(data));
const decisions  = await getCollection('decisions', ({ data }) => isLive(data));
const body       = await getCollection('body',      ({ data }) => isLive(data));

// Cornerstone — deepest, most-shared pieces. Edit this list to curate.
const cornerstoneSlugs = [
  'the-real-job-of-youth-sports',
  'are-youth-sports-worth-it',
  'why-kids-quit-sports',
  'the-90-second-rule',
  'when-she-says-i-hate-this-sport',
  'what-age-should-kids-start-sports',
];
const cornerstone = articles
  .filter(a => cornerstoneSlugs.includes(a.id))
  .map(a => ({
    kind: 'article' as const,
    slug: a.id,
    title: a.data.title,
    summary: a.data.dek ?? '',
    href: `/${a.data.phase}/${a.id}/`,
  }));

// Big decisions — featured ones only.
const bigDecisions = decisions.filter(d => d.data.featured).slice(0, 6);

// Top scripts — featured ones.
const topScripts = scripts.filter(s => s.data.featured).slice(0, 6);

// Body topics — high-urgency, high-search parent needs.
const bodyTopicSlugs = ['concussion-protocol-basics', 'youth-pitcher-arm-care', 'burnout-signs', 'sleep-targets-by-age'];
const topBodyTopics = body.filter(b => bodyTopicSlugs.includes(b.id));

// Sport grid — top 12 for start-here (more than homepage, less than full /sports/).
const FEATURED_SPORTS = [
  'baseball', 'soccer', 'basketball', 'football',
  'softball', 'volleyball', 'swimming', 'lacrosse-girls',
  'gymnastics', 'theater', 'track-field', 'hockey',
];
const featuredSports = FEATURED_SPORTS
  .map(slug => SPORTS.find(s => s.slug === slug))
  .filter(Boolean) as typeof SPORTS[number][];

// Tools to surface — subset most useful to a first-time visitor.
const startHereTools = TOOLS_NAV.filter(t =>
  ['cost-calculator', 'pendulum', 'season-calendar', 'pathways', 'rules'].includes(t.slug)
);
---
<BaseLayout
  title="Start here: the parents' guide to youth sports"
  description="If you're new to youth sports, or in the middle of a hard moment, start here. Cornerstone reads, the big decisions, scripts for the car, tools, and your sport."
>
  {/* ── HERO ─────────────────────────────────────────────────────────────── */}
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Start here</p>
      <h1 class="font-display text-ink text-[2rem] md:text-[3.75rem] leading-[1.05] max-w-3xl font-medium">
        The <em class="text-rust">parents' guide</em> to youth sports.
      </h1>
      <p class="font-display text-ink-soft text-lg md:text-2xl mt-5 max-w-2xl leading-snug">
        New to youth sports, or deep in a hard moment — this page routes you to what matters. Pick your sport, read the cornerstones, grab the tools.
      </p>
    </div>
  </section>

  {/* ── JUMP NAV ─────────────────────────────────────────────────────────── */}
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-5">
      <p class="font-display italic text-ink-soft text-xs mb-3 font-medium">Jump to</p>
      <div class="flex flex-wrap gap-2">
        <a href="#by-sport"     class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Your sport</a>
        <a href="#cornerstone"  class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Cornerstone reads</a>
        <a href="#the-body"     class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Injuries & health</a>
        <a href="#big-decisions" class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Big decisions</a>
        <a href="#scripts"      class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Scripts for the car</a>
        <a href="#tools"        class="font-display italic text-ink hover:text-rust border border-bone px-3 py-2 hover:bg-paper transition-colors text-sm font-medium">Tools</a>
      </div>
    </div>
  </section>

  {/* ── BY SPORT ─────────────────────────────────────────────────────────── */}
  <section id="by-sport" class="border-b border-bone scroll-mt-16">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-2 text-sm font-medium">Find everything for your kid's sport</p>
      <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-2 font-medium">
        Start with <em class="text-rust">your sport</em>.
      </h2>
      <p class="font-display text-ink-soft mb-6 leading-snug max-w-xl">
        Each sport page pulls together every article, drill, gear guide, rules primer, season calendar, and recruiting note we have. It's the fastest entry point.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-px bg-bone">
        {featuredSports.map((sport) => (
          <a
            href={`/sports/${sport.slug}/`}
            class="bg-paper px-5 py-4 group hover:bg-[#F2E2D5] transition-colors block"
          >
            <h3 class="font-display text-ink text-base leading-tight group-hover:text-rust transition-colors font-medium">
              {sport.label}
            </h3>
            <p class="font-display italic text-rust text-xs mt-1 font-medium">→ Sport guide</p>
          </a>
        ))}
      </div>
      <p class="font-display italic text-rust text-sm mt-5 font-medium">
        <a href="/sports/" class="hover:underline">→ All 26 sports and activities</a>
      </p>
    </div>
  </section>

  {/* ── CORNERSTONE ──────────────────────────────────────────────────────── */}
  {cornerstone.length > 0 && (
    <section id="cornerstone" class="border-b border-bone bg-paper-warm scroll-mt-16">
      <div class="container-px py-10 md:py-12">
        <p class="font-display italic text-rust mb-2 text-sm font-medium">If you only read a few</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4 font-medium">
          The <em class="text-rust">cornerstone</em> pieces.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {cornerstone.map((c) => (
            <li>
              <a href={c.href} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium" set:html={renderTitle(c.title)} />
                {c.summary && <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{c.summary}</span>}
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4 font-medium">
          <a href="/reads/" class="hover:underline">→ Full archive</a>
        </p>
      </div>
    </section>
  )}

  {/* ── THE BODY / INJURIES & HEALTH ─────────────────────────────────────── */}
  {topBodyTopics.length > 0 && (
    <section id="the-body" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-10 md:py-12">
        <p class="font-display italic text-rust mb-2 text-sm font-medium">What parents Google at 11pm</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4 font-medium">
          <em class="text-rust">Injuries, health</em>, and the hard questions.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {topBodyTopics.map((b) => (
            <li>
              <a href={`/body/${b.id}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium" set:html={renderTitle(b.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{b.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4 font-medium">
          <a href="/body/" class="hover:underline">→ All body and health topics</a>
        </p>
      </div>
    </section>
  )}

  {/* ── BIG DECISIONS ────────────────────────────────────────────────────── */}
  {bigDecisions.length > 0 && (
    <section id="big-decisions" class="border-b border-bone bg-paper-warm scroll-mt-16">
      <div class="container-px py-10 md:py-12">
        <p class="font-display italic text-rust mb-2 text-sm font-medium">The conversations every family has</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4 font-medium">
          The <em class="text-rust">big decisions</em>.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {bigDecisions.map((d) => (
            <li>
              <a href={`/decisions/${d.id}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium" set:html={renderTitle(d.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{d.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4 font-medium">
          <a href="/decisions/" class="hover:underline">→ All decision pages</a>
        </p>
      </div>
    </section>
  )}

  {/* ── SCRIPTS ──────────────────────────────────────────────────────────── */}
  {topScripts.length > 0 && (
    <section id="scripts" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-10 md:py-12">
        <p class="font-display italic text-rust mb-2 text-sm font-medium">For the moment in the car</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-4 font-medium">
          <em class="text-rust">What to say</em> when it counts.
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {topScripts.map((s) => (
            <li>
              <a href={`/scripts/${s.id}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium" set:html={renderTitle(s.data.title)} />
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{s.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="font-display italic text-rust text-sm mt-4 font-medium">
          <a href="/scripts/" class="hover:underline">→ All scripts</a>
        </p>
      </div>
    </section>
  )}

  {/* ── TOOLS ────────────────────────────────────────────────────────────── */}
  <section id="tools" class="border-b border-bone bg-paper-warm scroll-mt-16">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-2 text-sm font-medium">Reference and planning</p>
      <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl mb-6 font-medium">
        The <em class="text-rust">tools</em> worth bookmarking.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-bone">
        {startHereTools.map((t) => (
          <a
            href={t.href}
            class="bg-paper p-5 group hover:bg-[#F2E2D5] transition-colors block"
          >
            <h3 class="font-display text-ink text-base leading-tight group-hover:text-rust transition-colors font-medium">
              {t.label}
            </h3>
            <p class="font-display italic text-ink-soft text-xs mt-2 leading-snug font-medium">{t.blurb}</p>
            <p class="font-display italic text-rust text-xs mt-3 font-medium">→ Open</p>
          </a>
        ))}
      </div>
      <p class="font-display italic text-rust text-sm mt-5 font-medium">
        <a href="/tools/" class="hover:underline">→ All tools</a>
      </p>
    </div>
  </section>

  {/* ── NEWSLETTER ───────────────────────────────────────────────────────── */}
  <LeadMagnetCTA />
  <NewsletterSignup
    headline="One short note a week"
    blurb="The Friday Letter every Friday morning. One read, one idea, one thing worth passing on. Free, always."
    buttonLabel="Get the Friday Letter"
  />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { TOOLS_NAV, SPORTS } from '../../data/site';
import { PROFILES } from '../../data/costDefaults';

// Counts for the tile blurbs
const calendars  = await getCollection('seasonCalendars', ({ data }) => isLive(data));
const pathways   = await getCollection('pathways',       ({ data }) => isLive(data));
const recruiting = await getCollection('recruiting',     ({ data }) => isLive(data));
const adaptive   = await getCollection('adaptive',       ({ data }) => isLive(data));
const rules      = await getCollection('rules',          ({ data }) => isLive(data));
const decisions  = await getCollection('decisions',      ({ data }) => isLive(data));
const profileCount = PROFILES.length;

// Add live counts to each tool's metadata.
// Body & Safety lives under /reads/ now, not Tools, so no body count here.
const toolsWithCounts = TOOLS_NAV.map(t => {
  const counts: Record<string, string> = {
    'season-calendar':  `${calendars.length} calendars`,
    'pathways':         `${pathways.length} sports`,
    'cost-calculator':  `${profileCount} profiles`,
    'recruiting':       `${recruiting.length} pieces`,
    'rules':            `${rules.length} sports`,
    'adaptive':         `${adaptive.length} topics`,
    'decisions':        `${decisions.length} decisions`,
    'pendulum':         `single page`,
    'mental-skills':    `5 topics`,
    'governing-bodies': `directory`,
  };
  return { ...t, count: counts[t.slug] ?? '' };
});
---
<BaseLayout
  title="The Drawer"
  description="Reference tools for activities-oriented parents. Season calendars, age pathways, cost calculator, the body, recruiting, rules, adaptive athletes, decisions, the pendulum, mental skills, and the governing-body directory."
>
  <!-- Hero: what this section is, fast -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">The Drawer</p>
      <h1 class="font-display text-ink text-[2rem] md:text-[4rem] leading-[1.05] max-w-3xl font-medium">
        Pages parents <em class="text-rust">come back to</em>.
      </h1>
      <p class="font-display text-ink-soft text-lg md:text-2xl mt-5 max-w-2xl leading-snug">
        Reference tools, not articles. Open one when the moment comes up. Save it. Send it to the group chat the next time it does.
      </p>
    </div>
  </section>

  <!-- What this section is: quick explainer -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-8 md:py-10 max-w-3xl">
      <p class="font-display italic text-rust mb-3 text-sm font-medium">How this works</p>
      <p class="font-display text-ink leading-relaxed text-base md:text-lg">
        Each tool is a self-contained reference. The cost calculator runs the numbers. The season calendar shows the year. The pathways show what good looks like at every age. Pick the one you need. The Sideline File and the scripts hub now live under <a href="/reads/" class="text-rust hover:underline">Reads</a>.
      </p>
    </div>
  </section>

  <!-- Scannable directory of tools -->
  <section class="border-b border-bone">
    <div class="container-px py-8 md:py-10">
      <p class="font-display italic text-rust mb-4 font-medium" style="font-size: 1.05rem">All the tools</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1">
        {toolsWithCounts.map((t) => (
          <li>
            <a href={t.href} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
              <div class="flex items-baseline justify-between gap-3">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium">{t.label}</span>
                <span class="font-display italic text-ink-soft text-xs whitespace-nowrap font-medium">{t.count}</span>
              </div>
              <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{t.blurb}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- How they fit together -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-10 md:py-12">
      <p class="font-display italic text-rust mb-3 text-sm font-medium">How they fit</p>
      <h2 class="font-display text-ink text-2xl md:text-3xl leading-[1.05] max-w-3xl font-medium">
        The tools work as <em class="text-rust">one system</em>.
      </h2>
      <p class="font-display text-ink leading-relaxed mt-4 max-w-3xl">
        Pick a calendar to see the shape of your kid's year. Open the matching pathway to see what good looks like at this age. Open the cost calculator to see what it costs. The body topics and the scripts that match the moment live in <a href="/reads/" class="text-rust hover:underline">Reads</a>.
      </p>
    </div>
  </section>
</BaseLayout>

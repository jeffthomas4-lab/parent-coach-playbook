---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadMagnetCTA from '../../components/LeadMagnetCTA.astro';
import FAQPageSchema from '../../components/FAQPageSchema.astro';
import HowToSchema from '../../components/HowToSchema.astro';
import { SITE } from '../../data/site';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';

export async function getStaticPaths() {
  const decisions = await getCollection('decisions', ({ data }) => isLive(data));
  return decisions.map((d) => ({ params: { slug: d.slug }, props: { decision: d } }));
}

const { decision } = Astro.props;
const { Content } = await decision.render();

// Related scripts and other decisions
const allScripts = await getCollection('scripts', ({ data }) => isLive(data));
const relatedScripts = (decision.data.relatedScripts ?? [])
  .map(slug => allScripts.find(s => s.slug === slug))
  .filter(Boolean) as typeof allScripts;

const allDecisions = await getCollection('decisions', ({ data }) => isLive(data));
const relatedDecisions = (decision.data.relatedDecisions ?? [])
  .map(slug => allDecisions.find(d => d.slug === slug))
  .filter(Boolean) as typeof allDecisions;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Decisions', item: `${SITE.url}/decisions/` },
    { '@type': 'ListItem', position: 3, name: stripTitle(decision.data.title) },
  ],
};
---
<BaseLayout
  title={stripTitle(decision.data.title)}
  description={decision.data.summary}
>
  <FAQPageSchema
    slot="head"
    question={decision.data.theQuestion}
    summary={decision.data.summary}
    theRule={decision.data.theRule}
    benefits={decision.data.benefits}
    costs={decision.data.costs}
    signsItsAGoodFit={decision.data.signsItsAGoodFit}
    signsItsNot={decision.data.signsItsNot}
    howToHandleIt={decision.data.howToHandleIt}
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {decision.data.howToHandleIt.length > 0 && (
    <HowToSchema
      slot="head"
      name={`How to handle: ${stripTitle(decision.data.title)}`}
      description={decision.data.summary}
      steps={decision.data.howToHandleIt.map((h, i) => ({ name: `Step ${i + 1}`, text: h }))}
    />
  )}

  <!-- Hero -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/tools/" class="hover:underline">Tools</a> ·
        <a href="/decisions/" class="hover:underline">Decisions</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl font-medium" set:html={renderTitle(decision.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {decision.data.summary}
      </p>
    </div>
  </section>

  <!-- The question reframed -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-8 max-w-3xl">
      <p class="font-display italic text-rust mb-2 text-sm font-medium">The real question</p>
      <p class="font-display text-ink text-xl leading-snug font-medium">
        {decision.data.theQuestion}
      </p>
    </div>
  </section>

  <!-- Benefits + Costs -->
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        {decision.data.benefits.length > 0 && (
          <div>
            <p class="font-display italic mb-3 text-sm font-medium" style="color: #5C7459">Benefits</p>
            <ul class="grid gap-2">
              {decision.data.benefits.map((b) => (
                <li class="font-display text-ink leading-snug pl-4 -indent-4" style="font-weight: 400;">· {b}</li>
              ))}
            </ul>
          </div>
        )}
        {decision.data.costs.length > 0 && (
          <div>
            <p class="font-display italic mb-3 text-sm font-medium" style="color: #C5713D">Costs</p>
            <ul class="grid gap-2">
              {decision.data.costs.map((c) => (
                <li class="font-display text-ink leading-snug pl-4 -indent-4" style="font-weight: 400;">· {c}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Signs it fits / signs it doesn't -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-10">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        {decision.data.signsItsAGoodFit.length > 0 && (
          <div>
            <p class="font-display italic mb-3 text-sm font-medium" style="color: #5C7459">Signs it's a good fit</p>
            <ul class="grid gap-2">
              {decision.data.signsItsAGoodFit.map((s) => (
                <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {s}</li>
              ))}
            </ul>
          </div>
        )}
        {decision.data.signsItsNot.length > 0 && (
          <div>
            <p class="font-display italic mb-3 text-sm font-medium" style="color: #C5713D">Signs it's not</p>
            <ul class="grid gap-2">
              {decision.data.signsItsNot.map((s) => (
                <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {s}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- How to handle it -->
  {decision.data.howToHandleIt.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 max-w-3xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">How to handle the conversation</p>
        <ul class="grid gap-2">
          {decision.data.howToHandleIt.map((h) => (
            <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {h}</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- The rule -->
  <section class="border-b border-bone bg-ink text-paper">
    <div class="container-px py-12 max-w-3xl">
      <p class="font-display italic mb-3 text-sm font-medium" style="color: #D4AB6A">The rule</p>
      <p class="font-display text-paper text-2xl md:text-3xl leading-snug font-medium">
        {decision.data.theRule}
      </p>
    </div>
  </section>

  <!-- Optional markdown body -->
  {decision.body && decision.body.trim().length > 0 && (
    <article class="container-px py-10 md:py-12">
      <div class="article-body max-w-prose mx-auto">
        <Content />
      </div>
    </article>
  )}

  <!-- You might also need -->
  {(relatedScripts.length > 0 || relatedDecisions.length > 0) && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-10">
        <p class="font-display italic text-rust mb-4 font-medium">You might also need</p>
        <div class="grid md:grid-cols-2 gap-6">
          {relatedScripts.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3 font-medium">Scripts</p>
              <ul class="grid gap-2">
                {relatedScripts.map(s => (
                  <li><a href={`/scripts/${s.slug}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug font-medium">→ <span set:html={renderTitle(s.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
          {relatedDecisions.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3 font-medium">Other decisions</p>
              <ul class="grid gap-2">
                {relatedDecisions.map(d => (
                  <li><a href={`/decisions/${d.slug}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug font-medium">→ <span set:html={renderTitle(d.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <Lea
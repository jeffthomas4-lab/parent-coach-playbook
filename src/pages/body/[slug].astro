---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BodyDisclaimer from '../../components/BodyDisclaimer.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';
import { SPORTS } from '../../data/site';

export async function getStaticPaths() {
  const topics = await getCollection('body', ({ data }) => isLive(data));
  return topics.map((t) => ({ params: { slug: t.slug }, props: { topic: t } }));
}

const { topic } = Astro.props;
const { Content } = await topic.render();

// Related: pathways for the same sports, calendars for the same sports, sibling body topics.
const sportTags = topic.data.sportTags ?? [];

const pathways = await getCollection('pathways', ({ data }) => isLive(data));
const relatedPathways = pathways.filter(p => sportTags.includes(p.data.sport)).slice(0, 4);

const calendars = await getCollection('seasonCalendars', ({ data }) => isLive(data));
const relatedCalendars = calendars.filter(c => sportTags.includes(c.data.sport)).slice(0, 4);

const allBody = await getCollection('body', ({ data }) => isLive(data));
const siblingBody = allBody
  .filter(b => b.slug !== topic.slug && (b.data.category === topic.data.category || b.data.sportTags?.some(s => sportTags.includes(s))))
  .slice(0, 4);

const sportLabel = (s: string) => SPORTS.find(x => x.slug === s)?.label ?? s;

const lastUpdated = topic.data.publishedAt;
---
<BaseLayout
  title={stripTitle(topic.data.title)}
  description={topic.data.summary}
>
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/tools/" class="hover:underline">Tools</a> ·
        <a href="/body/" class="hover:underline">The body</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl" style="font-weight: 500;" set:html={renderTitle(topic.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {topic.data.summary}
      </p>
    </div>
  </section>

  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      <BodyDisclaimer />
      <Content />

      {topic.data.governingBodies && topic.data.governingBodies.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Sources</p>
          <ul class="grid gap-2">
            {topic.data.governingBodies.map((g) => (
              <li>
                <a href={g.url} target="_blank" rel="noopener" class="font-display text-ink hover:text-rust" style="font-weight: 500;">
                  {g.name} ↗
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {topic.data.doctorQuestions && topic.data.doctorQuestions.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Questions to bring to the pediatrician</p>
          <ul class="grid gap-2">
            {topic.data.doctorQuestions.map((q) => (
              <li class="font-display text-ink leading-snug" style="font-weight: 400;">— {q}</li>
            ))}
          </ul>
        </aside>
      )}

      {topic.data.gearPicks && topic.data.gearPicks.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Gear that helps</p>
          <ul class="grid gap-3">
            {topic.data.gearPicks.map((g) => (
              <li>
                {g.affiliateSlug ? (
                  <a href={`/go/${g.affiliateSlug}/`} class="font-display text-ink hover:text-rust" style="font-weight: 500;">{g.name} →</a>
                ) : (
                  <span class="font-display text-ink" style="font-weight: 500;">{g.name}</span>
                )}
                {g.note && (
                  <p class="font-display italic text-ink-soft text-sm mt-1 leading-snug" style="font-weight: 500;">{g.note}</p>
                )}
              </li>
            ))}
          </ul>
          <p class="font-display italic text-ink-soft text-xs mt-4 leading-snug" style="font-weight: 500;">
            Some of these are affiliate links. <a href="/disclosure/" class="hover:text-rust underline-offset-2 hover:underline">Read our disclosure</a>.
          </p>
        </aside>
      )}

      <p class="font-display italic text-ink-soft text-xs mt-10 pt-6 border-t border-bone" style="font-weight: 500;">
        Last updated {lastUpdated.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}.
      </p>
    </div>
  </article>

  <!-- Related across the site -->
  {(relatedPathways.length > 0 || relatedCalendars.length > 0 || siblingBody.length > 0) && (
    <section class="border-t border-bone bg-paper-warm">
      <div class="container-px py-10">
        <p class="font-display italic text-rust mb-4" style="font-weight: 500;">Related across the site</p>
        <div class="grid md:grid-cols-3 gap-6">
          {siblingBody.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">More from The body</p>
              <ul class="grid gap-2">
                {siblingBody.map(b => (
                  <li><a href={`/body/${b.slug}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ <span set:html={renderTitle(b.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
          {relatedPathways.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">Pathways</p>
              <ul class="grid gap-2">
                {relatedPathways.map(p => (
                  <li><a href={`/pathways/${p.data.sport}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ {sportLabel(p.data.sport)} pathway</a></li>
                ))}
              </ul>
            </div>
          )}
          {relatedCalendars.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">Season calendars</p>
              <ul class="grid gap-2">
                {relatedCalendars.map(c => (
                  <li><a href={`/season-calendar/${c.slug}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ <span set:html={renderTitle(c.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

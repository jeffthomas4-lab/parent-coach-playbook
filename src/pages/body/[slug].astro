---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BodyDisclaimer from '../../components/BodyDisclaimer.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';
import { serializeJsonLd } from '../../lib/jsonld';
import { SPORTS, SITE, authorEntity } from '../../data/site';

export async function getStaticPaths() {
  const topics = await getCollection('body', ({ data }) => isLive(data));
  return topics.map((t) => ({ params: { slug: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
const { Content } = await render(topic);

// JSON-LD: Article schema for the body topic (medical / training reference reads).
// Author entity resolved via authorEntity() — Organization until November, Person
// after the AUTHOR_REVEALED flip. Publisher stays Organization.
const bodyArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: stripTitle(topic.data.title),
  description: topic.data.summary,
  author: authorEntity(),
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/og-default.jpg` },
  },
  datePublished: topic.data.publishedAt.toISOString(),
  dateModified: topic.data.publishedAt.toISOString(),
  mainEntityOfPage: `${SITE.url}/body/${topic.id}/`,
  articleSection: 'The body',
  ...(topic.data.governingBodies && topic.data.governingBodies.length > 0
    ? { citation: topic.data.governingBodies.map((g: { name: string; url: string }) => ({ '@type': 'CreativeWork', name: g.name, url: g.url })) }
    : {}),
};

const bodyBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'The body', item: `${SITE.url}/body/` },
    { '@type': 'ListItem', position: 3, name: stripTitle(topic.data.title) },
  ],
};

// Related: pathways for the same sports, calendars for the same sports, sibling body topics.
const sportTags = topic.data.sportTags ?? [];

const pathways = await getCollection('pathways', ({ data }) => isLive(data));
const relatedPathways = pathways.filter(p => sportTags.includes(p.data.sport)).slice(0, 4);

const calendars = await getCollection('seasonCalendars', ({ data }) => isLive(data));
const relatedCalendars = calendars.filter(c => sportTags.includes(c.data.sport)).slice(0, 4);

const allBody = await getCollection('body', ({ data }) => isLive(data));
const siblingBody = allBody
  .filter(b => b.id !== topic.id && (b.data.category === topic.data.category || b.data.sportTags?.some(s => sportTags.includes(s))))
  .slice(0, 4);

const sportLabel = (s: string) => SPORTS.find(x => x.slug === s)?.label ?? s;

const lastUpdated = topic.data.publishedAt;
---
<BaseLayout
  title={stripTitle(topic.data.title)}
  description={topic.data.summary}
>
  <script slot="head" type="application/ld+json" set:html={serializeJsonLd(bodyArticleSchema)} />
  <script slot="head" type="application/ld+json" set:html={serializeJsonLd(bodyBreadcrumbSchema)} />
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/reads/" class="hover:underline">Reads</a> ·
        <a href="/body/" class="hover:underline">{(topic.data as any).subhub === 'safety' ? 'Safety' : 'The body'}</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl" style="font-weight: 500;" set:html={renderTitle(topic.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {topic.data.summary}
      </p>
    </div>
  </section>

  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      <BodyDisclaimer />
      <Content />

      {topic.data.governingBodies && topic.data.governingBodies.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Sources</p>
          <ul class="grid gap-2">
            {topic.data.governingBodies.map((g) => (
              <li>
                <a href={g.url} target="_blank" rel="noopener" class="font-display text-ink hover:text-rust" style="font-weight: 500;">
                  {g.name} ↗
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {topic.data.doctorQuestions && topic.data.doctorQuestions.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Questions to bring to the pediatrician</p>
          <ul class="grid gap-2">
            {topic.data.doctorQuestions.map((q) => (
              <li class="font-display text-ink leading-snug" style="font-weight: 400;">— {q}</li>
            ))}
          </ul>
        </aside>
      )}

      {topic.data.gearPicks && topic.data.gearPicks.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Gear that helps</p>
          <p class="font-display italic text-ink-soft text-xs mb-3 leading-snug" style="font-weight: 500;">
            Some of these are affiliate links. If you buy through them we earn a small commission; the price you pay does not change. <a href="/disclosure/" class="hover:text-rust underline-offset-2 hover:underline">Read our disclosure</a>.
          </p>
          <ul class="grid gap-3">
            {topic.data.gearPicks.map((g) => (
              <li>
                {g.affiliateSlug ? (
                  <a href={`/go/${g.affiliateSlug}/`} rel="sponsored nofollow noopener" class="font-display text-ink hover:text-rust" style="font-weight: 500;">{g.name} →</a>
                ) : (
                  <span class="font-display text-ink" style="font-weight: 500;">{g.name}</span>
                )}
                {g.note && (
                  <p class="font-display italic text-ink-soft text-sm mt-1 leading-snug" style="font-weight: 500;">{g.note}</p>
                )}
              </li>
            ))}
          </ul>
        </aside>
      )}

      <!-- Liability-conscious closing disclaimer. Reinforces that the article
           reflects sourced information from listed orgs and is not advice.
           Sits after Sources / Doctor Questions / Gear Picks so readers see the
           citation list before reading the disclaimer. -->
      <aside class="mt-12 pt-8 border-t border-bone bg-paper-warm p-6" aria-label="Editorial disclaimer">
        <p class="font-display italic text-rust mb-3 font-medium">About this piece and its limits</p>
        <p class="font-display text-ink-soft text-sm leading-snug">
          This piece was written by the Parent Coach Desk, a small group of parents who follow youth sports closely. It summarizes publicly available information from the medical organizations, governing bodies, and primary research listed in the Sources section above. We do our best to reflect what those sources say at the time of writing.
        </p>
        <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
          <strong class="font-medium text-ink">This is information, not advice.</strong> We are not physicians, athletic trainers, registered dietitians, mental-health professionals, lawyers, or licensed healthcare providers. We are not telling anyone what to do. We are sharing what published sources have said, with our reading of them.
        </p>
        <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
          For any decision about your child, please talk with their pediatrician, athletic trainer, or relevant licensed professional. Read the original sources cited above. Recommendations, laws, and rules change over time and vary by state, sport, and program; the right choice for your family depends on circumstances we cannot see from here.
        </p>
        <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
          If your child is in a medical emergency right now, call 911 or your local emergency number. For non-emergencies, your pediatrician's office is the right first call.
        </p>
        <p class="font-display text-ink-soft text-xs mt-3 leading-snug italic">
          The Parent Coach Desk and its contributors make no representations or warranties about the completeness, accuracy, or current relevance of this content and disclaim liability for actions taken based on it. Use of this page constitutes acceptance of these limits.
        </p>
        <p class="font-display italic text-ink-soft text-xs mt-4 leading-snug">
          Last updated {lastUpdated.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' })}. Corrections welcome at <a href={`mailto:${SITE.email}`} class="hover:text-rust underline-offset-2 hover:underline">{SITE.email}</a>.
        </p>
      </aside>
    </div>
  </article>

  <!-- Related across the site -->
  {(relatedPathways.length > 0 || relatedCalendars.length > 0 || siblingBody.length > 0) && (
    <section class="border-t border-bone bg-paper-warm">
      <div class="container-px py-10">
        <p class="font-display italic text-rust mb-4" style="font-weight: 500;">Related across the site</p>
        <div class="grid md:grid-cols-3 gap-6">
          {siblingBody.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">More from The body</p>
              <ul class="grid gap-2">
                {siblingBody.map(b => (
                  <li><a href={`/body/${b.id}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ <span set:html={renderTitle(b.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
          {relatedPathways.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">Pathways</p>
              <ul class="grid gap-2">
                {relatedPathways.map(p => (
                  <li><a href={`/pathways/${p.data.sport}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ {sportLabel(p.data.sport)} pathway</a></li>
                ))}
              </ul>
            </div>
          )}
          {relatedCalendars.length > 0 && (
            <div>
              <p class="font-display text-ink text-sm mb-3" style="font-weight: 500;">Season calendars</p>
              <ul class="grid gap-2">
                {relatedCalendars.map(c => (
                  <li><a href={`/season-calendar/${c.id}/`} class="font-display italic text-ink hover:text-rust text-sm leading-snug" style="font-weight: 500;">→ <span set:html={renderTitle(c.data.title)} /></a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

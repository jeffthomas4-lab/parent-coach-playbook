---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';

const topics = (await getCollection('body', ({ data }) => isLive(data)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const healthCategories = [
  { slug: 'concussion',         label: 'Concussion',          blurb: 'CDC HEADS UP, return-to-play, your state law.' },
  { slug: 'arm-care',            label: 'Arm care',            blurb: 'Pitch counts, off-season throwing, no curveballs before 14.' },
  { slug: 'heat',                label: 'Heat and hydration',  blurb: 'NATA youth heat acclimatization. The rules of an August practice.' },
  { slug: 'sleep',               label: 'Sleep',                blurb: 'AAP targets by age. Why the 6am practice is a performance issue.' },
  { slug: 'growth-plates',       label: 'Growth plates',        blurb: 'Sever\'s, Osgood-Schlatter\'s, why adolescent ankle pain matters.' },
  { slug: 'recovery',            label: 'Recovery',             blurb: 'Foam rollers, ice baths, when the gear actually helps.' },
  { slug: 'injury-prevention',   label: 'Injury prevention',    blurb: 'Pre-practice warm-up. The 11 minutes that change ACL math.' },
  { slug: 'nutrition',           label: 'Nutrition',            blurb: 'Real fueling for kids. The pre-game meal that doesn\'t backfire.' },
  { slug: 'hydration',           label: 'Hydration',            blurb: 'How much water, when. The electrolyte question.' },
  { slug: 'mental-skills',       label: 'Mental skills',        blurb: 'Pre-game nerves, identity, burnout signs.' },
  { slug: 'specialization',      label: 'Specialization',       blurb: 'When single-sport helps, when it costs you.' },
];

const safetyCategories = [
  { slug: 'weather',                  label: 'Weather',                  blurb: 'Lightning, heat, cold, wildfire smoke. When the day is too dangerous.' },
  { slug: 'coach-vetting',            label: 'Coach vetting',            blurb: 'SafeSport, background checks, the questions every league should answer.' },
  { slug: 'equipment-certification',  label: 'Equipment certification',  blurb: 'Helmet stamps, bat marks, mouthguards. What\'s safe, what\'s expired.' },
  { slug: 'travel-logistics',         label: 'Travel logistics',         blurb: 'Rooming, chaperones, transporting kids who aren\'t yours.' },
  { slug: 'emergency-response',       label: 'Emergency response',       blurb: 'Concussion now, broken-bone triage, AED location, missing-kid plan.' },
  { slug: 'conduct',                  label: 'Conduct',                  blurb: 'Bullying, hazing, ref abuse, locker room culture.' },
  { slug: 'aquatic',                  label: 'Aquatic',                  blurb: 'Pool deck rules, shallow-water blackout, open water.' },
  { slug: 'cyber',                    label: 'Cyber',                    blurb: 'Team apps, photo policies, recruiting DMs.' },
];

const groupedHealth = healthCategories.map(c => ({
  ...c,
  items: topics.filter(t => (t.data.subhub ?? 'health') === 'health' && t.data.category === c.slug),
})).filter(g => g.items.length > 0);

const groupedSafety = safetyCategories.map(c => ({
  ...c,
  items: topics.filter(t => t.data.subhub === 'safety' && (t.data as any).safetyCategory === c.slug),
})).filter(g => g.items.length > 0);

const sportBriefings = topics.filter(t => t.data.format === 'sport-briefing');
---
<BaseLayout
  title="Body & Safety"
  description="Pediatric sports medicine plus the safety canon. Concussion, arm care, heat, sleep, growth plates, equipment certification, lightning, league vetting, emergency response. What to know, what to ask the pediatrician, what to say to the league."
>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/reads/" class="hover:underline">Reads</a> · Body & Safety
      </p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl font-medium">
        Body & <em class="text-rust">Safety</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Two lenses, one hub. The body is the medicine: concussion, arm care, heat, sleep, growth plates. Safety is everything around the kid: weather, equipment, league vetting, emergency response, conduct.
      </p>

      <aside class="mt-8 border-l-4 pl-4 py-3 max-w-2xl" style="border-color: #B8908F; background: #FAF6F1;">
        <p class="font-display italic text-rust text-sm font-medium">What this is</p>
        <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
          Parent-to-parent. Not medical advice. We cite the governing body where one exists. For anything specific to your kid, talk to your pediatrician or your team's athletic trainer.
        </p>
      </aside>
    </div>
  </section>

  {/* Health lens */}
  {groupedHealth.length > 0 && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-8">
        <p class="font-display italic text-rust text-sm font-medium">The body</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium mt-1">Pediatric sports medicine, translated.</h2>
      </div>
    </section>
  )}
  {groupedHealth.map((g) => (
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-12">
        <div class="grid md:grid-cols-12 gap-8">
          <div class="md:col-span-4">
            <p class="font-display italic text-rust mb-2 font-medium">Category</p>
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">{g.label}</h2>
            <p class="font-display text-ink-soft mt-3 leading-snug">{g.blurb}</p>
          </div>
          <div class="md:col-span-8">
            <ul class="grid gap-4">
              {g.items.map((t) => (
                <li class="border border-bone bg-paper-warm p-5">
                  <a href={`/body/${t.slug}/`} class="font-display text-ink hover:text-rust text-xl leading-tight block font-medium" set:html={renderTitle(t.data.title)} />
                  <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{t.data.summary}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* Sport briefings — sit above category, after Health, before Safety */}
  {sportBriefings.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-12">
        <div class="grid md:grid-cols-12 gap-8">
          <div class="md:col-span-4">
            <p class="font-display italic text-rust mb-2 font-medium">Per-sport briefings</p>
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">Sport-specific safety</h2>
            <p class="font-display text-ink-soft mt-3 leading-snug">What is actually dangerous about youth football, and the per-sport equivalents as we ship them.</p>
          </div>
          <div class="md:col-span-8">
            <ul class="grid gap-4">
              {sportBriefings.map((t) => (
                <li class="border border-bone bg-paper-warm p-5">
                  <a href={`/body/${t.slug}/`} class="font-display text-ink hover:text-rust text-xl leading-tight block font-medium" set:html={renderTitle(t.data.title)} />
                  <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{t.data.summary}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Safety lens */}
  {groupedSafety.length > 0 && (
    <section class="border-b border-bone" style="background: #E5EFEB;">
      <div class="container-px py-8">
        <p class="font-display italic text-rust text-sm font-medium">Safety</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium mt-1">What's around the kid: people, places, equipment, weather, conduct.</h2>
      </div>
    </section>
  )}
  {groupedSafety.map((g) => (
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-12">
        <div class="grid md:grid-cols-12 gap-8">
          <div class="md:col-span-4">
            <p class="font-display italic text-rust mb-2 font-medium">Category</p>
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">{g.label}</h2>
            <p class="font-display text-ink-soft mt-3 leading-snug">{g.blurb}</p>
          </div>
          <div class="md:col-span-8">
            <ul class="grid gap-4">
              {g.items.map((t) => (
                <li class="border border-bone bg-paper-warm p-5">
                  <a href={`/body/${t.slug}/`} class="font-display text-ink hover:text-rust text-xl leading-tight block font-medium" set:html={renderTitle(t.data.title)} />
                  <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{t.data.summary}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  {groupedHealth.length === 0 && groupedSafety.length === 0 && sportBriefings.length === 0 && (
    <section>
      <div class="container-px py-12">
        <p class="font-display italic text-ink-soft font-medium">
          The first batch of topics ships this month. Check back.
        </p>
      </div>
    </section>
  )}
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicIcon from '../../components/TopicIcon.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';
import { AGE_BANDS, SPORTS } from '../../data/site';

// Pull every body piece (both subhubs), sorted newest first to match /reads/.
const all = (await getCollection('body', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const ITEMS_PER_PAGE = 60;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

const ageLabel = (a: string | undefined) =>
  AGE_BANDS.find(x => x.slug === a)?.label ?? null;

// Pretty labels for the meta chip.
const lensLabel = (subhub: string | undefined) =>
  subhub === 'safety' ? 'Safety' : 'The body';

const categoryLabel = (data: any) => {
  const slug = data.safetyCategory ?? data.category ?? '';
  if (!slug) return '';
  return slug.toString().replace(/-/g, ' ');
};

const formatLabel = (f: string | undefined) => {
  if (f === 'protocol') return 'Protocol';
  if (f === 'checklist') return 'Checklist';
  if (f === 'sport-briefing') return 'Sport briefing';
  return 'Topic';
};
---
<BaseLayout
  title="Body & Safety"
  description="Pediatric sports medicine plus the safety canon. Concussion, arm care, heat, sleep, growth plates, equipment certification, lightning, league vetting, emergency response, conduct."
>
  <section class="border-b border-bone">
    <div class="container-px pt-12 md:pt-14 pb-6">
      <figure class="mb-10 max-w-4xl">
        <img
          src="/illustrations/pillar-body-safety.webp"
          alt="A sideline first-aid kit half-open on a folding chair: bandages, instant cold pack, sunscreen, water bottle. A youth soccer ball and bag in the grass beside it."
          class="w-full border border-bone"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>
    </div>
    <div class="container-px pb-12 md:pb-14">
      <div class="grid md:grid-cols-12 gap-8">
        <div class="md:col-span-4">
          <TopicIcon topic="body" size={64} />
          <p class="font-display italic text-rust mb-2 mt-3 font-medium">Hub</p>
          <h1 class="font-display text-ink text-3xl md:text-4xl leading-[1.07] font-medium">
            Body & <em class="text-rust">Safety</em>
          </h1>
          <p class="font-display text-ink-soft mt-3 leading-snug">
            Two lenses, one hub. The body is the medicine: concussion, arm care, heat, sleep, growth plates. Safety is everything around the kid: weather, equipment, league vetting, emergency response, conduct.
          </p>
          <p class="font-display italic text-ink-soft text-sm mt-4 font-medium">
            {all.length} {all.length === 1 ? 'piece' : 'pieces'}
          </p>
          <aside class="mt-6 border-l-4 pl-4 py-2" style="border-color: #B8908F; background: #FAF6F1;">
            <p class="font-display italic text-rust text-xs font-medium">What this is</p>
            <p class="font-display text-ink-soft text-xs mt-1 leading-snug">
              Parent-to-parent. Not medical advice. We cite the governing body where one exists. For anything specific to your kid, talk to your pediatrician or your team's athletic trainer.
            </p>
          </aside>
        </div>
        <div class="md:col-span-8">
          {/* Filter bar */}
          <div class="border border-bone bg-paper-warm p-4 mb-6">
            <div class="space-y-4">
              {/* Lens filter (Health vs Safety) */}
              <div class="flex flex-wrap items-center gap-2" data-lens-filter>
                <span class="font-display italic text-ink-soft text-sm font-medium">Lens:</span>
                <button data-lens="" class="font-display italic px-2 py-0.5 border border-ink bg-ink text-paper text-xs font-medium">All</button>
                <button data-lens="health" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">The body</button>
                <button data-lens="safety" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">Safety</button>
              </div>
              {/* Format filter */}
              <div class="flex flex-wrap items-center gap-2" data-format-filter>
                <span class="font-display italic text-ink-soft text-sm font-medium">Format:</span>
                <button data-format="" class="font-display italic px-2 py-0.5 border border-ink bg-ink text-paper text-xs font-medium">All</button>
                <button data-format="topic" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">Topic</button>
                <button data-format="protocol" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">Protocol</button>
                <button data-format="checklist" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">Checklist</button>
                <button data-format="sport-briefing" class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">Sport briefing</button>
              </div>
              {/* Age filter */}
              <div class="flex flex-wrap items-center gap-2" data-age-filter>
                <span class="font-display italic text-ink-soft text-sm font-medium">Age:</span>
                <button data-age="" class="font-display italic px-2 py-0.5 border border-ink bg-ink text-paper text-xs font-medium">All ages</button>
                {AGE_BANDS.map((a) => (
                  <button data-age={a.slug} class="font-display italic px-2 py-0.5 border border-bone text-ink-soft text-xs hover:bg-paper font-medium">{a.label}</button>
                ))}
              </div>
              {/* Search */}
              <div class="flex items-center gap-2">
                <input
                  type="search"
                  placeholder="Search this hub..."
                  data-search-input
                  class="w-full max-w-sm px-2 py-1 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm"
                />
              </div>
            </div>
          </div>

          {/* Article grid */}
          {all.length === 0 ? (
            <p class="font-display italic text-ink-soft font-medium">More pieces coming.</p>
          ) : (
            <>
              <ul class="grid gap-px bg-bone" data-articles-grid>
                {all.slice(0, ITEMS_PER_PAGE).map((b) => {
                  const subhub = (b.data as any).subhub === 'safety' ? 'safety' : 'health';
                  const ageTags = ((b.data as any).ageBands ?? []).join(' ');
                  const fmt = (b.data as any).format ?? 'topic';
                  return (
                    <li
                      class="bg-paper"
                      data-lens-tag={subhub}
                      data-format-tag={fmt}
                      data-age-tags={ageTags}
                      data-title={b.data.title.toLowerCase()}
                      data-summary={(b.data.summary ?? '').toLowerCase()}
                    >
                      <a href={`/body/${b.slug}/`} class="block p-5 hover:bg-paper-warm transition-colors group">
                        <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
                          <p class="font-display italic text-ink-soft text-xs font-medium">
                            {[
                              lensLabel((b.data as any).subhub),
                              categoryLabel(b.data),
                              formatLabel(fmt),
                              fmtDate(b.data.publishedAt),
                            ].filter(Boolean).join(' · ')}
                          </p>
                        </div>
                        <h3
                          class="font-display text-ink text-lg leading-tight group-hover:text-rust transition-colors font-medium"
                          set:html={renderTitle(b.data.title)}
                        />
                        {b.data.summary && (
                          <p class="font-display text-ink-soft text-sm mt-1 leading-snug">{b.data.summary}</p>
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
              <p class="font-display italic text-ink-soft text-sm mt-6 hidden" data-empty>
                Nothing matches that filter. Try a different combination.
              </p>
            </>
          )}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      function init() {
        var lensBar = document.querySelector('[data-lens-filter]');
        var formatBar = document.querySelector('[data-format-filter]');
        var ageBar = document.querySelector('[data-age-filter]');
        var input = document.querySelector('[data-search-input]');
        var grid = document.querySelector('[data-articles-grid]');
        var empty = document.querySelector('[data-empty]');

        if (!grid) return;

        var l = '', f = '', a = '', q = '';

        function apply() {
          var rows = grid.querySelectorAll('[data-lens-tag]');
          var visible = 0;
          for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            var lens = row.getAttribute('data-lens-tag') || '';
            var fmt = row.getAttribute('data-format-tag') || '';
            var ages = row.getAttribute('data-age-tags') || '';
            var title = row.getAttribute('data-title') || '';
            var summary = row.getAttribute('data-summary') || '';
            var lOk = !l || lens === l;
            var fOk = !f || fmt === f;
            var ageList = ages ? ages.split(' ') : [];
            var aOk = !a || ageList.length === 0 || ageList.indexOf(a) !== -1;
            var qOk = !q || title.indexOf(q) !== -1 || summary.indexOf(q) !== -1;
            var ok = lOk && fOk && aOk && qOk;
            row.style.display = ok ? '' : 'none';
            if (ok) visible++;
          }
          if (empty) {
            if (visible > 0) empty.classList.add('hidden');
            else empty.classList.remove('hidden');
          }
        }

        function wire(bar, attr, setter) {
          if (!bar) return;
          bar.addEventListener('click', function (e) {
            var t = e.target;
            while (t && t.tagName !== 'BUTTON' && t !== bar) t = t.parentElement;
            if (!t || t.tagName !== 'BUTTON') return;
            var buttons = bar.querySelectorAll('button');
            for (var i = 0; i < buttons.length; i++) {
              buttons[i].classList.remove('bg-ink', 'text-paper', 'border-ink');
              buttons[i].classList.add('border-bone', 'text-ink-soft');
            }
            t.classList.remove('border-bone', 'text-ink-soft');
            t.classList.add('bg-ink', 'text-paper', 'border-ink');
            setter(t.getAttribute('data-' + attr) || '');
            apply();
          });
        }

        wire(lensBar,   'lens',   function (v) { l = v; });
        wire(formatBar, 'format', function (v) { f = v; });
        wire(ageBar,    'age',    function (v) { a = v; });

        if (input) {
          input.addEventListener('input', function () {
            q = input.value.trim().toLowerCase();
            apply();
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>

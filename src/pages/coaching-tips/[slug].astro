---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuyingGuideDisclosure from '../../components/BuyingGuideDisclosure.astro';
import { EDITORIAL, SITE, authorEntity } from '../../data/site';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';

export async function getStaticPaths() {
  const tips = await getCollection('coachingTips', ({ data }) => isLive(data));
  return tips.map((t) => ({
    params: { slug: t.slug },
    props: { tip: t },
  }));
}

const { tip } = Astro.props;
const { Content } = await tip.render();
// FTC 16 CFR Part 255: affiliate disclosure must appear before the first
// affiliate link, not just in the footer. Render it whenever the tip body
// contains a /go/ redirect link.
const hasAffiliateLinks = tip.body.includes('/go/');
const tagBits = [tip.data.sport, tip.data.age, tip.data.focus].filter(Boolean);

// JSON-LD: HowTo for drill content. Steps come from the markdown body, so we
// emit a minimal HowTo with name/description/single step pointing at the page.
// Better than nothing for SEO. A future content migration can structure steps.
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: stripTitle(tip.data.title),
  description: tip.data.summary,
  author: authorEntity(),
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  step: [{
    '@type': 'HowToStep',
    name: 'Run the drill',
    text: tip.data.summary,
    url: `${SITE.url}/coaching-tips/${tip.slug}/`,
  }],
};
---
<BaseLayout
  title={stripTitle(tip.data.title)}
  description={tip.data.summary}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/coaching-tips/" class="hover:underline">Drills</a>
        {tagBits.length > 0 && ' · ' + tagBits.join(' · ')}
      </p>
      <h1 class="font-display text-ink text-[2rem] md:text-[3rem] leading-[1.0] max-w-3xl font-medium" set:html={renderTitle(tip.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {tip.data.summary}
      </p>
    </div>
  </section>

  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      {hasAffiliateLinks && <BuyingGuideDisclosure />}
      <Content />
      <aside class="mt-12 pt-8 border-t border-bone">
        <p class="font-display italic text-rust mb-2 font-medium">From the {EDITORIAL.byline}</p>
        <p class="font-display text-ink-soft text-sm leading-snug">
          See the full <a href="/coaching-tips/" class="hover:text-rust underline-offset-2 hover:underline">drill library</a> or filter by sport and age to find what fits Tuesday's practice.
        </p>
      </aside>
    </div>
  </article>
</BaseLayout>

---
import affiliates from '../../data/affiliates.json';
import governance from '../../data/affiliate-governance.json';
import { governedAffiliateDestination } from '../../lib/affiliate-routing';
import type { AffiliateGovernance } from '../../lib/affiliate-routing';

export async function getStaticPaths() {
  return Object.entries(affiliates).map(([slug, entry]) => {
    const destination = governedAffiliateDestination(
      (entry as any).destination,
      (entry as any).campaign ?? slug,
      governance as AffiliateGovernance,
    );
    return { params: { slug }, props: { destination } };
  });
}

const { destination } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${destination}`} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={destination} />
  <title>Redirecting...</title>
  <!-- JS redirect removed: <meta http-equiv="refresh"> above handles it without unsafe-inline -->
</head>
<body>
  <p>Redirecting to <a href={destination} rel="sponsored noopener">{destination}</a>...</p>
</body>
</html>

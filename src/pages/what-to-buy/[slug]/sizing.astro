const notes = sizingNotes[guide.slug] ?? {
  intro: 'Sizing notes for this activity are coming. Email us at parentcoachplaybook@gmail.com if you want a specific question answered first.',
  sections: [],
};
---
<BaseLayout
  title={`${guide.label} sizing guide`}
  description={`How to size ${guide.label.toLowerCase()} gear for kids: practical fit tests, age-by-age sizing, what to do with used gear.`}
>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/what-to-buy/" class="hover:underline">What to Buy</a> · <a href={`/what-to-buy/${guide.slug}/`} class="hover:underline">{guide.label}</a> · Sizing
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.0] max-w-3xl" style="font-weight: 500;">
        {guide.label} <em class="text-rust">sizing</em> guide.
      </h1>
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {notes.intro}
      </p>
    </div>
  </section>

  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      {notes.sections.map((s) => (
        <section class="mb-10">
          <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight mt-0 mb-4" style="font-weight: 500;">{s.heading}</h2>
          {s.body.map((p) => (
            <p>{p}</p>
          ))}
        </section>
      ))}

      <aside class="mt-12 pt-8 border-t border-bone">
        <p class="font-display italic text-rust mb-2" style="font-weight: 500;">A note on used gear</p>
        <p>Used cleats, skates, and shoes are fine if you replace the insole. The insole is the only piece that molds to a foot. A fresh insole resets the shoe to a neutral position so your kid is not standing in someone else’s shape.</p>
        <p>Used helmets are fine if the certification sticker is current and the re-conditioning record is intact. NOCSAE for football, baseball, lacrosse. HECC for hockey. ASTM for women’s lacrosse goggles.</p>
        <p>Used pads, bats, sticks, rackets are usually fine. Inspect for cracks. Trust the kid’s hands and feet on a fit test.</p>
        <a href={`/what-to-buy/${guide.slug}/`} class="t-cta inline-block mt-4">Back to the {guide.label.toLowerCase()} guide →</a>
      </aside>
    </div>
  </article>
</BaseLayout>

      { heading: 'Balls', body: [
        'Red dot foam or felt: ages 4-6.',
        'Orange dot: ages 7-9.',
        'Green dot: ages 10-11.',
        'Yellow regular: ages 12+.',
      ]},
      { heading: 'Stringing', body: [
        'A factory-strung racket loses tension in 3-6 months. Re-string at the beginning of each playing season.',
      ]},

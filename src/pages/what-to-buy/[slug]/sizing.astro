---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BUYING_GUIDES, EDITORIAL } from '../../../data/site';

export async function getStaticPaths() {
  return BUYING_GUIDES.map((g) => ({
    params: { slug: g.slug },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;

// Sizing copy keyed by slug. Sport-specific. Practical, not theoretical.
const sizingNotes: Record<string, { intro: string; sections: { heading: string; body: string[] }[] }> = {
  baseball: {
    intro: 'Baseball gear has three sizing decisions that matter most: glove, bat, and helmet. Get those right, the rest is forgiving.',
    sections: [
      { heading: 'Glove', body: [
        'Ages 5-7: 10 to 10.5 inches. A first glove should close easily. If the kid cannot close it on a thrown ball, it is too big.',
        'Ages 8-10: 10.5 to 11.5 inches. Infielders go shorter, outfielders go longer.',
        'Ages 11-12: 11.5 to 12 inches.',
        'Ages 13+: 11.5 inches for middle infield, 12 inches for outfield, 12.5 for first base.',
        'How to test fit: have the kid open and close the glove ten times. If their hand is shaking by ten, the glove is stiff for them. Stiff is fine for an older kid. Not for a beginner.',
      ]},
      { heading: 'Bat', body: [
        'The reach test: stand the bat next to the kid, knob on the floor. The bat should reach the middle of the palm with the arm fully extended down the side.',
        'The leg test: stand the bat on the ground next to the kid. It should reach the kid\'s hip bone. Not the belly button. Not the ribcage.',
        'The chest test: kid holds the bat straight out from their chest with one arm. They should be able to hold it for ten seconds without the bat tip dropping.',
        'Drop weight: Little League uses a -10 or -11 drop for ages 5-12 (USABat stamp required). Senior leagues drop to -8 or -5. Travel teams may require BBCOR (-3) at age 13+.',
      ]},
      { heading: 'Helmet', body: [
        'Sizing is by head circumference. Measure with a soft tape an inch above the eyebrows.',
        'Most youth helmets fit a 6 1/2 to 7 1/4 inch range. Look for the NOCSAE seal inside.',
        'Fit check: helmet should not slide front-to-back when the kid shakes their head. The chin strap snug, not strangling.',
      ]},
      { heading: 'Cleats', body: [
        'Buy a half size up from their street shoe. Feet swell on the field.',
        'Molded cleats for Little League (metal cleats banned for U-13 in most leagues).',
        'If you buy used cleats, replace the insole. Used cleats are shaped to whoever wore them. A fresh insole resets the foot to a neutral position.',
      ]},
    ],
  },
  softball: {
    intro: 'Softball sizing is close to baseball with a few specific differences: bigger glove for the bigger ball, different bat profile, and chest protectors for catchers.',
    sections: [
      { heading: 'Glove', body: [
        'Softball gloves run an inch longer than baseball gloves. Ages 5-7: 11 inches. Ages 8-10: 11 to 12 inches. Ages 11-12: 12 to 12.5 inches. Ages 13+: 12.5 to 13 inches for fielders, 13 inches for first base.',
        'The web should be deeper than a baseball glove. The ball is bigger.',
        'Same fit test as baseball: kid opens and closes the glove ten times without their hand shaking.',
      ]},
      { heading: 'Bat', body: [
        'Same reach and leg tests as baseball.',
        'Drop weight is typically -11 to -12 for fastpitch up to age 12, dropping to -10 for older players. ASA/USA Softball stamp required.',
        'Slowpitch bats are different. If you are not sure, ask the league what stamp they require.',
      ]},
      { heading: 'Face mask and helmet', body: [
        'Many fastpitch leagues require a fielder\'s face mask. Sizing is by youth/adult and adjusts at the chin strap.',
        'Catcher\'s gear: chest protector (NOCSAE-approved for the kid\'s age band), shin guards, mask. Sized by height.',
      ]},
    ],
  },
  soccer: {
    intro: 'Soccer is mostly cleats and shin guards. Both are fit-tested in seconds.',
    sections: [
      { heading: 'Cleats', body: [
        'Buy a half size up from street shoe. Feet swell on the field.',
        'For ages 5-9, get firm-ground molded cleats with rounded studs. Avoid bladed studs at this age.',
        'Used cleats are fine if you replace the insole. The insole is the only piece that molds to the foot. A new insole resets it.',
        'Indoor soccer needs a separate flat-soled shoe. Cleats damage indoor surfaces and most leagues prohibit them.',
      ]},
      { heading: 'Shin guards', body: [
        'The 70-80 percent rule: the shin guard should cover 70-80 percent of the shin from the top of the cleat to just below the knee.',
        'Ages 5-7: about 6 inches. Ages 8-10: 6-7 inches. Ages 11-13: 7-9 inches. Ages 14+: youth XL or adult small.',
        'Slip-in style is fine through about age 10. Older players want strap-on or sleeve style.',
      ]},
      { heading: 'Ball', body: [
        'Size 3: ages 4-8. Size 4: ages 9-12. Size 5: ages 13+.',
        'Buy two. One stays in the car. One stays in the garage.',
      ]},
    ],
  },
  basketball: {
    intro: 'Basketball is mostly shoes. The ball size matters too, and so does the shoe-vs-court grip.',
    sections: [
      { heading: 'Shoes', body: [
        'Court shoes have a flat sole with a herringbone tread. Running shoes do not work and slide on a wood floor.',
        'A high-top is preferred through age 12 because ankle stability matters more than weight at that age. Mid-cut after that.',
        'Buy at the end of the day when feet have swelled. Bring the socks they will play in.',
      ]},
      { heading: 'Ball', body: [
        'Size 5 (27.5 inches): ages 5-8.',
        'Size 6 (28.5 inches, intermediate): ages 9-11 boys, ages 9-13+ girls.',
        'Size 7 (29.5 inches, official): boys 12+ and high school.',
      ]},
    ],
  },
  'flag-football': {
    intro: 'Flag football needs almost no equipment. The fit decisions are mouthguard and cleats.',
    sections: [
      { heading: 'Mouthguard', body: [
        'NOCSAE-stamped boil-and-bite is the right entry point. Five to fifteen dollars.',
        'A high-top fit-test: the kid bites it after boiling, the impression should fully cover the upper teeth and gums.',
        'Replace it every season. Mouthguards harden and crack over time.',
      ]},
      { heading: 'Cleats', body: [
        'Soccer cleats work. Football cleats work. Rubber-stud, not metal.',
        'NFL Flag rules require non-metal cleats. Most leagues match this rule.',
      ]},
      { heading: 'Gloves', body: [
        'Optional. The right glove is sticky receiver gloves: small for kids 5-9, medium for 10-13, large for 14+.',
        'A kid who hates dropping the ball will love these. A kid who plays line will not need them.',
      ]},
    ],
  },
  football: {
    intro: 'Tackle football is the most fit-critical sport on the list. Helmet and shoulder pads must be sized correctly.',
    sections: [
      { heading: 'Helmet', body: [
        'Measure head circumference an inch above the eyebrows. Match to manufacturer chart.',
        'NOCSAE certification is mandatory. Re-conditioning every 1-2 years per manufacturer guidance. A used helmet must have a current NOCSAE re-cert sticker.',
        'Fit check: no front-to-back slide when shaking the head, chin strap snug, no pressure points after ten minutes wearing.',
      ]},
      { heading: 'Shoulder pads', body: [
        'Measure shoulder-to-shoulder across the back, plus chest size.',
        'Pads should sit on the AC joint, not the bicep. Arm holes large enough to lift overhead without the pads riding up.',
        'Skill-position pads (running back, receiver) are slimmer than line pads. Match the position.',
      ]},
      { heading: 'Cleats', body: [
        'Half size up from street shoe.',
        'Mid-cut for ankle protection. High-top for linemen.',
        'Molded cleats for youth. Detachable studs only at high-school level and above.',
      ]},
    ],
  },
  hockey: {
    intro: 'Hockey is the most expensive sport and the hardest to size yourself. The skate is the keystone fit.',
    sections: [
      { heading: 'Skates', body: [
        'Most kids fit a hockey skate 1 to 1.5 sizes smaller than their street shoe. Confirm at a hockey shop with a baking process if the brand supports it.',
        'A hot-spot fit is the goal: heel locked, toes lightly brushing the cap when standing, fully off the cap when bent in the stance.',
        'Used skates are fine if the boot has not broken down. Look at the heel counter. If it has lost shape, pass.',
      ]},
      { heading: 'Helmet', body: [
        'HECC certification mandatory. The sticker has an expiration date. Past that date, the helmet is not legal for play.',
        'Cage or full shield required for youth. Sized by helmet model.',
      ]},
      { heading: 'Stick', body: [
        'Junior, intermediate, senior. The right length stands between chin and tip of nose with skates on.',
        'Flex rating roughly half the player\'s weight in pounds.',
      ]},
    ],
  },
  lacrosse: {
    intro: 'Lacrosse gear is sport-specific and sized by age band more than measurement. Boys and girls gear differs.',
    sections: [
      { heading: 'Stick', body: [
        'Boys: youth stick (37-42 inches) for ages 8-12, full length (40-72 inches) for ages 13+. Defenders use longer poles.',
        'Girls: youth (35-43 inches), full length (35.5-43.25 inches) at older ages.',
        'Pocket depth is regulated. Tournament officials check.',
      ]},
      { heading: 'Helmet (boys)', body: [
        'NOCSAE certification required. Sized by head circumference plus model fit.',
        'Cage and chin strap included. Mouthguard worn under the cage.',
      ]},
      { heading: 'Chest protector (boys)', body: [
        'NOCSAE ND200 certification mandatory since 2021/22. This is non-negotiable.',
        'Sized by chest circumference. Should not restrict arm movement.',
      ]},
      { heading: 'Goggles (girls)', body: [
        'ASTM F803 certification required.',
        'Sized to the face. Should not bounce when the player runs.',
      ]},
    ],
  },
  volleyball: {
    intro: 'Volleyball is mostly shoes and knee pads. Both are fit-tested fast.',
    sections: [
      { heading: 'Shoes', body: [
        'Indoor court shoes, not running shoes. The lateral cut and gum-rubber sole matter for the side-to-side movement.',
        'Buy at the end of the day. Socks the kid will play in.',
        'Used indoor shoes are not a great buy. The sole compresses with use.',
      ]},
      { heading: 'Knee pads', body: [
        'Sized small/medium/large. Should sit just below the kneecap when bent.',
        'Two pairs is standard. They take a beating.',
      ]},
      { heading: 'Ball', body: [
        'Size 5 (official): ages 12+.',
        'Lighter youth ball for ages 8-11.',
      ]},
    ],
  },
  swimming: {
    intro: 'Swim gear is the simplest list on the site. Suit, cap, goggles. Sized in minutes.',
    sections: [
      { heading: 'Suit', body: [
        'A training suit (twenty to forty dollars) is the right buy for ages 5-12. Tech suits are for kids who compete year-round at age 12+.',
        'Polyester lasts longer than nylon in chlorine. The brand on the tag matters less than the fabric.',
        'A snug fit. Not painful, not loose. Loose suits create drag.',
      ]},
      { heading: 'Goggles', body: [
        'Press the goggle to the eye socket without the strap. If it suctions for two seconds, the seal fits.',
        'Anti-fog coating wears off within a season. A drop of baby shampoo on the inside of the lens is the workaround.',
        'Buy two pairs. One always lives in the bag.',
      ]},
      { heading: 'Cap', body: [
        'Silicone is more comfortable than latex and lasts longer.',
        'Long hair: a longer cap or two caps stacked.',
      ]},
    ],
  },
  'track-field': {
    intro: 'Sizing in track and field changes by event. Trainers are the base layer for everyone.',
    sections: [
      { heading: 'Trainers', body: [
        'A neutral running shoe in the kid\'s correct size. Not a court shoe. Not a basketball shoe.',
        'Replace every 300-500 miles, which for a youth athlete is roughly every season.',
      ]},
      { heading: 'Sprint spikes (100-400m and hurdles)', body: [
        'A stiffer plate, six to eight pin holes, lightweight upper.',
        'Buy a half size smaller than the trainer. Sprint spikes should feel close to the foot.',
      ]},
      { heading: 'Distance flats / spikes (800m+)', body: [
        'For 800-1600m: a flexible spike with four to six pins.',
        'For 3200m+ on track: a flat or a softer spike.',
      ]},
      { heading: 'Jump spikes', body: [
        'Long jump and triple jump: a spike with a heel plate. Different from a sprint spike.',
        'High jump: a high jump spike, sized to the takeoff foot.',
      ]},
      { heading: 'Throwing shoe', body: [
        'A flat-soled shoe with a smooth bottom for the throwing circle. No spikes.',
        'Brand and exact model matters less than fit.',
      ]},
    ],
  },
  'cross-country': {
    intro: 'Cross country gear is trainers, racing flats, and cold-weather layers. The fit decisions are simple.',
    sections: [
      { heading: 'Trainers', body: [
        'A neutral running shoe sized correctly. Take to a running store for a gait check at the start of the season.',
        'A second pair on rotation extends the life of both.',
      ]},
      { heading: 'Racing flats', body: [
        'Optional through age 12. Worth it at age 13+.',
        'Lighter and stiffer than trainers. Not for daily training.',
      ]},
      { heading: 'Spikes (cross country)', body: [
        'Cross country spikes have aggressive lugs in addition to pins.',
        'Different from track spikes. Track spikes do not bite on grass and mud.',
      ]},
      { heading: 'Cold weather', body: [
        'Tights, a long-sleeve base layer, gloves, a beanie. Cross country season runs into November in most regions.',
        'Layers come off mid-race in some warm-late-fall regions. Practice with the layers the kid will race in.',
      ]},
    ],
  },
  tennis: {
    intro: 'Racket length is the most important fit decision in tennis. A wrong-length racket teaches a wrong swing.',
    sections: [
      { heading: 'Racket', body: [
        'Ages 4-6: 19-21 inch.',
        'Ages 7-8: 21-23 inch.',
        'Ages 9-10: 23-25 inch.',
        'Ages 11-12: 25-26 inch.',
        'Ages 13+: 27 inch (full size).',
        'Length test: rest the racket head on the ground. The grip should sit at or just below the kid\'s wrist.',
      ]},
      { heading: 'Shoes', body: [
        'Court soles with a herringbone tread. Running shoes do not work. They damage the court and slide.',
        'Hard court vs clay court soles differ. Most rec play is hard court.',

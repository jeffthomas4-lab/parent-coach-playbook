---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import BuyingGuideDisclosure from '../../components/BuyingGuideDisclosure.astro';
import { BUYING_GUIDES, EDITORIAL } from '../../data/site';
import { isLive } from '../../lib/publishFilter';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => isLive(data));
  return guides.map((g) => ({
    params: { slug: g.id },          // filename-derived slug, e.g. "baseball"
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const meta = BUYING_GUIDES.find(g => g.slug === guide.id)!;

// Pull only top-level (h2) headings for the in-page jump nav
const jumpNav = headings.filter((h) => h.depth === 2);

// SEO title/description with sane fallbacks for guides that haven't set them yet.
const pageTitle = guide.data.seoTitle
  ?? `Youth ${guide.data.activity} Gear List by Age: What to Buy (and Skip)`;
const pageDescription = guide.data.seoDescription ?? guide.data.lede;

// Structured data. BreadcrumbList for every guide; ItemList built from the
// gear-pick cards in the markdown body (h3 title + /go/ slug pairs).
import { SITE } from '../../data/site';
const pageUrl = `${SITE.url}/what-to-buy/${guide.id}/`;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Gear Files', item: `${SITE.url}/what-to-buy/` },
    { '@type': 'ListItem', position: 3, name: guide.data.activity, item: pageUrl },
  ],
};
// Each gear-pick card renders <h3 ...>Product name</h3> ... href="/go/slug/".
const cardBlocks = (guide.body ?? '').match(/<h3[^>]*>[^<]+<\/h3>[\s\S]*?href="\/go\/[a-z0-9-]+\/"/g) ?? [];
const gearItems = cardBlocks.map((block) => {
  const name = block.match(/<h3[^>]*>([^<]+)<\/h3>/)?.[1]?.trim();
  const goSlug = block.match(/href="\/go\/([a-z0-9-]+)\/"/)?.[1];
  return name && goSlug ? { name, url: `${SITE.url}/go/${goSlug}/` } : null;
}).filter(Boolean) as { name: string; url: string }[];
const itemListSchema = gearItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: pageTitle,
  numberOfItems: gearItems.length,
  itemListElement: gearItems.map((it, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'Product', name: it.name, url: it.url },
  })),
} : null;
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {itemListSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  )}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/what-to-buy/" class="hover:underline">Gear Files</a> · {meta.category === 'sport' ? 'Sports' : meta.category === 'activity' ? 'Performing arts' : meta.category === 'coach-gear' ? 'Coach gear' : 'Essentials'}
      </p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl font-medium">
        Gear file for <em class="text-rust">{guide.data.activity.toLowerCase()}</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl mt-6 max-w-2xl leading-snug">
        {guide.data.lede}
      </p>
      <div class="mt-6 grid sm:grid-cols-2 gap-3 max-w-2xl">
        <div class="border border-bone p-4 bg-paper-warm">
          <p class="font-display italic text-rust text-sm font-medium">Rough cost</p>
          <p class="font-display text-ink mt-1 font-medium">{guide.data.costSummary}</p>
        </div>
        {guide.data.seasonNote && (
          <div class="border border-bone p-4 bg-paper-warm">
            <p class="font-display italic text-rust text-sm font-medium">Season notes</p>
            <p class="font-display text-ink mt-1 font-medium">{guide.data.seasonNote}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section>
    <div class="container-px py-12 grid lg:grid-cols-12 gap-10">
      {jumpNav.length > 1 && (
        <aside class="lg:col-span-3 lg:sticky lg:top-6 self-start">
          <p class="font-display italic text-rust mb-3 font-medium">Jump to</p>
          <ul class="grid gap-2">
            {jumpNav.map((h) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class="font-display italic text-ink hover:text-rust transition-colors font-medium"
                >{h.text}</a>
              </li>
            ))}
          </ul>

          <div class="mt-8 pt-6 border-t border-bone">
            <p class="font-display italic text-rust text-sm font-medium">{EDITORIAL.byline}</p>
            <p class="font-display italic text-ink-soft text-xs mt-1">
              Updated {(guide.data.updatedAt ?? guide.data.publishedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })}
            </p>
            <p class="font-display italic text-ink-soft text-xs mt-3 leading-snug">
              Need to know what size? <a href={`/what-to-buy/${guide.id}/sizing/`} class="text-rust hover:underline">{guide.data.activity} sizing guide →</a>
            </p>
          </div>
        </aside>
      )}

      <div class={`${jumpNav.length > 1 ? 'lg:col-span-9' : 'lg:col-span-12 max-w-prose mx-auto'} article-body`}>
        <BuyingGuideDisclosure />
        <Content />
      </div>
    </div>
  </section>

  <NewsletterSignup />
</BaseLayout>

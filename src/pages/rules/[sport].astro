---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { SPORTS } from '../../data/site';

export async function getStaticPaths() {
  const pieces = await getCollection('rules', ({ data }) => isLive(data));
  return pieces.map((p) => ({ params: { sport: p.data.sport }, props: { piece: p } }));
}

const { piece } = Astro.props;
const { Content } = await piece.render();
const sportLabel = SPORTS.find(s => s.slug === piece.data.sport)?.label ?? piece.data.sport;
---
<BaseLayout
  title={piece.data.title}
  description={piece.data.summary}
>
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/tools/" class="hover:underline">Tools</a> ·
        <a href="/rules/" class="hover:underline">Rules at-a-glance</a> ·
        {sportLabel}
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl" style="font-weight: 500;">
        {piece.data.title}
      </h1>
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {piece.data.summary}
      </p>
    </div>
  </section>

  <!-- Structured rules block -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-12">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        <div>
          <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">Field/court setup</p>
          <p class="font-display text-ink leading-snug">{piece.data.fieldSetup}</p>
        </div>
        <div>
          <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">Game length</p>
          <p class="font-display text-ink leading-snug">{piece.data.gameLength}</p>
        </div>
      </div>

      {piece.data.scoringBasics && piece.data.scoringBasics.length > 0 && (
        <div class="mt-8 max-w-3xl">
          <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">Scoring basics</p>
          <ul class="grid gap-1.5">
            {piece.data.scoringBasics.map((s) => (
              <li class="font-display text-ink leading-snug">— {s}</li>
            ))}
          </ul>
        </div>
      )}

      {piece.data.commonCalls && piece.data.commonCalls.length > 0 && (
        <div class="mt-8 max-w-3xl">
          <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">Calls you'll see</p>
          <ul class="grid gap-1.5">
            {piece.data.commonCalls.map((s) => (
              <li class="font-display text-ink leading-snug">— {s}</li>
            ))}
          </ul>
        </div>
      )}

      {piece.data.thingsParentsGetWrong && piece.data.thingsParentsGetWrong.length > 0 && (
        <div class="mt-8 max-w-3xl bg-paper-warm border-l-4 pl-4 py-3" style="border-color: #C5713D;">
          <p class="font-display italic text-rust mb-2 text-sm" style="font-weight: 500;">Three things parents most often get wrong</p>
          <ul class="grid gap-1.5">
            {piece.data.thingsParentsGetWrong.map((s) => (
              <li class="font-display text-ink leading-snug">— {s}</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  {/* Optional markdown body for extra context */}
  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      <Content />

      <aside class="mt-10 pt-6 border-t border-bone">
        <p class="font-display italic text-rust mb-2" style="font-weight: 500;">The official rulebook</p>
        <p class="font-display text-ink leading-snug">
          {piece.data.governingBody.name}:
          <a href={piece.data.governingBody.url} target="_blank" rel="noopener" class="text-rust hover:underline">{piece.data.governingBody.url} ↗</a>
        </p>
        {piece.data.ruleBookUrl && (
          <p class="font-display text-ink leading-snug mt-2">
            Direct rulebook link: <a href={piece.data.ruleBookUrl} target="_blank" rel="noopener" class="text-rust hover:underline">{piece.data.ruleBookUrl} ↗</a>
          </p>
        )}
      </aside>

      <p class="font-display italic text-ink-soft text-xs mt-8 pt-6 border-t border-bone" style="font-weight: 500;">
        Last updated {piece.data.publishedAt.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}.
      </p>
    </div>
  </article>
</BaseLayout>

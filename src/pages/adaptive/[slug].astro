---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';

export async function getStaticPaths() {
  const pieces = await getCollection('adaptive', ({ data }) => isLive(data));
  return pieces.map((p) => ({ params: { slug: p.slug }, props: { piece: p } }));
}

const { piece } = Astro.props;
const { Content } = await piece.render();
---
<BaseLayout
  title={stripTitle(piece.data.title)}
  description={piece.data.summary}
>
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/tools/" class="hover:underline">Tools</a> ·
        <a href="/adaptive/" class="hover:underline">Adaptive</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl font-medium" set:html={renderTitle(piece.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {piece.data.summary}
      </p>
      <aside class="mt-7 border-l-4 pl-4 py-3 max-w-2xl" style="border-color: #B8908F; background: #FAF6F1;">
        <p class="font-display italic text-rust text-xs font-medium">Not medical advice</p>
        <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
          This is parent-perspective information. We name programs, organizations, and accommodations that families have found useful. We are not a substitute for IEP teams, OT or PT clinicians, developmental pediatricians, or any other specialist your child works with. Talk to those professionals before making decisions that affect your child's care.
        </p>
      </aside>
    </div>
  </section>

  <article class="container-px py-10 md:py-14">
    <div class="article-body max-w-prose mx-auto">
      <Content />

      {piece.data.governingBodies && piece.data.governingBodies.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-bone">
          <p class="font-display italic text-rust mb-3 font-medium">Sources & programs</p>
          <ul class="grid gap-2">
            {piece.data.governingBodies.map((g) => (
              <li>
                <a href={g.url} target="_blank" rel="noopener" class="font-display text-ink hover:text-rust font-medium">
                  {g.name} ↗
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <p class="font-display italic text-ink-soft text-xs mt-10 pt-6 border-t border-bone font-medium">
        Last updated {piece.data.publishedAt.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}.
      </p>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTRIBUTORS } from '../data/site';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft);
const byContributor = (slug: string) =>
  all.filter(a => a.data.contributor === slug)
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const contribs = Object.values(CONTRIBUTORS);
---
<BaseLayout
  title="Contributors"
  description="Meet the three voices who write here. Maren, Dan, and Jeff."
>
  <section class="border-b border-bone">
    <div class="container-px py-16 md:py-20">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Contributors</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl" style="font-weight: 500;">
        Three of us write here. <em class="text-rust">Most days.</em>
      </h1>
      <p class="font-display text-ink-soft text-xl mt-6 max-w-2xl leading-snug">
        Maren writes most things. Dan writes when he has been thinking about something long enough to be useful. Jeff writes the longer pieces and edits everything.
      </p>
    </div>
  </section>

  {contribs.map((c) => {
    const posts = byContributor(c.slug);
    return (
      <section class="border-b border-bone" style={`background: ${c.accentBg};`}>
        <div class="container-px py-14 grid md:grid-cols-12 gap-10">
          <div class="md:col-span-4 flex flex-col items-start gap-4">
            <div
              class="w-24 h-24 rounded-full flex items-center justify-center font-display italic"
              style={`background: ${c.accent}; color: #FAF6EE; font-weight: 500; font-size: 2.5rem;`}
              aria-hidden="true"
            >{c.avatarLetter}</div>
            <div>
              <div class="font-display italic" style={`color: ${c.accent}; font-weight: 500;`}>
                {c.role}
              </div>
              <h2 class="font-display text-ink text-3xl md:text-4xl mt-1" style="font-weight: 500;">{c.name}</h2>
            </div>
          </div>
          <div class="md:col-span-8">
            <p class="font-display text-ink text-xl leading-snug" style="font-weight: 500;">
              {c.short}
            </p>
            <p class="font-display text-ink-soft mt-4 leading-relaxed">
              {c.bio}
            </p>

            {posts.length > 0 && (
              <div class="mt-8">
                <p class="font-display italic mb-3" style={`color: ${c.accent}; font-weight: 500;`}>
                  Recent posts
                </p>
                <ul class="grid gap-2">
                  {posts.slice(0, 4).map((p) => (
                    <li>
                      <a
                        href={`/${p.data.phase}/${p.slug}/`}
                        class="font-display text-ink hover:text-rust"
                        style="font-weight: 500;"
                        set:html={p.data.title.replace(/\*([^*]+)\*/g, '<em style="color:' + c.accent + ';">$1</em>')}
                      />
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </section>
    );
  })}

  <section>
    <div class="container-px py-16 max-w-3xl">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">A note on names</p>
      <div class="article-body">
        <p>Jeff writes under his real name. Maren and Dan are composite voices drawn from interviews with parent-coaches across our network. Everything they write is true to a real situation, just stitched together so we can write honestly about families without naming any one of them.</p>
        <p>If that bothers you, fair. It bothered us a little too. We landed here because moms in our network said they would rather read posts where the writer wasn't pretending it was fine when it wasn't. The composite voice lets us tell the truth.</p>
        <p>If you want to write here under your real name, get in touch. We are starting to pay contributors a small honorarium per post.</p>
      </div>
    </div>
  </section>
</BaseLayout>

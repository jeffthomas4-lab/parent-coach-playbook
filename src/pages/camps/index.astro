---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { listApprovedCamps, listFeaturedCamps, type Camp } from '../../lib/camps-db';
import { CAMP_SPORTS } from '../../data/site';

const sportLabel = (slug: string): string => {
  const match = CAMP_SPORTS.find((s) => s.slug === slug);
  if (match) return match.label;
  return slug
    .split(/[\s-]+/)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

// SSR. Pulls live from D1 each request, but the response is cached at
// Cloudflare's edge for 10 minutes (s-maxage=600), with stale-while-revalidate
// keeping the page snappy for up to 24 hours while a background refresh runs.
// Net effect: at typical traffic, ~1 D1 read per 10 minutes per Cloudflare PoP
// instead of 1 read per visit.
export const prerender = false;
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=600, stale-while-revalidate=86400',
);

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
let camps: Camp[] = [];
let dbAvailable = !!env?.DB;
if (env?.DB) {
  try {
    camps = await listApprovedCamps(env.DB);
  } catch (e) {
    console.error('listApprovedCamps failed', e);
  }
}

let featuredCamps: Camp[] = [];
if (env?.DB) {
  try {
    featuredCamps = await listFeaturedCamps(env.DB);
  } catch (e) {
    console.error('listFeaturedCamps failed', e);
  }
}

// Parse YYYY-MM-DD as local date (not UTC). Avoids the off-by-one timezone bug
// where new Date('2026-08-03') becomes Aug 2 in Pacific time.
const fmtDateRange = (start: string, end: string) => {
  const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  const [sy, sm, sd] = start.split('-').map(Number);
  const [ey, em, ed] = end.split('-').map(Number);
  if (sm === em && sy === ey) {
    return `${MONTHS[sm - 1]} ${sd}–${ed}, ${sy}`;
  }
  return `${MONTHS[sm - 1]} ${sd} – ${MONTHS[em - 1]} ${ed}, ${sy}`;
};

const PNW = new Set(['WA', 'OR', 'ID', 'MT', 'AK']);
const pnw = camps.filter(c => PNW.has(c.state));
const elsewhere = camps.filter(c => !PNW.has(c.state));

// Render cards as HTML strings in the frontmatter and inject via set:html.
// Astro's per-element JSX iteration was costing ~50-100µs per card; at 1308
// camps that pushed past the Cloudflare Pages Function CPU budget and triggered
// 1102 errors. A pre-built HTML string is roughly 10x faster on the server.
const escHtml = (s: unknown) => String(s ?? '')
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

const renderCardHtml = (c: Camp): string => {
  const photo = c.hero_photo_key
    ? `<div class="mb-3 border border-bone overflow-hidden bg-paper-warm" style="aspect-ratio: 16/9;"><img src="https://parentcoachdesk.com/camp-photos/${escHtml(c.hero_photo_key)}" alt="${escHtml(c.name)}" class="w-full h-full object-cover" loading="lazy" decoding="async" width="800" height="450" /></div>`
    : '';
  const verified = c.verified === 1
    ? `<span class="font-display text-rust text-xs font-medium" style="white-space: nowrap">Verified ✓</span>`
    : '';
  const dayLabel = c.day_or_overnight === 'day' ? 'Day camp' : 'Overnight';
  const spotsLabel = c.spots_status === 'open' ? 'Open' : c.spots_status === 'waitlist' ? 'Waitlist' : 'Full';
  const price = c.price_text
    ? `<p class="font-display italic text-rust text-xs mt-2 font-medium">${escHtml(c.price_text)}</p>`
    : '';
  return `<div class="camp-card bg-paper p-5 hover:bg-paper-warm transition-colors group" data-camp-id="${escHtml(c.id)}">${photo}<div class="flex items-start justify-between gap-2 mb-1"><p class="font-display italic text-ink-soft text-xs font-medium">${escHtml(sportLabel(c.sport))} · ages ${c.age_min}–${c.age_max} · ${escHtml(fmtDateRange(c.start_date, c.end_date))}</p>${verified}</div><a href="/camps/${escHtml(c.slug)}/" class="block"><h3 class="font-display text-ink text-xl mt-1 leading-tight group-hover:text-rust transition-colors font-medium">${escHtml(c.name)}</h3></a><p class="font-display text-ink-soft text-sm mt-1 leading-snug">${escHtml(c.city)}, ${escHtml(c.state)} · ${dayLabel} · ${spotsLabel}</p>${price}<a href="/camps/${escHtml(c.slug)}/" class="t-cta inline-block mt-3">View</a></div>`;
};
const pnwHtml = pnw.map(renderCardHtml).join('');
const nationalHtml = elsewhere.map(renderCardHtml).join('');

const renderFeaturedCardHtml = (c: Camp): string => {
  const photo = c.hero_photo_key
    ? `<div class="mb-3 border border-bone overflow-hidden bg-paper-warm" style="aspect-ratio: 16/9;"><img src="https://parentcoachdesk.com/camp-photos/${escHtml(c.hero_photo_key)}" alt="${escHtml(c.name)}" class="w-full h-full object-cover" loading="lazy" decoding="async" width="800" height="450" /></div>`
    : '';
  const verified = c.verified === 1
    ? `<span class="font-display text-rust text-xs font-medium" style="white-space: nowrap">Verified ✓</span>`
    : '';
  const dayLabel = c.day_or_overnight === 'day' ? 'Day camp' : 'Overnight';
  const spotsLabel = c.spots_status === 'open' ? 'Open' : c.spots_status === 'waitlist' ? 'Waitlist' : 'Full';
  const price = c.price_text
    ? `<p class="font-display italic text-rust text-xs mt-2 font-medium">${escHtml(c.price_text)}</p>`
    : '';
  const featuredBadge = `<span class="t-label text-rust border border-rust px-2 py-0.5 text-xs font-medium">Featured</span>`;
  return `<div class="camp-card bg-paper p-5 hover:bg-paper-warm transition-colors group" data-camp-id="${escHtml(c.id)}">${photo}<div class="flex items-start justify-between gap-2 mb-1">${featuredBadge}</div><div class="flex items-start justify-between gap-2 mb-1"><p class="font-display italic text-ink-soft text-xs font-medium">${escHtml(sportLabel(c.sport))} · ages ${c.age_min}–${c.age_max} · ${escHtml(fmtDateRange(c.start_date, c.end_date))}</p>${verified}</div><a href="/camps/${escHtml(c.slug)}/" class="block"><h3 class="font-display text-ink text-xl mt-1 leading-tight group-hover:text-rust transition-colors font-medium">${escHtml(c.name)}</h3></a><p class="font-display text-ink-soft text-sm mt-1 leading-snug">${escHtml(c.city)}, ${escHtml(c.state)} · ${dayLabel} · ${spotsLabel}</p>${price}<a href="/camps/${escHtml(c.slug)}/" class="t-cta inline-block mt-3">View</a></div>`;
};
const featuredCardsHtml = featuredCamps.map(renderFeaturedCardHtml).join('');

// Serialize camps for client-side JS — slim payload. Client filters only
// touch the fields below, so dropping the rest cuts the JSON payload from
// ~2 MB to ~400 KB on a 1300-camp directory. Description is truncated to
// 200 chars (still enough for substring search).
const campsLite = camps.map(c => ({
  id: c.id,
  name: c.name,
  slug: c.slug,
  sport: c.sport,
  age_min: c.age_min,
  age_max: c.age_max,
  start_date: c.start_date,
  end_date: c.end_date,
  city: c.city,
  state: c.state,
  day_or_overnight: c.day_or_overnight,
  spots_status: c.spots_status,
  program_type: c.program_type,
  latitude: c.latitude,
  longitude: c.longitude,
  description: (c.description || '').slice(0, 200),
}));
const campsJson = JSON.stringify(campsLite);
// CAMP_SPORTS already includes the camp-only options (multi-sport, outdoor, stem, general, etc).
const sportsListJson = JSON.stringify(CAMP_SPORTS);
---
<BaseLayout
  title="Camps & Leagues"
  description="Youth camps and league signups we know about. Starting in the Pacific Northwest where we can verify programs personally. National listings welcome."
  ogImage="/illustrations/og-camps.jpg"
>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Camps & Leagues</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] font-medium">
        A directory of <em class="text-rust">camps and leagues</em> your kid can actually sign up for.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Youth camps and league signups, with the dates, ages, prices, and contact info you actually need to plan. Submitted by parents and program directors. Reviewed before they go live. Full programs and leagues are hidden by default. Flip the toggles to see them.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/camps/submit/" class="btn">Submit a program</a>
        <a href="#all-camps" class="btn btn-ghost">Browse the directory</a>
      </div>
    </div>
  </section>

  <!-- Honest scope disclosure -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-8">
      <div class="grid md:grid-cols-12 gap-6 items-start">
        <div class="md:col-span-3">
          <p class="font-display italic text-rust font-medium">Where we are starting</p>
        </div>
        <div class="md:col-span-9 article-body">
          <p>We're starting in the Pacific Northwest where we can verify camps and leagues personally. National listings welcome but light coverage outside PNW for now. If you run a camp or league anywhere in the country and want it in the directory, <a href="/camps/submit/" class="text-rust hover:underline">submit it here</a>. We'll review and publish it. Just know of an organization but not the specifics? <a href="/camps/suggest/" class="text-rust hover:underline">Suggest it</a> and we'll look into it.</p>
          <p style="font-size: 0.875rem; color: var(--ink-soft);">Some programs don't have coordinates yet and won't appear on the map, but you'll find them in the directory below.</p>
        </div>
      </div>
    </div>
  </section>

  {featuredCamps.length > 0 && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-8">
        <p class="font-display italic text-rust mb-2 font-medium text-sm">Featured</p>
        <h2 class="font-display text-ink text-xl leading-tight font-medium mb-5">Featured camps</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-bone" set:html={featuredCardsHtml} />
      </div>
    </section>
  )}

  <section id="all-camps">
    <div class="container-px py-12">
      {!dbAvailable ? (
        <p class="font-display italic text-ink-soft font-medium">Directory is warming up. Try again in a moment.</p>
      ) : camps.length === 0 ? (
        <div>
          <img
            src="/illustrations/camps-empty-state.webp"
            alt="A summer camp at golden hour: a wooded lakeside, a wooden dock, two canoes."
            class="w-full max-w-3xl mb-8 rounded"
            loading="lazy"
          />
          <p class="font-display italic text-rust mb-3 font-medium">Coming online</p>
          <h2 class="font-display text-ink text-3xl leading-tight max-w-2xl font-medium">
            No camps in the directory yet.
          </h2>
          <p class="font-display text-ink-soft mt-4 max-w-2xl leading-snug">
            We launched the directory recently. The first batch of Pacific-Northwest camps is being verified. If you run a camp or send your kid to one, you can <a href="/camps/submit/" class="text-rust hover:underline">submit it</a> and we'll review it within a few days.
          </p>
        </div>
      ) : (
        <>
          {/* Map */}
          <div
            id="camps-map"
            class="mb-8 border border-bone"
            style="height: 400px; width: 100%; background: #EAEFE7;"
            aria-label="Map showing all camps in the directory"
          ></div>

          {/* Filter Bar */}
          <div class="mb-8 border border-bone bg-paper-warm p-6">
            <div class="flex flex-wrap items-end gap-4 mb-6">
              {/* Search by name */}
              <div>
                <label for="filter-search" class="font-display italic text-rust text-xs block mb-2 font-medium">Search</label>
                <input
                  type="search"
                  id="filter-search"
                  placeholder="Camp name, org, or keyword"
                  class="font-display px-3 py-2 border border-bone bg-paper w-64"
                />
              </div>

              {/* Sport Dropdown */}
              <div>
                <label for="filter-sport" class="font-display italic text-rust text-xs block mb-2 font-medium">Sport</label>
                <select id="filter-sport" class="font-display px-3 py-2 border border-bone bg-paper">
                  <option value="">All sports</option>
                </select>
              </div>

              {/* Age Range */}
              <div>
                <label for="filter-age-min" class="font-display italic text-rust text-xs block mb-2 font-medium">Age range</label>
                <div class="flex gap-2">
                  <input
                    type="number"
                    id="filter-age-min"
                    placeholder="Min"
                    min="0"
                    max="120"
                    class="font-display px-3 py-2 border border-bone bg-paper w-16"
                  />
                  <span class="text-ink-soft px-1">to</span>
                  <input
                    type="number"
                    id="filter-age-max"
                    placeholder="Max"
                    min="0"
                    max="120"
                    class="font-display px-3 py-2 border border-bone bg-paper w-16"
                  />
                </div>
              </div>

              {/* Date Range */}
              <div>
                <p class="font-display italic text-rust text-xs mb-2 font-medium">Date range</p>
                <div class="flex gap-2 items-center">
                  <input
                    type="date"
                    id="filter-date-start"
                    aria-label="Earliest start date"
                    class="font-display px-3 py-2 border border-bone bg-paper"
                  />
                  <span class="text-ink-soft px-1">to</span>
                  <input
                    type="date"
                    id="filter-date-end"
                    aria-label="Latest end date"
                    class="font-display px-3 py-2 border border-bone bg-paper"
                  />
                </div>
              </div>

              {/* Day/Overnight */}
              <div>
                <p class="font-display italic text-rust text-xs mb-2 font-medium">Format</p>
                <div class="flex gap-2">
                  <button type="button" data-filter-dayovernght="all" class="filter-toggle font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors" data-active="true" style="background: var(--rust); color: white; border-color: var(--rust);">All</button>
                  <button type="button" data-filter-dayovernght="day" class="filter-toggle font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Day</button>
                  <button type="button" data-filter-dayovernght="overnight" class="filter-toggle font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Overnight</button>
                </div>
              </div>

              {/* Include hidden-by-default rows */}
              <div>
                <p class="font-display italic text-rust text-xs mb-2 font-medium">Include</p>
                <div class="flex gap-2">
                  <button type="button" id="filter-show-leagues" class="filter-toggle font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Leagues</button>
                  <button type="button" id="filter-show-full" class="filter-toggle font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Full programs</button>
                </div>
              </div>

              {/* State Dropdown */}
              <div>
                <label for="filter-state" class="font-display italic text-rust text-xs block mb-2 font-medium">State</label>
                <select id="filter-state" class="font-display px-3 py-2 border border-bone bg-paper">
                  <option value="">All states</option>
                </select>
              </div>

              {/* Zip + Radius */}
              <form id="filter-zip-form" class="flex gap-2 items-end">
                <div>
                  <label for="filter-zip" class="font-display italic text-rust text-xs block mb-2 font-medium">Zip code</label>
                  <input
                    type="text"
                    id="filter-zip"
                    placeholder="e.g. 98101"
                    maxlength="10"
                    class="font-display px-3 py-2 border border-bone bg-paper w-32"
                  />
                </div>
                <div>
                  <label for="filter-radius" class="font-display italic text-rust text-xs block mb-2 font-medium">Radius</label>
                  <select id="filter-radius" class="font-display px-3 py-2 border border-bone bg-paper">
                    <option value="10">10 miles</option>
                    <option value="25">25 miles</option>
                    <option value="50">50 miles</option>
                    <option value="100">100 miles</option>
                    <option value="all">Any distance</option>
                  </select>
                </div>
                <button type="submit" class="font-display px-4 py-2 border border-rust bg-rust text-white hover:opacity-90 transition-opacity">Search</button>
              </form>
            </div>

            {/* Clear Filters */}
            <button id="clear-filters" class="font-display italic text-rust text-sm hover:underline font-medium">Clear all filters</button>
          </div>

          {/* Camps Grid — cards are pre-rendered as an HTML string in the
               frontmatter (much faster than per-element JSX over 1000+ rows)
               and injected via set:html. */}
          <div id="camps-directory">
            {pnw.length > 0 && (
              <div class="mb-12">
                <p class="font-display italic text-rust mb-3 font-medium">Pacific Northwest</p>
                <div id="pnw-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-bone" set:html={pnwHtml}></div>
              </div>
            )}

            {elsewhere.length > 0 && (
              <div>
                <p class="font-display italic text-rust mb-3 font-medium">National</p>
                <div id="national-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-bone" set:html={nationalHtml}></div>
              </div>
            )}
          </div>
        </>
      )}
    </div>
  </section>

  <NewsletterSignup
    headline="New camps as we verify them"
    blurb="Subscribe and we'll send a Friday note when new camps land in the directory."
  />


  {/* JSON data island — non-executable, exempt from script-src CSP. The
      bundled script below reads it via getElementById so we can remove
      is:inline + define:vars and eliminate that unsafe-inline vector. */}
  <script type="application/json" id="camps-data" set:html={JSON.stringify({ camps: campsLite, sports: CAMP_SPORTS })} />

  <script>
    import L from 'leaflet';
    import 'leaflet/dist/leaflet.css';
    (function () {
      const dataEl = document.getElementById('camps-data');
      const _data = dataEl ? JSON.parse(dataEl.textContent || '{}') : {};
      const camps = _data.camps || [];
      const sportsList = _data.sports || [];

      // Helper: get sport label
      function sportLabel(slug) {
        const match = sportsList.find(s => s.slug === slug);
        return match ? match.label : slug.split(/[\s-]+/).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      }

      // Helper: haversine distance in miles
      function haversineMiles(lat1, lon1, lat2, lon2) {
        const toRad = d => d * Math.PI / 180;
        const R = 3958.8;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2)**2;
        return 2 * R * Math.asin(Math.sqrt(a));
      }

      // Helper: geocode zip via Nominatim. Uses structured query so the
      // country filter actually applies — `country=US` is silently ignored
      // when paired with free-text `q=`, which was causing "98101" to
      // resolve to a French postcode about 50% of the time. Falls back to
      // "ZIP, USA" free-text if structured returns nothing.
      async function geocodeZip(zip) {
        const tries = [
          `https://nominatim.openstreetmap.org/search?postalcode=${encodeURIComponent(zip)}&countrycodes=us&format=json&limit=1`,
          `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(zip + ', USA')}&format=json&limit=1`,
        ];
        for (const url of tries) {
          try {
            const r = await fetch(url, { headers: { 'Accept-Language': 'en' } });
            if (!r.ok) continue;
            const data = await r.json();
            if (!data.length) continue;
            const lat = parseFloat(data[0].lat);
            const lon = parseFloat(data[0].lon);
            if (!Number.isFinite(lat) || !Number.isFinite(lon)) continue;
            return { lat, lon };
          } catch {
            // try the next URL
          }
        }
        return null;
      }

      // Filter state. showLeagues and showFull default to false so the page
      // opens with only camps that parents can actually sign up for right now.
      let state = {
        search: '',
        sport: '',
        ageMin: null,
        ageMax: null,
        dateStart: '',  // ISO YYYY-MM-DD; empty means no lower bound
        dateEnd: '',    // ISO YYYY-MM-DD; empty means no upper bound
        dayOvernight: 'all',
        state: '',
        zipLat: null,
        zipLon: null,
        zipRadius: 10,
        showLeagues: false,
        showFull: false,
      };

      let map = null;
      let markers = [];
      let visibleCamps = [];

      // Initialize map
      function initMap() {
        const mapEl = document.getElementById('camps-map');
        if (!mapEl || typeof L === 'undefined') return setTimeout(initMap, 100);

        const campsWithGeo = camps.filter(c => typeof c.latitude === 'number' && typeof c.longitude === 'number');

        // Default to a continental US frame so first paint shows the whole footprint,
        // not the math-centroid of all camps (which lands in Nebraska when most camps
        // are on the coasts).
        map = L.map(mapEl, { scrollWheelZoom: false, attributionControl: true })
          .setView([39.5, -98.5], 4);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap',
        }).addTo(map);

        // Then fit to actual camp bounds. fitBounds beats centroid+zoom because it
        // frames every pin regardless of how skewed the distribution is.
        if (campsWithGeo.length > 0) {
          const bounds = L.latLngBounds(campsWithGeo.map(c => [c.latitude, c.longitude]));
          map.fitBounds(bounds, { padding: [40, 40], maxZoom: 10 });
        }
      }

      // Render map markers
      function renderMap() {
        if (!map) return;

        // Clear old markers
        markers.forEach(m => map.removeLayer(m));
        markers = [];

        // Track positions we've already pinned. Camps at the exact same coords get nudged
        // a tiny amount so all pins stay clickable instead of stacking under one another.
        const positionCounts = {};
        const jitterFor = (lat, lon) => {
          const key = `${lat.toFixed(6)},${lon.toFixed(6)}`;
          const idx = positionCounts[key] || 0;
          positionCounts[key] = idx + 1;
          if (idx === 0) return [lat, lon];
          // ~0.0002 deg = ~70 ft. Spread overlapping pins in a small ring.
          const angle = (idx - 1) * (Math.PI * 2 / 6);
          const r = 0.00018;
          return [lat + r * Math.sin(angle), lon + r * Math.cos(angle)];
        };

        // Add markers for visible camps
        const pinnedCoords = [];
        visibleCamps.forEach(c => {
          if (typeof c.latitude === 'number' && typeof c.longitude === 'number') {
            const [latJ, lonJ] = jitterFor(c.latitude, c.longitude);
            const marker = L.marker([latJ, lonJ]).addTo(map);
            const popup = `<div style="font-size: 14px;">
              <strong>${c.name}</strong><br/>
              ${c.city}, ${c.state}<br/>
              ${sportLabel(c.sport)}<br/>
              <a href="/camps/${c.slug}/" style="color: var(--rust); text-decoration: none;">View camp ↗</a>
            </div>`;
            marker.bindPopup(popup);
            markers.push(marker);
            pinnedCoords.push([c.latitude, c.longitude]);
          }
        });

        // Re-fit bounds to whatever's currently visible. If a ZIP filter is
        // active, the user's center matters more than every pin, so leave the
        // existing zoom alone. Otherwise frame the visible set.
        if (pinnedCoords.length > 0 && state.zipLat == null) {
          const bounds = L.latLngBounds(pinnedCoords);
          map.fitBounds(bounds, { padding: [40, 40], maxZoom: 12 });
        }
      }

      // Apply all filters
      function applyFilters() {
        visibleCamps = camps.filter(c => {
          // Hide leagues unless toggled on. program_type may be undefined on
          // older rows imported before the schema was extended; treat those as 'camp'.
          const isLeague = c.program_type === 'league';
          if (isLeague && !state.showLeagues) return false;

          // Hide full programs unless toggled on.
          if (c.spots_status === 'full' && !state.showFull) return false;

          // Free-text search across name, city, and description. Case-insensitive
          // substring match. Empty string matches everything.
          if (state.search) {
            const q = state.search.toLowerCase();
            const haystack = `${c.name} ${c.city} ${c.description}`.toLowerCase();
            if (!haystack.includes(q)) return false;
          }

          // Sport
          if (state.sport && c.sport !== state.sport) return false;

          // Age range
          if (state.ageMin !== null && c.age_max < state.ageMin) return false;
          if (state.ageMax !== null && c.age_min > state.ageMax) return false;

          // Date range — overlap test. Camp matches if any of its days fall
          // inside the requested window: camp.start <= filter.end AND
          // camp.end >= filter.start. Empty bound = no constraint on that side.
          if (state.dateStart && c.end_date < state.dateStart) return false;
          if (state.dateEnd && c.start_date > state.dateEnd) return false;

          // Day/overnight
          if (state.dayOvernight !== 'all' && c.day_or_overnight !== state.dayOvernight) return false;

          // State
          if (state.state && c.state !== state.state) return false;

          // Zip radius. Infinity means user picked "Any distance" — zip filter
          // is effectively off, all camps pass regardless of coordinates.
          if (state.zipLat !== null && state.zipLon !== null && Number.isFinite(state.zipRadius)) {
            if (typeof c.latitude !== 'number' || typeof c.longitude !== 'number') return false;
            const dist = haversineMiles(state.zipLat, state.zipLon, c.latitude, c.longitude);
            if (dist > state.zipRadius) return false;
          }

          return true;
        });

        // Hide/show camp cards
        document.querySelectorAll('.camp-card').forEach(card => {
          const campId = card.getAttribute('data-camp-id');
          const isVisible = visibleCamps.some(c => c.id === campId);
          card.style.display = isVisible ? '' : 'none';
        });

        renderMap();
      }

      // Populate dropdowns
      function populateFilters() {
        // Sport options
        const sportSelect = document.getElementById('filter-sport');
        const uniqueSports = [...new Set(camps.map(c => c.sport))].sort();
        uniqueSports.forEach(sport => {
          const opt = document.createElement('option');
          opt.value = sport;
          opt.textContent = sportLabel(sport);
          sportSelect.appendChild(opt);
        });

        // State options
        const stateSelect = document.getElementById('filter-state');
        const uniqueStates = [...new Set(camps.map(c => c.state))].sort();
        uniqueStates.forEach(st => {
          const opt = document.createElement('option');
          opt.value = st;
          opt.textContent = st;
          stateSelect.appendChild(opt);
        });
      }

      // Event listeners
      function attachListeners() {
        // Free-text search
        document.getElementById('filter-search').addEventListener('input', (e) => {
          state.search = e.target.value.trim();
          applyFilters();
        });

        // Sport
        document.getElementById('filter-sport').addEventListener('change', (e) => {
          state.sport = e.target.value;
          applyFilters();
        });

        // Age min
        document.getElementById('filter-age-min').addEventListener('input', (e) => {
          state.ageMin = e.target.value ? parseInt(e.target.value, 10) : null;
          applyFilters();
        });

        // Age max
        document.getElementById('filter-age-max').addEventListener('input', (e) => {
          state.ageMax = e.target.value ? parseInt(e.target.value, 10) : null;
          applyFilters();
        });

        // Date start
        document.getElementById('filter-date-start').addEventListener('change', (e) => {
          state.dateStart = e.target.value || '';
          applyFilters();
        });

        // Date end
        document.getElementById('filter-date-end').addEventListener('change', (e) => {
          state.dateEnd = e.target.value || '';
          applyFilters();
        });

        // Visual helpers: filter toggle buttons need to *look* active when
        // pressed. Swap an inline style so the user gets feedback without
        // needing a CSS file change.
        const ACTIVE_STYLE = 'background: var(--rust); color: white; border-color: var(--rust);';
        function setToggleActive(btn, active) {
          if (active) {
            btn.setAttribute('data-active', 'true');
            btn.style.cssText = ACTIVE_STYLE;
          } else {
            btn.removeAttribute('data-active');
            btn.style.cssText = '';
          }
        }

        // Day/overnight — single-select group
        document.querySelectorAll('[data-filter-dayovernght]').forEach(btn => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('[data-filter-dayovernght]').forEach(b => setToggleActive(b, false));
            setToggleActive(btn, true);
            state.dayOvernight = btn.getAttribute('data-filter-dayovernght');
            applyFilters();
          });
        });

        // State
        document.getElementById('filter-state').addEventListener('change', (e) => {
          state.state = e.target.value;
          applyFilters();
        });

        // Zip form. The submit button does the geocode; clearing the input
        // releases the filter automatically; changing the radius after a
        // successful search re-filters without requiring another click.
        document.getElementById('filter-zip-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const zip = document.getElementById('filter-zip').value.trim();
          if (!zip) {
            state.zipLat = null;
            state.zipLon = null;
            applyFilters();
            return;
          }

          const submitBtn = e.target.querySelector('button[type="submit"]');
          const originalLabel = submitBtn ? submitBtn.textContent : null;
          if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Searching...'; }

          const geo = await geocodeZip(zip);

          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = originalLabel; }

          if (!geo) {
            alert('Zip code not found. Make sure it is a 5-digit US zip and try again.');
            return;
          }

          state.zipLat = geo.lat;
          state.zipLon = geo.lon;
          const radiusVal = document.getElementById('filter-radius').value;
          state.zipRadius = radiusVal === 'all' ? Infinity : parseInt(radiusVal, 10);
          applyFilters();
        });

        // Clearing the zip input releases the radius filter immediately.
        document.getElementById('filter-zip').addEventListener('input', (e) => {
          if (!e.target.value.trim() && state.zipLat !== null) {
            state.zipLat = null;
            state.zipLon = null;
            applyFilters();
          }
        });

        // Changing the radius after a successful zip search re-filters in place.
        document.getElementById('filter-radius').addEventListener('change', (e) => {
          if (state.zipLat === null) return; // no active zip filter, nothing to do
          state.zipRadius = e.target.value === 'all' ? Infinity : parseInt(e.target.value, 10);
          applyFilters();
        });

        // Show leagues toggle (independent on/off)
        document.getElementById('filter-show-leagues').addEventListener('click', (e) => {
          state.showLeagues = !state.showLeagues;
          setToggleActive(e.currentTarget, state.showLeagues);
          applyFilters();
        });

        // Show full toggle (independent on/off)
        document.getElementById('filter-show-full').addEventListener('click', (e) => {
          state.showFull = !state.showFull;
          setToggleActive(e.currentTarget, state.showFull);
          applyFilters();
        });

        // Clear filters — resets to default which hides leagues + full programs.
        document.getElementById('clear-filters').addEventListener('click', () => {
          state = { search: '', sport: '', ageMin: null, ageMax: null, dateStart: '', dateEnd: '', dayOvernight: 'all', state: '', zipLat: null, zipLon: null, zipRadius: 10, showLeagues: false, showFull: false };
          document.getElementById('filter-search').value = '';
          document.getElementById('filter-sport').value = '';
          document.getElementById('filter-age-min').value = '';
          document.getElementById('filter-age-max').value = '';
          document.getElementById('filter-date-start').value = '';
          document.getElementById('filter-date-end').value = '';
          document.getElementById('filter-state').value = '';
          document.getElementById('filter-zip').value = '';
          document.getElementById('filter-radius').value = '10';
          document.querySelectorAll('[data-filter-dayovernght]').forEach(b => setToggleActive(b, false));
          const allBtn = document.querySelector('[data-filter-dayovernght="all"]');
          if (allBtn) setToggleActive(allBtn, true);
          setToggleActive(document.getElementById('filter-show-leagues'), false);
          setToggleActive(document.getElementById('filter-show-full'), false);
          applyFilters();
        });
      }

      // Initial setup
      populateFilters();
      attachListeners();
      initMap();
      renderMap();
      applyFilters();
    })();
  </script>

<script is:inline>
(function () {
  try {
    if (!navigator.geolocation) return;
    if (sessionStorage.getItem('pcp:camps:geo-tried') === '1') return;
    sessionStorage.setItem('pcp:camps:geo-tried', '1');

    // Don't redirect if the URL already has a query (filter applied).
    if (location.search) return;

    navigator.geolocation.getCurrentPosition(
      function (pos) {
        var lat = pos.coords.latitude;
        var lon = pos.coords.longitude;
        // Hit a server endpoint that resolves lat/lng to nearest covered city.
        fetch('/api/camps/nearest?lat=' + lat + '&lon=' + lon)
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (j) {
            if (j && j.state && j.city_slug) {
              location.replace('/camps/' + j.state.toLowerCase() + '/' + j.city_slug + '/');
            }
          })
          .catch(function () { /* stay put */ });
      },
      function () { /* permission denied - stay put */ },
      { timeout: 4000, maximumAge: 600000 }
    );
  } catch (e) { /* swallow */ }
})();
</script>
</BaseLayout>

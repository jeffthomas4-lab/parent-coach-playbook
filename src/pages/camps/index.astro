---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { listApprovedCamps, type Camp } from '../../lib/camps-db';
import { CAMP_SPORTS } from '../../data/site';

const sportLabel = (slug: string): string => {
  const match = CAMP_SPORTS.find((s) => s.slug === slug);
  if (match) return match.label;
  return slug
    .split(/[\s-]+/)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

// SSR. Pulls live from D1 each request.
export const prerender = false;

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
let camps: Camp[] = [];
let dbAvailable = !!env?.DB;
if (env?.DB) {
  try {
    camps = await listApprovedCamps(env.DB);
  } catch (e) {
    console.error('listApprovedCamps failed', e);
  }
}

const fmtDateRange = (start: string, end: string) => {
  const s = new Date(start);
  const e = new Date(end);
  const month = (d: Date) => d.toLocaleDateString('en-US', { month: 'short' });
  const day = (d: Date) => d.getDate();
  if (s.getMonth() === e.getMonth() && s.getFullYear() === e.getFullYear()) {
    return `${month(s)} ${day(s)}–${day(e)}, ${s.getFullYear()}`;
  }
  return `${month(s)} ${day(s)} – ${month(e)} ${day(e)}, ${s.getFullYear()}`;
};

const PNW = new Set(['WA', 'OR', 'ID', 'MT', 'AK']);
const pnw = camps.filter(c => PNW.has(c.state));
const elsewhere = camps.filter(c => !PNW.has(c.state));

// Serialize camps for client-side JS
const campsJson = JSON.stringify(camps);
// CAMP_SPORTS already includes the camp-only options (multi-sport, outdoor, stem, general, etc).
const sportsListJson = JSON.stringify(CAMP_SPORTS);
---
<BaseLayout
  title="Camps"
  description="Youth sports camps and activity programs we know about. Starting in the Pacific Northwest where we can verify camps personally. National listings welcome."
  ogImage="/illustrations/og-camps.png"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  </Fragment>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Camps</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0]" style="font-weight: 500;">
        A directory of <em class="text-rust">camps</em> for the summer that's coming.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Youth sports camps and activity programs, with the dates, ages, prices, and contact info you actually need to plan. Submitted by parents and program directors. Reviewed before they go live.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/camps/submit/" class="btn">Submit a camp</a>
        <a href="#all-camps" class="btn btn-ghost">Browse the directory</a>
      </div>
    </div>
  </section>

  <!-- Honest scope disclosure -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-8">
      <div class="grid md:grid-cols-12 gap-6 items-start">
        <div class="md:col-span-3">
          <p class="font-display italic text-rust" style="font-weight: 500;">Where we are starting</p>
        </div>
        <div class="md:col-span-9 article-body">
          <p>We're starting in the Pacific Northwest where we can verify camps personally. National listings welcome but light coverage outside PNW for now. If you run a camp anywhere in the country and want it in the directory, <a href="/camps/submit/" class="text-rust hover:underline">submit it here</a>. We'll review and publish it.</p>
          <p style="font-size: 0.875rem; color: var(--ink-soft);">Some camps don't have coordinates yet and won't appear on the map, but you'll find them in the directory below.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="all-camps">
    <div class="container-px py-12">
      {!dbAvailable ? (
        <p class="font-display italic text-ink-soft" style="font-weight: 500;">Directory is warming up. Try again in a moment.</p>
      ) : camps.length === 0 ? (
        <div>
          <img
            src="/illustrations/camps-empty-state.png"
            alt="A summer camp at golden hour: a wooded lakeside, a wooden dock, two canoes."
            class="w-full max-w-3xl mb-8 rounded"
            loading="lazy"
          />
          <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Coming online</p>
          <h2 class="font-display text-ink text-3xl leading-tight max-w-2xl" style="font-weight: 500;">
            No camps in the directory yet.
          </h2>
          <p class="font-display text-ink-soft mt-4 max-w-2xl leading-snug">
            We launched the directory recently. The first batch of Pacific-Northwest camps is being verified. If you run a camp or send your kid to one, you can <a href="/camps/submit/" class="text-rust hover:underline">submit it</a> and we'll review it within a few days.
          </p>
        </div>
      ) : (
        <>
          {/* Map */}
          <div
            id="camps-map"
            class="mb-8 border border-bone"
            style="height: 400px; width: 100%; background: #EAEFE7;"
            aria-label="Map showing all camps in the directory"
          ></div>

          {/* Filter Bar */}
          <div class="mb-8 border border-bone bg-paper-warm p-6">
            <div class="flex flex-wrap items-end gap-4 mb-6">
              {/* Sport Dropdown */}
              <div>
                <label for="filter-sport" class="font-display italic text-rust text-xs block mb-2" style="font-weight: 500;">Sport</label>
                <select id="filter-sport" class="font-display px-3 py-2 border border-bone bg-paper">
                  <option value="">All sports</option>
                </select>
              </div>

              {/* Age Range */}
              <div>
                <label for="filter-age-min" class="font-display italic text-rust text-xs block mb-2" style="font-weight: 500;">Age range</label>
                <div class="flex gap-2">
                  <input
                    type="number"
                    id="filter-age-min"
                    placeholder="Min"
                    min="0"
                    max="120"
                    class="font-display px-3 py-2 border border-bone bg-paper w-16"
                  />
                  <span class="text-ink-soft px-1">to</span>
                  <input
                    type="number"
                    id="filter-age-max"
                    placeholder="Max"
                    min="0"
                    max="120"
                    class="font-display px-3 py-2 border border-bone bg-paper w-16"
                  />
                </div>
              </div>

              {/* Day/Overnight */}
              <div>
                <p class="font-display italic text-rust text-xs mb-2" style="font-weight: 500;">Format</p>
                <div class="flex gap-2">
                  <button data-filter-dayovernght="all" class="font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors" data-active="true">All</button>
                  <button data-filter-dayovernght="day" class="font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Day</button>
                  <button data-filter-dayovernght="overnight" class="font-display px-3 py-2 border border-bone bg-paper hover:bg-paper-warm transition-colors">Overnight</button>
                </div>
              </div>

              {/* State Dropdown */}
              <div>
                <label for="filter-state" class="font-display italic text-rust text-xs block mb-2" style="font-weight: 500;">State</label>
                <select id="filter-state" class="font-display px-3 py-2 border border-bone bg-paper">
                  <option value="">All states</option>
                </select>
              </div>

              {/* Zip + Radius */}
              <form id="filter-zip-form" class="flex gap-2 items-end">
                <div>
                  <label for="filter-zip" class="font-display italic text-rust text-xs block mb-2" style="font-weight: 500;">Zip code</label>
                  <input
                    type="text"
                    id="filter-zip"
                    placeholder="e.g. 98101"
                    maxlength="10"
                    class="font-display px-3 py-2 border border-bone bg-paper w-32"
                  />
                </div>
                <div>
                  <label for="filter-radius" class="font-display italic text-rust text-xs block mb-2" style="font-weight: 500;">Radius</label>
                  <select id="filter-radius" class="font-display px-3 py-2 border border-bone bg-paper">
                    <option value="10">10 miles</option>
                    <option value="25">25 miles</option>
                    <option value="50">50 miles</option>
                    <option value="100">100 miles</option>
                  </select>
                </div>
                <button type="submit" class="font-display px-4 py-2 border border-rust bg-rust text-white hover:opacity-90 transition-opacity">Search</button>
              </form>
            </div>

            {/* Clear Filters */}
            <button id="clear-filters" class="font-display italic text-rust text-sm hover:underline" style="font-weight: 500;">Clear all filters</button>
          </div>

          {/* Camps Grid */}
          <div id="camps-directory">
            {pnw.length > 0 && (
              <div class="mb-12">
                <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Pacific Northwest</p>
                <div id="pnw-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-bone">
                  {pnw.map((c) => (
                    <div class="camp-card bg-paper p-5 hover:bg-paper-warm transition-colors group" data-camp-id={c.id}>
                      {c.hero_photo_key && (
                        <div class="mb-3 border border-bone overflow-hidden bg-paper-warm" style="aspect-ratio: 16/9;">
                          <img src={`https://parentcoachplaybook.com/camp-photos/${c.hero_photo_key}`} alt={c.name} class="w-full h-full object-cover" />
                        </div>
                      )}
                      <div class="flex items-start justify-between gap-2 mb-1">
                        <p class="font-display italic text-ink-soft text-xs" style="font-weight: 500;">
                          {sportLabel(c.sport)} · ages {c.age_min}–{c.age_max} · {fmtDateRange(c.start_date, c.end_date)}
                        </p>
                        {c.verified === 1 && (
                          <span class="font-display text-rust text-xs" style="font-weight: 500; white-space: nowrap;">Verified ✓</span>
                        )}
                      </div>
                      <a href={`/camps/${c.slug}/`} class="block">
                        <h3 class="font-display text-ink text-xl mt-1 leading-tight group-hover:text-rust transition-colors" style="font-weight: 500;">
                          {c.name}
                        </h3>
                      </a>
                      <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                        {c.city}, {c.state} · {c.day_or_overnight === 'day' ? 'Day camp' : 'Overnight'} · {c.spots_status === 'open' ? 'Open' : c.spots_status === 'waitlist' ? 'Waitlist' : 'Full'}
                      </p>
                      {c.price_text && (
                        <p class="font-display italic text-rust text-xs mt-2" style="font-weight: 500;">{c.price_text}</p>
                      )}
                      <a href={`/camps/${c.slug}/`} class="t-cta inline-block mt-3">View</a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {elsewhere.length > 0 && (
              <div>
                <p class="font-display italic text-rust mb-3" style="font-weight: 500;">National</p>
                <div id="national-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-bone">
                  {elsewhere.map((c) => (
                    <div class="camp-card bg-paper p-5 hover:bg-paper-warm transition-colors group" data-camp-id={c.id}>
                      {c.hero_photo_key && (
                        <div class="mb-3 border border-bone overflow-hidden bg-paper-warm" style="aspect-ratio: 16/9;">
                          <img src={`https://parentcoachplaybook.com/camp-photos/${c.hero_photo_key}`} alt={c.name} class="w-full h-full object-cover" />
                        </div>
                      )}
                      <div class="flex items-start justify-between gap-2 mb-1">
                        <p class="font-display italic text-ink-soft text-xs" style="font-weight: 500;">
                          {sportLabel(c.sport)} · ages {c.age_min}–{c.age_max} · {fmtDateRange(c.start_date, c.end_date)}
                        </p>
                        {c.verified === 1 && (
                          <span class="font-display text-rust text-xs" style="font-weight: 500; white-space: nowrap;">Verified ✓</span>
                        )}
                      </div>
                      <a href={`/camps/${c.slug}/`} class="block">
                        <h3 class="font-display text-ink text-xl mt-1 leading-tight group-hover:text-rust transition-colors" style="font-weight: 500;">
                          {c.name}
                        </h3>
                      </a>
                      <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                        {c.city}, {c.state} · {c.day_or_overnight === 'day' ? 'Day camp' : 'Overnight'} · {c.spots_status === 'open' ? 'Open' : c.spots_status === 'waitlist' ? 'Waitlist' : 'Full'}
                      </p>
                      {c.price_text && (
                        <p class="font-display italic text-rust text-xs mt-2" style="font-weight: 500;">{c.price_text}</p>
                      )}
                      <a href={`/camps/${c.slug}/`} class="t-cta inline-block mt-3">View</a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </>
      )}
    </div>
  </section>

  <NewsletterSignup
    headline="New camps as we verify them"
    blurb="Subscribe and we'll send a Friday note when new camps land in the directory."
  />

  <Fragment slot="head">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" defer></script>
  </Fragment>

  <script is:inline define:vars={{ campsJson, sportsListJson }}>
    (function () {
      const camps = JSON.parse(campsJson);
      const sportsList = JSON.parse(sportsListJson);

      // Helper: get sport label
      function sportLabel(slug) {
        const match = sportsList.find(s => s.slug === slug);
        return match ? match.label : slug.split(/[\s-]+/).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      }

      // Helper: haversine distance in miles
      function haversineMiles(lat1, lon1, lat2, lon2) {
        const toRad = d => d * Math.PI / 180;
        const R = 3958.8;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2)**2;
        return 2 * R * Math.asin(Math.sqrt(a));
      }

      // Helper: geocode zip via Nominatim
      async function geocodeZip(zip) {
        const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(zip)}&country=US&format=json&limit=1`;
        try {
          const r = await fetch(url, { headers: { 'Accept-Language': 'en' } });
          if (!r.ok) return null;
          const data = await r.json();
          if (!data.length) return null;
          return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
        } catch {
          return null;
        }
      }

      // Filter state
      let state = {
        sport: '',
        ageMin: null,
        ageMax: null,
        dayOvernight: 'all',
        state: '',
        zipLat: null,
        zipLon: null,
        zipRadius: 10,
      };

      let map = null;
      let markers = [];
      let visibleCamps = [];

      // Initialize map
      function initMap() {
        const mapEl = document.getElementById('camps-map');
        if (!mapEl || typeof L === 'undefined') return setTimeout(initMap, 100);

        // Calculate centroid of camps with coordinates
        const campsWithGeo = camps.filter(c => typeof c.latitude === 'number' && typeof c.longitude === 'number');
        let centerLat = 47.6;
        let centerLon = -122.3;
        let zoom = 8;

        if (campsWithGeo.length > 0) {
          const sumLat = campsWithGeo.reduce((sum, c) => sum + c.latitude, 0);
          const sumLon = campsWithGeo.reduce((sum, c) => sum + c.longitude, 0);
          centerLat = sumLat / campsWithGeo.length;
          centerLon = sumLon / campsWithGeo.length;
          zoom = 9;
        }

        map = L.map(mapEl, { scrollWheelZoom: false, attributionControl: true }).setView([centerLat, centerLon], zoom);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap',
        }).addTo(map);
      }

      // Render map markers
      function renderMap() {
        if (!map) return;

        // Clear old markers
        markers.forEach(m => map.removeLayer(m));
        markers = [];

        // Track positions we've already pinned. Camps at the exact same coords get nudged
        // a tiny amount so all pins stay clickable instead of stacking under one another.
        const positionCounts = {};
        const jitterFor = (lat, lon) => {
          const key = `${lat.toFixed(6)},${lon.toFixed(6)}`;
          const idx = positionCounts[key] || 0;
          positionCounts[key] = idx + 1;
          if (idx === 0) return [lat, lon];
          // ~0.0002 deg = ~70 ft. Spread overlapping pins in a small ring.
          const angle = (idx - 1) * (Math.PI * 2 / 6);
          const r = 0.00018;
          return [lat + r * Math.sin(angle), lon + r * Math.cos(angle)];
        };

        // Add markers for visible camps
        visibleCamps.forEach(c => {
          if (typeof c.latitude === 'number' && typeof c.longitude === 'number') {
            const [latJ, lonJ] = jitterFor(c.latitude, c.longitude);
            const marker = L.marker([latJ, lonJ]).addTo(map);
            const popup = `<div style="font-size: 14px;">
              <strong>${c.name}</strong><br/>
              ${c.city}, ${c.state}<br/>
              ${sportLabel(c.sport)}<br/>
              <a href="/camps/${c.slug}/" style="color: var(--rust); text-decoration: none;">View camp ↗</a>
            </div>`;
            marker.bindPopup(popup);
            markers.push(marker);
          }
        });
      }

      // Apply all filters
      function applyFilters() {
        visibleCamps = camps.filter(c => {
          // Sport
          if (state.sport && c.sport !== state.sport) return false;

          // Age range
          if (state.ageMin !== null && c.age_max < state.ageMin) return false;
          if (state.ageMax !== null && c.age_min > state.ageMax) return false;

          // Day/overnight
          if (state.dayOvernight !== 'all' && c.day_or_overnight !== state.dayOvernight) return false;

          // State
          if (state.state && c.state !== state.state) return false;

          // Zip radius
          if (state.zipLat !== null && state.zipLon !== null) {
            if (typeof c.latitude !== 'number' || typeof c.longitude !== 'number') return false;
            const dist = haversineMiles(state.zipLat, state.zipLon, c.latitude, c.longitude);
            if (dist > state.zipRadius) return false;
          }

          return true;
        });

        // Hide/show camp cards
        document.querySelectorAll('.camp-card').forEach(card => {
          const campId = card.getAttribute('data-camp-id');
          const isVisible = visibleCamps.some(c => c.id === campId);
          card.style.display = isVisible ? '' : 'none';
        });

        renderMap();
      }

      // Populate dropdowns
      function populateFilters() {
        // Sport options
        const sportSelect = document.getElementById('filter-sport');
        const uniqueSports = [...new Set(camps.map(c => c.sport))].sort();
        uniqueSports.forEach(sport => {
          const opt = document.createElement('option');
          opt.value = sport;
          opt.textContent = sportLabel(sport);
          sportSelect.appendChild(opt);
        });

        // State options
        const stateSelect = document.getElementById('filter-state');
        const uniqueStates = [...new Set(camps.map(c => c.state))].sort();
        uniqueStates.forEach(st => {
          const opt = document.createElement('option');
          opt.value = st;
          opt.textContent = st;
          stateSelect.appendChild(opt);
        });
      }

      // Event listeners
      function attachListeners() {
        // Sport
        document.getElementById('filter-sport').addEventListener('change', (e) => {
          state.sport = e.target.value;
          applyFilters();
        });

        // Age min
        document.getElementById('filter-age-min').addEventListener('input', (e) => {
          state.ageMin = e.target.value ? parseInt(e.target.value, 10) : null;
          applyFilters();
        });

        // Age max
        document.getElementById('filter-age-max').addEventListener('input', (e) => {
          state.ageMax = e.target.value ? parseInt(e.target.value, 10) : null;
          applyFilters();
        });

        // Day/overnight
        document.querySelectorAll('[data-filter-dayovernght]').forEach(btn => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('[data-filter-dayovernght]').forEach(b => b.removeAttribute('data-active'));
            btn.setAttribute('data-active', 'true');
            state.dayOvernight = btn.getAttribute('data-filter-dayovernght');
            applyFilters();
          });
        });

        // State
        document.getElementById('filter-state').addEventListener('change', (e) => {
          state.state = e.target.value;
          applyFilters();
        });

        // Zip form
        document.getElementById('filter-zip-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const zip = document.getElementById('filter-zip').value.trim();
          if (!zip) {
            state.zipLat = null;
            state.zipLon = null;
            applyFilters();
            return;
          }

          const geo = await geocodeZip(zip);
          if (!geo) {
            alert('Zip code not found. Try again.');
            return;
          }

          state.zipLat = geo.lat;
          state.zipLon = geo.lon;
          state.zipRadius = parseInt(document.getElementById('filter-radius').value, 10);
          applyFilters();
        });

        // Clear filters
        document.getElementById('clear-filters').addEventListener('click', () => {
          state = { sport: '', ageMin: null, ageMax: null, dayOvernight: 'all', state: '', zipLat: null, zipLon: null, zipRadius: 10 };
          document.getElementById('filter-sport').value = '';
          document.getElementById('filter-age-min').value = '';
          document.getElementById('filter-age-max').value = '';
          document.getElementById('filter-state').value = '';
          document.getElementById('filter-zip').value = '';
          document.getElementById('filter-radius').value = '10';
          document.querySelectorAll('[data-filter-dayovernght]').forEach(b => b.removeAttribute('data-active'));
          const allBtn = document.querySelector('[data-filter-dayovernght="all"]');
          if (allBtn) allBtn.setAttribute('data-active', 'true');
          applyFilters();
        });
      }

      // Initial setup
      populateFilters();
      attachListeners();
      initMap();
      renderMap();
      applyFilters();
    })();
  </script>
</BaseLayout>

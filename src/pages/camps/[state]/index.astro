---
// State-level camp landing page. Lists cities in the state with camp counts.
//
// URL: /camps/wa/, /camps/or/, etc. State code is lowercase in URL, normalized
// to uppercase before the DB query.
//
// SSR. Cached at the edge for 30 minutes since state-level rollups change slowly.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { listCitiesInState, listCampsByState, slugifyCity, type Camp } from '../../../lib/camps-db';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=1800, stale-while-revalidate=86400');

const stateParam = (Astro.params.state || '').toLowerCase();
const stateCode = stateParam.toUpperCase();

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
let cities: { city: string; count: number }[] = [];
let recent: Camp[] = [];

if (env?.DB && stateCode) {
  try {
    cities = await listCitiesInState(env.DB, stateCode);
    const all = await listCampsByState(env.DB, stateCode);
    recent = all.slice(0, 6);
  } catch (e) {
    console.error('state page query failed', e);
  }
}

if (cities.length === 0) {
  return new Response('No camps yet for this state', { status: 404 });
}

const STATE_NAMES: Record<string, string> = {
  AL:'Alabama',AK:'Alaska',AZ:'Arizona',AR:'Arkansas',CA:'California',CO:'Colorado',CT:'Connecticut',
  DE:'Delaware',FL:'Florida',GA:'Georgia',HI:'Hawaii',ID:'Idaho',IL:'Illinois',IN:'Indiana',IA:'Iowa',
  KS:'Kansas',KY:'Kentucky',LA:'Louisiana',ME:'Maine',MD:'Maryland',MA:'Massachusetts',MI:'Michigan',
  MN:'Minnesota',MS:'Mississippi',MO:'Missouri',MT:'Montana',NE:'Nebraska',NV:'Nevada',NH:'New Hampshire',
  NJ:'New Jersey',NM:'New Mexico',NY:'New York',NC:'North Carolina',ND:'North Dakota',OH:'Ohio',
  OK:'Oklahoma',OR:'Oregon',PA:'Pennsylvania',RI:'Rhode Island',SC:'South Carolina',SD:'South Dakota',
  TN:'Tennessee',TX:'Texas',UT:'Utah',VT:'Vermont',VA:'Virginia',WA:'Washington',WV:'West Virginia',
  WI:'Wisconsin',WY:'Wyoming',DC:'District of Columbia',
};
const stateName = STATE_NAMES[stateCode] || stateCode;
const totalCamps = cities.reduce((n, c) => n + c.count, 0);

const title = `Summer camps in ${stateName}`;
const description = `${totalCamps} verified camp${totalCamps === 1 ? '' : 's'} across ${cities.length} ${cities.length === 1 ? 'city' : 'cities'} in ${stateName}. Browse by city, sport, or age.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Camps', item: 'https://parentcoachdesk.com/camps/' },
    { '@type': 'ListItem', position: 2, name: stateName },
  ],
};
---
<BaseLayout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
        <a href="/camps/" class="hover:underline">Camps</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05]" style="font-weight: 500;">
        {title}
      </h1>
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {totalCamps} verified camp{totalCamps === 1 ? '' : 's'} across {cities.length} {cities.length === 1 ? 'city' : 'cities'}.
      </p>
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      <h2 class="font-display text-ink text-2xl mb-6" style="font-weight: 500;">Pick your city</h2>
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
        {cities.map((c) => (
          <li>
            <a
              href={`/camps/${stateParam}/${slugifyCity(c.city)}/`}
              class="font-display text-ink hover:text-rust block border border-bone rounded p-3"
              style="font-weight: 500;"
            >
              <span class="text-base">{c.city}</span>
              <span class="font-display italic text-ink-soft text-sm ml-2" style="font-weight: 500;">
                {c.count} camp{c.count === 1 ? '' : 's'}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCampBySlug, getCampBySlugAny, listApprovedReviewsForCamp, listOtherCampsAtAddress, slugifyCity, type Camp, type CampReview } from '../../lib/camps-db';
import { SPORTS, BUYING_GUIDES } from '../../data/site';

// SSR — pulls live from D1 each request, but cached at the edge for 1 hour
// since individual camp detail pages change less often than the directory.
// Admin edits will reflect within the hour, or sooner if cache is purged.
export const prerender = false;
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=3600, stale-while-revalidate=86400',
);

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
const slug = Astro.params.slug;

// State-code dispatch. Astro's routing prefers /camps/[slug].astro over
// /camps/[state]/index.astro for single-segment URLs (alphabetical fallback when
// both match), so /camps/wa/ would 404 here even though the state page exists.
// If the slug is a 2-letter state code and that state has approved camps,
// render the state-landing UI inline. Otherwise continue to camp detail.
const STATE_CODES = new Set(['al','ak','az','ar','ca','co','ct','de','fl','ga','hi','id','il','in','ia','ks','ky','la','me','md','ma','mi','mn','ms','mo','mt','ne','nv','nh','nj','nm','ny','nc','nd','oh','ok','or','pa','ri','sc','sd','tn','tx','ut','vt','va','wa','wv','wi','wy','dc']);

let stateCities: { city: string; count: number }[] | null = null;
if (env?.DB && slug && STATE_CODES.has(slug.toLowerCase())) {
  try {
    const { listCitiesInState } = await import('../../lib/camps-db');
    stateCities = await listCitiesInState(env.DB, slug.toUpperCase());
  } catch (e) {
    console.error('listCitiesInState dispatch failed', e);
  }
}

let camp: Camp | null = null;
if (!stateCities || stateCities.length === 0) {
  if (env?.DB && slug) {
    try {
      camp = await getCampBySlug(env.DB, slug);
    } catch (e) {
      console.error('getCampBySlug failed', e);
    }
  }
  if (!camp || camp.status !== 'approved') {
    // A live approved+future camp always takes the branch above. Anything
    // else falls here, and a bare 404 used to be the only outcome — including
    // for camps that were once public and indexed (2026-07 SEO audit: expired
    // camps must never 404; they either 301 to a hub or 410, so Google keeps
    // the URL's signal instead of the page rotting into a dead end).
    let any: Camp | null = null;
    if (env?.DB && slug) {
      try {
        any = await getCampBySlugAny(env.DB, slug);
      } catch (e) {
        console.error('getCampBySlugAny failed', e);
      }
    }
    if (!any) {
      // Slug never existed. A real 404 is the correct response.
      return new Response('Not found', { status: 404 });
    }
    const today = new Date().toISOString().slice(0, 10);
    if (any.end_date && any.end_date < today) {
      // The event already happened, approved or not. 301 to the sport hub
      // (a static page that always renders) so the URL's link/impression
      // signal lands somewhere permanent instead of dying.
      const sportGuide = SPORTS.find((s) => s.slug === any!.sport);
      const dest = sportGuide ? `/sports/${sportGuide.slug}/` : '/camps/';
      return Astro.redirect(dest, 301);
    }
    // Future-dated but not approved (pending review, or rejected for cause:
    // duplicate, dead URL, spam, etc.). Never indexed as a live page, but the
    // slug is real and may be crawled — 410 says so is permanently gone
    // rather than a bare, ambiguous 404.
    return new Response('Gone', { status: 410 });
  }
}

// State-page presentation values. Computed in frontmatter to avoid TypeScript
// type assertions inline in the template body — esbuild's parser interprets
// `<string, string>` as JSX and the build breaks.
const STATE_NAMES_BY_CODE: Record<string, string> = {
  AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas',
  CA: 'California', CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware',
  FL: 'Florida', GA: 'Georgia', HI: 'Hawaii', ID: 'Idaho',
  IL: 'Illinois', IN: 'Indiana', IA: 'Iowa', KS: 'Kansas',
  KY: 'Kentucky', LA: 'Louisiana', ME: 'Maine', MD: 'Maryland',
  MA: 'Massachusetts', MI: 'Michigan', MN: 'Minnesota', MS: 'Mississippi',
  MO: 'Missouri', MT: 'Montana', NE: 'Nebraska', NV: 'Nevada',
  NH: 'New Hampshire', NJ: 'New Jersey', NM: 'New Mexico', NY: 'New York',
  NC: 'North Carolina', ND: 'North Dakota', OH: 'Ohio', OK: 'Oklahoma',
  OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah',
  VT: 'Vermont', VA: 'Virginia', WA: 'Washington', WV: 'West Virginia',
  WI: 'Wisconsin', WY: 'Wyoming', DC: 'District of Columbia',
};
const stateCodeForSlug = (slug || '').toUpperCase();
const stateNameForSlug = STATE_NAMES_BY_CODE[stateCodeForSlug] || stateCodeForSlug;
const stateTotalCamps = stateCities ? stateCities.reduce((n, c) => n + c.count, 0) : 0;

// Camp-only frontmatter. Skip entirely when we're rendering a state landing
// (camp is null in that branch and these calls would crash on camp.id).
let reviews: CampReview[] = [];
let avgRating: number | null = null;
let otherAtAddress: Camp[] = [];
if (camp) {
  try {
    if (env?.DB) reviews = await listApprovedReviewsForCamp(env.DB, camp.id);
  } catch (e) {
    console.error('listApprovedReviewsForCamp failed', e);
  }

  avgRating = reviews.length
    ? (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length)
    : null;

  try {
    if (env?.DB) {
      otherAtAddress = await listOtherCampsAtAddress(env.DB, camp.address, camp.city, camp.zip, camp.id);
    }
  } catch (e) {
    console.error('listOtherCampsAtAddress failed', e);
  }
}

// Parse YYYY-MM-DD as local date (not UTC) so dates display correctly in
// Pacific time. new Date('2026-08-03') would be Aug 2 5pm Pacific.
const MONTHS_LONG = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const fmtDate = (s: string) => {
  const [y, m, d] = s.split('-').map(Number);
  return `${MONTHS_LONG[m - 1]} ${d}, ${y}`;
};

const fmtRange = (start: string, end: string) => `${fmtDate(start)} – ${fmtDate(end)}`;

// Sport label: prefer the SPORTS array's title-cased label; fall back to capitalizing.
const sportLabel = (slug: string): string => {
  const match = SPORTS.find((s) => s.slug === slug);
  if (match) return match.label;
  return slug
    .split(/[\s-]+/)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

// Camp-only computed values. Declare null/empty defaults so the state-page
// dispatch branch can render without these being referenced via undefined.
const skillLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
  all: 'All levels',
};
const spotsLabel: Record<string, string> = {
  open: 'Open',
  waitlist: 'Waitlist',
  full: 'Full',
};

// Normalize submitted URLs that may be missing a protocol (e.g. "tacomahawks.com").
const normalizeUrl = (raw: string | null): string | null => {
  if (!raw) return null;
  const trimmed = raw.trim();
  if (!trimmed) return null;
  if (/^https?:\/\//i.test(trimmed)) return trimmed;
  return `https://${trimmed}`;
};

let sportPretty = '';
let sportGuide: typeof BUYING_GUIDES[number] | undefined = undefined;
let dayLabel = '';
let websiteHref: string | null = null;
let registrationHref: string | null = null;
let galleryKeys: string[] = [];
let hasGeo = false;
let mapsHref = '';

if (camp) {
  sportPretty = sportLabel(camp.sport);
  sportGuide = BUYING_GUIDES.find((g) => g.slug === camp.sport);
  dayLabel = camp.day_or_overnight === 'day' ? 'Day camp' : 'Overnight camp';
  websiteHref = normalizeUrl(camp.website_url);
  registrationHref = normalizeUrl(camp.registration_url);

  if (camp.gallery_keys) {
    try {
      const parsed = JSON.parse(camp.gallery_keys);
      if (Array.isArray(parsed)) galleryKeys = parsed.filter((k) => typeof k === 'string' && k.length > 0);
    } catch {
      // ignore malformed
    }
  }

  hasGeo = typeof camp.latitude === 'number' && typeof camp.longitude === 'number';
  mapsHref = hasGeo
    ? `https://www.google.com/maps/search/?api=1&query=${camp.latitude},${camp.longitude}`
    : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${camp.address}, ${camp.city}, ${camp.state} ${camp.zip}`)}`;
}
---
{stateCities && stateCities.length > 0 ? (
  <BaseLayout
    title={`Summer camps in ${stateNameForSlug}`}
    description={`${stateTotalCamps} verified camps across ${stateCities.length} ${stateCities.length === 1 ? 'city' : 'cities'}.`}
  >
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-14">
        <p class="font-display italic text-rust mb-3" style="font-weight: 500;">
          <a href="/camps/" class="hover:underline">Camps</a>
        </p>
        <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05]" style="font-weight: 500;">
          Summer camps in {stateNameForSlug}
        </h1>
        <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
          {stateTotalCamps} verified camp{stateTotalCamps === 1 ? '' : 's'} across {stateCities.length}{' '}{stateCities.length === 1 ? 'city' : 'cities'}.
        </p>
      </div>
    </section>
    <section>
      <div class="container-px py-10">
        <h2 class="font-display text-ink text-2xl mb-6" style="font-weight: 500;">Pick your city</h2>
        <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
          {stateCities.map((c) => (
            <li>
              <a
                href={`/camps/${(slug || '').toLowerCase()}/${slugifyCity(c.city)}/`}
                class="font-display text-ink hover:text-rust block border border-bone rounded p-3"
                style="font-weight: 500;"
              >
                <span class="text-base">{c.city}</span>
                <span class="font-display italic text-ink-soft text-sm ml-2" style="font-weight: 500;">
                  {c.count} camp{c.count === 1 ? '' : 's'}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </BaseLayout>
) : (
<BaseLayout
  title={camp.name}
  description={`${sportPretty} camp for ages ${camp.age_min}-${camp.age_max} in ${camp.city}, ${camp.state}. ${fmtRange(camp.start_date, camp.end_date)}.`}
>

  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/camps/" class="hover:underline">Camps</a> · {sportPretty}
      </p>
      <div class="flex items-start gap-4 max-w-3xl">
        {camp.is_claimed === 1 && camp.logo_key && (
          <img
            src={`/camp-photos/${camp.logo_key}`}
            alt={`${camp.name} logo`}
            class="w-20 h-20 md:w-24 md:h-24 flex-shrink-0 object-contain bg-paper-warm border border-bone"
            loading="eager"
            decoding="async"
            width="96"
            height="96"
          />
        )}
        <h1 class="font-display text-ink text-[2.25rem] md:text-[3.5rem] leading-[1.0] font-medium">
          {camp.name}
          {camp.verified === 1 && (
            <span class="inline-block ml-2 align-middle font-display italic text-rust text-base border border-rust px-2 py-0.5 font-medium" title="Verified by the Parent Coach Desk editorial">
              Verified ✓
            </span>
          )}
        </h1>
      </div>
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {sportPretty} · ages {camp.age_min}–{camp.age_max} · {fmtRange(camp.start_date, camp.end_date)}
        {avgRating !== null && (
          <span class="inline-block ml-2 font-display italic text-rust text-base font-medium">
            · {avgRating.toFixed(1)}/5 ({reviews.length} {reviews.length === 1 ? 'review' : 'reviews'})
          </span>
        )}
      </p>

      {camp.hero_photo_key && (
        <div class="mt-8 max-w-3xl border border-bone bg-paper-warm" style="aspect-ratio: 16/9; overflow: hidden;">
          <img
            src={`/camp-photos/${camp.hero_photo_key}`}
            alt={`${camp.name} hero photo`}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width="1200"
            height="675"
            style="width: 100%; height: 100%; object-fit: cover;"
          />
        </div>
      )}

      <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-3 max-w-3xl">
        <div class="border border-bone p-3 bg-paper-warm">
          <p class="font-display italic text-rust text-xs font-medium">Format</p>
          <p class="font-display text-ink mt-0.5 font-medium">{dayLabel}</p>
        </div>
        <div class="border border-bone p-3 bg-paper-warm">
          <p class="font-display italic text-rust text-xs font-medium">Skill level</p>
          <p class="font-display text-ink mt-0.5 font-medium">{skillLabel[camp.skill_level] ?? camp.skill_level}</p>
        </div>
        <div class="border border-bone p-3 bg-paper-warm">
          <p class="font-display italic text-rust text-xs font-medium">Spots</p>
          <p class="font-display text-ink mt-0.5 font-medium">{spotsLabel[camp.spots_status] ?? camp.spots_status}</p>
        </div>
        {camp.price_text && (
          <div class="border border-bone p-3 bg-paper-warm">
            <p class="font-display italic text-rust text-xs font-medium">Price</p>
            <p class="font-display text-ink mt-0.5 font-medium">{camp.price_text}</p>
          </div>
        )}
      </div>

      {camp.is_claimed === 1 && registrationHref && camp.spots_status !== 'full' && (
        <div class="mt-6 max-w-3xl">
          <a
            href={registrationHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block font-display px-6 py-3 bg-rust text-paper hover:opacity-90 transition-opacity font-medium"
          >
            Register now ↗
          </a>
          <p class="font-display italic text-ink-soft text-xs mt-2 font-medium">
            Registration goes directly to the camp's site. We don't take a commission.
          </p>
        </div>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-12 grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-8 article-body">
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight mt-0 mb-4 font-medium">About this camp</h2>
        <p style="white-space: pre-wrap;">{camp.description}</p>

        <p class="font-display italic text-ink-soft text-sm mt-6 font-medium">
          {camp.lunch_included ? 'Lunch included.' : 'Bring lunch.'}
          {' '}{camp.aftercare_available ? 'Aftercare available.' : 'No aftercare.'}
        </p>

        {camp.is_claimed === 1 && galleryKeys.length > 0 && (
          <section class="mt-10 pt-8 border-t border-bone">
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight mt-0 mb-4 font-medium">
              Photos
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              {galleryKeys.map((key, idx) => (
                <div class="border border-bone bg-paper-warm overflow-hidden" style="aspect-ratio: 4/3;">
                  <img
                    src={`/camp-photos/${key}`}
                    alt={`${camp.name} photo ${idx + 1}`}
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="600"
                    style="width: 100%; height: 100%; object-fit: cover;"
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        {sportGuide && (
          <section class="mt-10 pt-8 border-t border-bone">
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight mt-0 mb-3 font-medium">
              Equipment for this camp
            </h2>
            <p class="font-display text-ink-soft leading-snug max-w-2xl">
              Most {sportPretty.toLowerCase()} camps expect kids to bring their own basic gear. Our guide covers what to buy at every age band, fit tests, and used-gear notes.
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              <a href={`/what-to-buy/${sportGuide.slug}/`} class="font-display italic px-4 py-2 border border-rust text-rust hover:bg-rust hover:text-paper transition-colors font-medium">
                Gear file for {sportPretty.toLowerCase()} →
              </a>
              <a href={`/what-to-buy/${sportGuide.slug}/sizing/`} class="font-display italic px-4 py-2 border border-bone text-ink hover:bg-paper-warm transition-colors font-medium">
                {sportPretty} sizing guide →
              </a>
            </div>
            <p class="font-display italic text-ink-soft text-xs mt-4 font-medium">
              Some links on the buying guide are affiliate links. We earn a small commission when you buy. The price you pay is the same.
            </p>
          </section>
        )}

        <!-- Reviews -->
        <section class="mt-12 pt-8 border-t border-bone">
          <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight mt-0 mb-4 font-medium">
            What parents say
          </h2>
          {reviews.length === 0 ? (
            <p class="font-display italic text-ink-soft font-medium">
              No reviews yet. If you've sent your kid here, you can be the first.
            </p>
          ) : (
            <ul class="grid gap-5">
              {reviews.map((r) => (
                <li class="border border-bone p-4 bg-paper-warm">
                  <p class="font-display italic text-rust text-sm font-medium">
                    {r.rating}/5 · {r.reviewer_display_name ?? 'A parent'} · {new Date(r.submitted_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </p>
                  <p class="font-display text-ink mt-2 leading-snug" style="white-space: pre-wrap;">{r.body}</p>
                </li>
              ))}
            </ul>
          )}

          <details class="mt-8 border border-bone bg-paper">
            <summary class="font-display italic text-rust px-4 py-3 cursor-pointer font-medium">
              Leave a review (your kid attended) →
            </summary>
            <form id="review-form" class="grid gap-4 p-4 pt-0" data-camp-slug={camp?.slug} novalidate>
              <div style="position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden;" aria-hidden="true">
                <label>Website (leave empty)
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <label class="grid gap-1">
                <span class="font-display italic text-ink text-sm font-medium">Your email</span>
                <input name="reviewer_email" type="email" required class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none" />
                <span class="font-display italic text-ink-soft text-xs font-medium">Stays private. Used only to verify and follow up if needed.</span>
              </label>

              <label class="grid gap-1">
                <span class="font-display italic text-ink text-sm font-medium">Display name (optional)</span>
                <input name="reviewer_display_name" maxlength="40" placeholder='e.g. "Tacoma soccer mom"' class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none" />
                <span class="font-display italic text-ink-soft text-xs font-medium">If you skip this, your review shows as "A parent."</span>
              </label>

              <label class="grid gap-1">
                <span class="font-display italic text-ink text-sm font-medium">Rating (1-5)</span>
                <select name="rating" required class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none max-w-xs">
                  <option value="">Choose...</option>
                  <option value="5">5: would do again</option>
                  <option value="4">4: solid, minor gripes</option>
                  <option value="3">3: fine, mixed</option>
                  <option value="2">2: would not repeat</option>
                  <option value="1">1: avoid</option>
                </select>
              </label>

              <label class="grid gap-1">
                <span class="font-display italic text-ink text-sm font-medium">Your review</span>
                <textarea name="body" required minlength="30" maxlength="2000" rows="5" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none" placeholder="What was your kid's week like? What worked, what didn't? 50-300 words."></textarea>
              </label>

              <div class="flex items-center gap-4">
                <button type="submit" class="btn">Submit review</button>
                <p data-review-status class="font-display italic text-ink-soft text-sm hidden font-medium" aria-live="polite"></p>
              </div>
              <p class="font-display italic text-ink-soft text-xs font-medium">
                Reviews are read by the editorial team before they go live. We publish the honest ones, both good and bad. Spam and personal attacks get rejected. We do not pay for reviews, accept payment for them, or suppress negative ones, and a camp claiming its listing has no effect on its reviews.
              </p>
            </form>
          </details>
        </section>
      </div>

      <aside class="lg:col-span-4 lg:pl-8 lg:border-l lg:border-bone">
        <p class="font-display italic text-rust mb-3 font-medium">Where</p>
        <p class="font-display text-ink leading-snug font-medium">
          {camp.address}<br />
          {camp.city}, {camp.state} {camp.zip}
        </p>

        {hasGeo ? (
          <div
            id="camp-map"
            class="mt-3 border border-bone"
            style="height: 220px; width: 100%; background: #EAEFE7;"
            data-lat={camp.latitude}
            data-lon={camp.longitude}
            data-name={camp.name}
            aria-label={`Map showing ${camp.name}`}
          ></div>
        ) : (
          <div class="mt-3 border border-bone bg-paper-warm p-4">
            <p class="font-display italic text-ink-soft text-sm font-medium">Map coming once we verify the address.</p>
          </div>
        )}

        <a href={mapsHref} target="_blank" rel="noopener" class="t-cta inline-block mt-3">
          Open in Google Maps ↗
        </a>

        <p class="font-display italic text-rust mt-6 mb-3 font-medium">Contact</p>
        <ul class="grid gap-2">
          {camp.contact_email && (
            <li>
              <a href={`mailto:${camp.contact_email}`} class="font-display text-ink hover:text-rust break-words font-medium">{camp.contact_email}</a>
            </li>
          )}
          {camp.contact_phone && (
            <li>
              <a href={`tel:${camp.contact_phone}`} class="font-display text-ink hover:text-rust font-medium">{camp.contact_phone}</a>
            </li>
          )}
          {websiteHref && (
            <li>
              <a href={websiteHref} target="_blank" rel="noopener" class="font-display text-ink hover:text-rust break-words font-medium">Camp website ↗</a>
            </li>
          )}
          {!camp.contact_email && !camp.contact_phone && !camp.website_url && (
            <li class="font-display italic text-ink-soft text-sm font-medium">No contact info on file. Email support@parentcoachdesk.com if you need an intro.</li>
          )}
        </ul>

        {otherAtAddress.length > 0 && (
          <div class="mt-8 pt-6 border-t border-bone">
            <p class="font-display italic text-rust mb-3 font-medium">Also at this address</p>
            <ul class="grid gap-2">
              {otherAtAddress.map((c) => (
                <li>
                  <a href={`/camps/${c.slug}/`} class="font-display text-ink hover:text-rust block leading-tight font-medium">
                    {c.name}
                  </a>
                  <p class="font-display italic text-ink-soft text-xs mt-0.5 font-medium">
                    {c.sport} · ages {c.age_min}–{c.age_max}
                  </p>
                </li>
              ))}
            </ul>
          </div>
        )}

        {camp.is_claimed === 1 ? (
          <p class="font-display italic text-rust text-xs mt-8 font-medium">
            ✓ Claimed by the camp. Information self-managed.
          </p>
        ) : (
          <details class="mt-8 pt-6 border-t border-bone">
            <summary class="font-display italic text-rust cursor-pointer text-sm font-medium">
              Run this camp? Claim the listing →
            </summary>
            <div class="mt-3 article-body" style="font-size: 0.9rem;">
              <p>Camps that claim their listing get to self-edit info, add a logo, post a photo gallery, and embed a registration link. Free. We verify ownership before activating.</p>
              <p>By uploading photos you confirm you own them and have written consent from a parent or guardian for any child shown.</p>
            </div>
            <form id="claim-form" class="grid gap-3 mt-3" data-camp-slug={camp?.slug} novalidate>
              <div style="position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden;" aria-hidden="true">
                <label>Website (leave empty)
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>
              <label class="grid gap-1">
                <span class="sr-only">Your email</span>
                <input name="claimant_email" type="email" required placeholder="Your email" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm" />
              </label>
              <label class="grid gap-1">
                <span class="sr-only">Your name</span>
                <input name="claimant_name" placeholder="Your name" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm" />
              </label>
              <label class="grid gap-1">
                <span class="sr-only">Organization</span>
                <input name="organization" placeholder="Organization (e.g. Lincoln High School Athletics)" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm" />
              </label>
              <label class="grid gap-1">
                <span class="sr-only">Phone (optional)</span>
                <input name="phone" placeholder="Phone (optional)" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm" />
              </label>
              <label class="grid gap-1">
                <span class="sr-only">Proof of ownership</span>
                <textarea name="notes" required minlength="20" rows="3" placeholder="Proof of ownership: your role, how to verify (e.g. 'I'm the head coach. Reach me via the school's main line.')" class="px-3 py-2 font-body bg-paper border border-bone focus:border-rust focus:outline-none text-sm"></textarea>
              </label>
              <button type="submit" class="btn">Submit claim request</button>
              <p data-claim-status class="font-display italic text-ink-soft text-xs hidden font-medium" aria-live="polite"></p>
              <p class="font-display italic text-ink-soft text-xs font-medium">
                We review every claim. Verification takes ~2 business days.
              </p>
            </form>
          </details>
        )}

        <p class="font-display italic text-ink-soft text-xs mt-8 font-medium">
          Listing reviewed by the Parent Coach Desk. Something off? Email <a href="mailto:support@parentcoachdesk.com" class="text-rust hover:underline">support@parentcoachdesk.com</a>.
        </p>
      </aside>
    </div>
  </section>


  <script>
    (function () {
      var form = document.getElementById('review-form');
      var status = document.querySelector('[data-review-status]');
      if (!form || !status) return;
      var slug = form.getAttribute('data-camp-slug') || '';
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        status.classList.remove('hidden');
        status.textContent = 'Submitting...';
        status.style.color = '#5F5448';
        var fd = new FormData(form);
        fetch('/api/camps/' + slug + '/reviews/submit', { method: 'POST', body: fd })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              status.textContent = data.error ? "Couldn't submit: " + data.error : 'Something went wrong. Try again.';
              status.style.color = '#9E5228';
              return;
            }
            form.reset();
            status.textContent = 'Thanks. Review queued for moderation.';
            status.style.color = '#5C7459';
          })
          .catch(function () {
            status.textContent = 'Network error. Try again.';
            status.style.color = '#9E5228';
          });
      });
    })();

    (function () {
      var form = document.getElementById('claim-form');
      var status = document.querySelector('[data-claim-status]');
      if (!form || !status) return;
      var slug = form.getAttribute('data-camp-slug') || '';
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        status.classList.remove('hidden');
        status.textContent = 'Submitting...';
        status.style.color = '#5F5448';
        var fd = new FormData(form);
        fetch('/api/camps/' + slug + '/claim', { method: 'POST', body: fd })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              status.textContent = data.error ? "Couldn't submit: " + data.error : 'Something went wrong. Try again.';
              status.style.color = '#9E5228';
              return;
            }
            form.reset();
            status.textContent = data.message || 'Claim request received.';
            status.style.color = '#5C7459';
          })
          .catch(function () {
            status.textContent = 'Network error. Try again.';
            status.style.color = '#9E5228';
          });
      });
    })();
  </script>

  <script>
    import L from 'leaflet';
    import 'leaflet/dist/leaflet.css';
    const mapEl = document.getElementById('camp-map') as HTMLElement | null;
    if (mapEl) {
      const lat = parseFloat(mapEl.getAttribute('data-lat') ?? '');
      const lon = parseFloat(mapEl.getAttribute('data-lon') ?? '');
      const name = mapEl.getAttribute('data-name') || 'Camp';
      if (isFinite(lat) && isFinite(lon)) {
        const map = L.map(mapEl, { scrollWheelZoom: false, attributionControl: true })
          .setView([lat, lon], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> contributors',
        }).addTo(map);
        L.marker([lat, lon]).addTo(map).bindPopup(name);
      }
    }
  </script>
</BaseLayout>
)}

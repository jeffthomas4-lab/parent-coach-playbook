---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';

export const prerender = true;

const axes = [
  {
    label: 'Fun ↔ Performance',
    leftLabel: 'Fun',
    rightLabel: 'Performance',
    leftBlurb: 'Joy of playing. Friends on the team. Coming back next year because they want to.',
    rightBlurb: 'Skill development. Stats. Roster spots. The college pipeline if it exists for this kid.',
    middleBlurb: 'Most families live somewhere on the spectrum, sometimes drifting one direction without meaning to.',
  },
  {
    label: 'Rec ↔ Travel',
    leftLabel: 'Rec',
    rightLabel: 'Travel',
    leftBlurb: 'Local league. One season. Snack rotation. Banquet at the pizza place.',
    rightBlurb: 'Tryout-based. Travel weekends. Year-round or near-it. Higher stakes, higher cost.',
    middleBlurb: 'There is a missing rec-plus layer at most ages. Worth knowing what you actually want before you sign.',
  },
  {
    label: 'Growth ↔ Burnout',
    leftLabel: 'Growth',
    rightLabel: 'Burnout',
    leftBlurb: 'Kid is getting better. Loves the work. Wants the next thing.',
    rightBlurb: 'Kid is showing avoidance, mood changes, lost interest. Body is breaking down.',
    middleBlurb: 'Almost every kid touches both ends across a season. The job is reading where they actually are right now.',
  },
  {
    label: 'Parent support ↔ Parent pressure',
    leftLabel: 'Support',
    rightLabel: 'Pressure',
    leftBlurb: 'You drive, you watch, you stay quiet on the way home, you trust the coach.',
    rightBlurb: 'You evaluate, you compare, you coach from the sideline, you make next year a campaign.',
    middleBlurb: 'Almost every parent slides toward the right when the kid starts being good. The slide is invisible until the kid mentions it.',
  },
];
---
<BaseLayout
  title="The youth sports pendulum"
  description="Fun ↔ performance. Rec ↔ travel. Growth ↔ burnout. Parent support ↔ parent pressure. Where is your family on each one right now?"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'The Youth Sports Pendulum',
    url: 'https://parentcoachdesk.com/youth-sports-pendulum/',
    applicationCategory: 'EducationalApplication',
    operatingSystem: 'Web',
    description: 'An interactive self-assessment tool that helps families locate themselves on four youth sports spectrums: fun vs performance, rec vs travel, growth vs burnout, and parent support vs parent pressure.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  })} />
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">A way to think about it</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl font-medium">
        The youth sports <em class="text-rust">pendulum</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Youth sports isn't one thing. There's a fun-first lane and a performance-first lane. There's rec and there's travel. Every family ends up somewhere on the spectrum. The job is knowing where you are.
      </p>
      <figure class="mt-10">
        <img
          src="/illustrations/pendulum-fun-vs-performance.webp"
          alt="The Pendulum: Fun on one side, Performance on the other, kids playing soccer underneath."
          class="w-full h-auto border border-bone"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-10 max-w-3xl">
      <p class="font-display text-ink leading-relaxed text-lg">
        Some kids play for the joy. Some chase the next level. Most families are somewhere in between, and that's the whole point of the pendulum: it swings.
      </p>
      <p class="font-display text-ink leading-relaxed text-lg mt-3">
        The mistake is pretending you're at one end when you're actually at the other. The other mistake is assuming the kid is on the same end you are.
      </p>
    </div>
  </section>

  {axes.map((a) => (
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-12 max-w-4xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">Axis</p>
        <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">
          {a.label}
        </h2>

        <!-- Visual spectrum -->
        <div class="mt-6 flex items-center gap-3">
          <span class="font-display italic text-sm font-medium" style="color: #5C7459">{a.leftLabel}</span>
          <div class="flex-1 h-2 bg-bone relative">
            <div class="absolute top-1/2 -translate-y-1/2 h-4 w-4 bg-rust rounded-full" style="left: 50%; transform: translate(-50%, -50%);"></div>
          </div>
          <span class="font-display italic text-sm font-medium" style="color: #C5713D">{a.rightLabel}</span>
        </div>

        <div class="mt-6 grid md:grid-cols-2 gap-6">
          <div>
            <p class="font-display italic text-sm mb-2 font-medium" style="color: #5C7459">{a.leftLabel}</p>
            <p class="font-display text-ink leading-snug">{a.leftBlurb}</p>
          </div>
          <div>
            <p class="font-display italic text-sm mb-2 font-medium" style="color: #C5713D">{a.rightLabel}</p>
            <p class="font-display text-ink leading-snug">{a.rightBlurb}</p>
          </div>
        </div>

        <div class="mt-5 pt-4 border-t border-bone">
          <p class="font-display italic text-ink-soft text-sm leading-snug font-medium">
            {a.middleBlurb}
          </p>
        </div>
      </div>
    </section>
  ))}

  <!-- The big idea -->
  <section class="border-b border-bone bg-ink text-paper">
    <div class="container-px py-12 max-w-3xl">
      <p class="font-display italic mb-3 text-sm font-medium" style="color: #D4AB6A">The point</p>
      <p class="font-display text-paper text-2xl md:text-3xl leading-snug font-medium">
        Find where your family actually is on each axis. Then ask: is that where we want to be?
      </p>
      <p class="font-display text-paper-warm mt-5 leading-relaxed">
        Most parenting decisions in youth sports are not yes-or-no decisions. They're position-on-the-pendulum decisions. The travel team isn't good or bad. The question is whether it pulls you in the direction you want to go right now.
      </p>
    </div>
  </section>

  <!-- Where to go from here -->
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-4 font-medium">From here</p>
      <div class="grid sm:grid-cols-2 gap-px bg-bone max-w-4xl">
        <a href="/decisions/" class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
          <h3 class="font-display text-ink text-xl group-hover:text-rust transition-colors font-medium">Walk through the big decisions</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">Travel, quit, specialize, multi-sport. Page each.</p>
        </a>
        <a href="/scripts/" class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
          <h3 class="font-display text-ink text-xl group-hover:text-rust transition-colors font-medium">Open the Scripts hub</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">What to say in the moments that matter.</p>
        </a>
        <a href="/cost-calculator/" class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
          <h3 class="font-display text-ink text-xl group-hover:text-rust transition-colors font-medium">Open the calculator</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">What does each tier of the pendulum cost in real dollars?</p>
        </a>
        <a href="/body/burnout-signs/" class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
          <h3 class="font-display text-ink text-xl group-hover:text-rust transition-colors font-medium">Read on burnout signs</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">If the pendulum is sliding toward the wrong end.</p>
        </a>
      </div>
    </div>
  </section>

  <LeadMagnetCTA />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isLive } from '../lib/publishFilter';
import { stripTitle } from '../lib/title';
import { SPORTS } from '../data/site';
import { serializeJsonLd } from '../lib/jsonld';

// Pull every public collection so search covers the whole site.
const articles    = (await getCollection('articles',       ({ data }) => isLive(data)));
const guides      = (await getCollection('guides',         ({ data }) => isLive(data)));
const resources   = (await getCollection('resources',      ({ data }) => isLive(data) && data.type !== 'external'));
const tips        = (await getCollection('coachingTips',   ({ data }) => isLive(data)));
const bodyTopics  = (await getCollection('body',           ({ data }) => isLive(data)));
const pathways    = (await getCollection('pathways',       ({ data }) => isLive(data)));
const calendars   = (await getCollection('seasonCalendars',({ data }) => isLive(data)));
const recruiting  = (await getCollection('recruiting',     ({ data }) => isLive(data)));
const adaptive    = (await getCollection('adaptive',       ({ data }) => isLive(data)));
const rules       = (await getCollection('rules',          ({ data }) => isLive(data)));
const scripts     = (await getCollection('scripts',        ({ data }) => isLive(data)));
const decisions   = (await getCollection('decisions',      ({ data }) => isLive(data)));

const sportLabel = (s: string) => SPORTS.find(x => x.slug === s)?.label ?? s;

// Each entry: type for the meta label, title for matching+display, dek for matching+display,
// href for the destination, meta for the small label above the title.
const articleIndex = articles.map(a => ({
  type: 'Reads',
  title: stripTitle(a.data.title),
  dek: a.data.dek ?? '',
  href: `/${a.data.phase}/${a.id}/`,
  meta: ['Reads', a.data.phase, a.data.sport, a.data.age].filter(Boolean).join(' · '),
}));

const guideIndex = guides.map(g => ({
  type: 'Gear Files',
  title: `Gear File: ${g.data.activity.toLowerCase()}`,
  dek: g.data.lede,
  href: `/what-to-buy/${g.id}/`,
  meta: g.data.category === 'sport' ? 'Gear Files · sport' : g.data.category === 'activity' ? 'Gear Files · activity' : 'Gear Files · essentials',
}));

const resourceIndex = resources.map(r => ({
  type: 'Team Parent',
  title: stripTitle(r.data.title),
  dek: r.data.summary,
  href: `/team-parent/${r.id}/`,
  meta: 'Team Parent · ' + r.data.category.replace('-', ' '),
}));

const tipsIndex = tips.map(t => ({
  type: 'Drills',
  title: stripTitle(t.data.title),
  dek: t.data.summary,
  href: `/coaching-tips/${t.id}/`,
  meta: ['Drills', t.data.sport, t.data.age, t.data.focus].filter(Boolean).join(' · '),
}));

const bodyIndex = bodyTopics.map(b => {
  const subhub = (b.data as any).subhub === 'safety' ? 'Safety' : 'Body';
  const cat = (b.data as any).safetyCategory ?? b.data.category ?? '';
  return {
    type: subhub === 'Safety' ? 'Safety' : 'The Body',
    title: stripTitle(b.data.title),
    dek: b.data.summary,
    href: `/body/${b.id}/`,
    meta: `${subhub === 'Safety' ? 'Safety' : 'The Body'} · ${cat.toString().replace(/-/g, ' ')}`.trim(),
  };
});

const pathwayIndex = pathways.map(p => ({
  type: 'Pathways',
  title: stripTitle(p.data.title),
  dek: p.data.summary,
  href: `/pathways/${p.data.sport}/`,
  meta: 'Pathways · ' + sportLabel(p.data.sport),
}));

const calendarIndex = calendars.map(c => ({
  type: 'Season calendar',
  title: stripTitle(c.data.title),
  dek: c.data.summary,
  href: `/season-calendar/${c.id}/`,
  meta: 'Season calendar · ' + sportLabel(c.data.sport),
}));

const recruitingIndex = recruiting.map(r => ({
  type: 'Recruiting',
  title: stripTitle(r.data.title),
  dek: r.data.summary,
  href: `/recruiting/${r.id}/`,
  meta: 'Recruiting · ' + r.data.category,
}));

const adaptiveIndex = adaptive.map(a => ({
  type: 'Adaptive',
  title: stripTitle(a.data.title),
  dek: a.data.summary,
  href: `/adaptive/${a.id}/`,
  meta: 'Adaptive · ' + a.data.category.replace('-', ' '),
}));

const rulesIndex = rules.map(r => ({
  type: 'Rules',
  title: stripTitle(r.data.title),
  dek: r.data.summary,
  href: `/rules/${r.data.sport}/`,
  meta: 'Rules · ' + sportLabel(r.data.sport),
}));

const scriptsIndex = scripts.map(s => ({
  type: 'Scripts',
  title: stripTitle(s.data.title),
  dek: s.data.summary,
  href: `/scripts/${s.id}/`,
  meta: 'Scripts · ' + s.data.moment.replace(/-/g, ' '),
}));

const decisionsIndex = decisions.map(d => ({
  type: 'Decisions',
  title: stripTitle(d.data.title),
  dek: d.data.summary,
  href: `/decisions/${d.id}/`,
  meta: 'Decisions',
}));

// Static pages parents might search for.
const staticIndex = [
  { type: 'Parent-Coach', title: 'The parent-coach', dek: 'Reads, drills, scripts, and decisions for the parent who is also on the bench.', href: '/parent-coach/', meta: 'Parent-coach pillar' },
  { type: 'Sports', title: 'By sport', dek: 'Every read, drill, calendar, and tool grouped by sport. The fastest entry point.', href: '/sports/', meta: 'Sports · index' },
  ...SPORTS.map(s => ({
    type: 'Sport guide' as const,
    title: `${s.label} parent guide`,
    dek: `Articles, drills, pathways, calendars, and rules for ${s.label.toLowerCase()} families.`,
    href: `/sports/${s.slug}/`,
    meta: `Sports · ${s.label}`,
  })),
  { type: 'Tools', title: 'Cost calculator', dek: 'What does a year of youth sports actually cost?', href: '/cost-calculator/', meta: 'Tools · cost calculator' },
  { type: 'Tools', title: 'Cost calculator methodology', dek: 'Where the default numbers come from.', href: '/cost-calculator/methodology/', meta: 'Tools · methodology' },
  { type: 'Tools', title: 'Tools index', dek: 'Cost calculator, by sport, season calendar, pathways, recruiting.', href: '/tools/', meta: 'Tools' },
  { type: 'Camps', title: 'Camps directory', dek: 'Search and submit youth sports and activity camps.', href: '/camps/', meta: 'Camps' },
  { type: 'About', title: 'About Parent Coach Desk', dek: 'What this is and who writes it.', href: '/about/', meta: 'About' },
  { type: 'About', title: 'Sources', dek: 'The institutions and journals we cite from.', href: '/about/sources/', meta: 'About · sources' },
  { type: 'About', title: 'Corrections', dek: 'Every fix we have made to a published piece.', href: '/about/corrections/', meta: 'About · corrections' },
  { type: 'Friday Letter', title: 'The Friday Letter', dek: 'One short read every Friday from the Parent Coach Desk.', href: '/newsletter/', meta: 'Friday Letter' },
  { type: 'Start', title: 'Start here', dek: 'If you are new to this, or in the middle of a hard moment, start here.', href: '/start-here/', meta: 'Start here' },
];

const fullIndex = [
  ...scriptsIndex, ...decisionsIndex,
  ...articleIndex, ...guideIndex, ...resourceIndex, ...tipsIndex,
  ...bodyIndex, ...pathwayIndex, ...calendarIndex,
  ...recruitingIndex, ...adaptiveIndex, ...rulesIndex,
  ...staticIndex,
];

const totalCount = fullIndex.length;

// Curated popular searches and popular reads (manual list, edit anytime)
const popularSearches = [
  { label: 'tryouts', href: '/drive-there/night-before-tryouts/' },
  { label: 'bad game', href: '/drive-home/the-90-second-rule/' },
  { label: 'cost', href: '/cost-calculator/' },
  { label: 'recruiting', href: '/recruiting/' },
  { label: 'concussion', href: '/body/concussion-protocol-basics/' },
  { label: 'travel ball', href: '/team-parent/travel-tournament-packing-list/' },
];

const popularReads = [
  { title: 'What you say in the first 90 seconds', dek: 'The post-game window decides what the next week feels like.', href: '/drive-home/the-90-second-rule/' },
  { title: 'Are youth sports worth it? An honest answer.', dek: 'The cost is real. The hassle is real. The benefits are real too.', href: '/drive-there/are-youth-sports-worth-it/' },
  { title: 'Cost calculator', dek: 'What does a year of youth sports actually cost? Honest math, either way.', href: '/cost-calculator/' },
  { title: 'Concussion protocol basics', dek: 'CDC HEADS UP, return-to-play, your state law.', href: '/body/concussion-protocol-basics/' },
];
---
<BaseLayout title="Search" description="Search the whole site. Articles, body topics, pathways, season calendars, cost calculator, recruiting, adaptive, rules, drills, gear guides.">
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Search</p>
      <h1 class="font-display text-ink text-[2rem] md:text-[3rem] leading-[1.0] font-medium">
        Find what you're looking for
      </h1>
      <p class="font-display italic text-ink-soft text-sm mt-3 font-medium">
        Searching {totalCount} pieces across the whole site.
      </p>
      <input
        type="search"
        placeholder="Try: tryouts, recruiting, concussion, AAU, gear, cost..."
        class="mt-7 w-full max-w-xl px-4 py-3 font-body bg-paper border border-ink focus:border-rust focus:outline-none"
        data-search-input
      />

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <span class="font-display italic text-ink-soft text-sm font-medium">Popular searches:</span>
        {popularSearches.map(p => (
          <a
            href={p.href}
            class="font-display italic text-rust hover:text-ink text-sm border border-bone px-3 py-1 hover:bg-paper-warm transition-colors font-medium"
          >{p.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Default: popular reads. Replaced by JS when the user types. -->
  <section data-default-state>
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-4 font-medium">Popular reads</p>
      <div class="grid md:grid-cols-2 gap-px bg-bone">
        {popularReads.map(r => (
          <a href={r.href} class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
            <h2 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium">
              {r.title}
            </h2>
            <p class="font-display text-ink-soft mt-2 leading-snug text-sm">
              {r.dek}
            </p>
            <div class="t-cta mt-3">Read it →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Search results: populated by JS when the user types -->
  <section class="hidden" data-results-state>
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-4 font-medium" data-results-label aria-live="polite">Results</p>
      <div data-search-results aria-live="polite"></div>
    </div>
  </section>

  <script type="application/json" id="search-index" set:html={serializeJsonLd(fullIndex)} />
  <script>
    type Hit = { type: string; title: string; dek: string; href: string; meta: string };
    const idxEl = document.getElementById('search-index') as HTMLScriptElement | null;
    const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
    const out = document.querySelector('[data-search-results]') as HTMLElement | null;
    const defaultState = document.querySelector('[data-default-state]') as HTMLElement | null;
    const resultsState = document.querySelector('[data-results-state]') as HTMLElement | null;
    const resultsLabel = document.querySelector('[data-results-label]') as HTMLElement | null;

    if (idxEl && input && out && defaultState && resultsState && resultsLabel) {
      const data: Hit[] = JSON.parse(idxEl.textContent || '[]');
      const escape = (s: string) => s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c] || c));

      const render = (hits: Hit[], query: string) => {
        if (hits.length === 0) {
          out.innerHTML = `<p class="font-display italic text-ink-soft text-lg font-medium">No matches for "${escape(query)}". Email us at <a href="mailto:support@parentcoachdesk.com" class="text-rust">support@parentcoachdesk.com</a> and tell us what you're looking for.</p>`;
          return;
        }
        out.innerHTML = hits.map(h => `
          <a href="${h.href}" class="block border-b border-bone py-5 hover:bg-paper-warm transition-colors">
            <div class="font-display italic text-rust text-xs font-medium">${escape(h.meta)}</div>
            <h2 class="font-display text-ink text-xl mt-1 leading-tight font-medium">${escape(h.title)}</h2>
            ${h.dek ? `<p class="font-display text-ink-soft text-sm mt-1 leading-snug">${escape(h.dek)}</p>` : ''}
          </a>`).join('');
      };

      // Debounced logging: fires after the user stops typing for 600 ms, only
      // when the query is more than 2 characters. Fire-and-forget — errors are
      // swallowed so they never surface to the user.
      let logTimer: ReturnType<typeof setTimeout>;
      const logSearch = (q: string, resultCount: number) => {
        if (q.length <= 2) return;
        clearTimeout(logTimer);
        logTimer = setTimeout(() => {
          fetch('/api/search-event', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ query: q, resultCount }),
          }).catch(() => {});
        }, 600);
      };

      const runSearchAndLog = (raw: string) => {
        const q = raw.trim().toLowerCase();
        if (!q) {
          defaultState.classList.remove('hidden');
          resultsState.classList.add('hidden');
          clearTimeout(logTimer);
          return;
        }
        defaultState.classList.add('hidden');
        resultsState.classList.remove('hidden');
        const hits = data.filter(h =>
          h.title.toLowerCase().includes(q) ||
          h.dek.toLowerCase().includes(q) ||
          h.meta.toLowerCase().includes(q)
        );
        resultsLabel.textContent = `${hits.length} result${hits.length === 1 ? '' : 's'} for "${q}"`;
        render(hits, q);
        logSearch(q, hits.length);
      };

      input.addEventListener('input', () => runSearchAndLog(input.value));

      // Pre-fill from ?q= URL parameter so inline searches from /reads/ land on results.
      const urlParams = new URLSearchParams(window.location.search);
      const initialQ = urlParams.get('q');
      if (initialQ) {
        input.value = initialQ;
        runSearchAndLog(initialQ);
        input.focus();
      }
    }
  </script>
</BaseLayout>

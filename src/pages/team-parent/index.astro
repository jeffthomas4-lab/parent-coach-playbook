---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { TEAM_PARENT_TOPICS, TEAM_PARENT_CATEGORIES } from '../../data/site';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';

// Articles marked as team-parent phase
const teamParentArticles = (await getCollection('articles', ({ data }) =>
  isLive(data) && data.phase === 'team-parent'
))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Resources (older system, kept for templates and external links)
const resources = (await getCollection('resources', ({ data }) => isLive(data)))
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

// For each topic, gather count
const topicData = TEAM_PARENT_TOPICS.map(topic => {
  const articles = teamParentArticles.filter(a => a.data.teamParentTopic === topic.slug);
  return {
    ...topic,
    count: articles.length,
    recent: articles[0] || null,
  };
});

const recentArticles = teamParentArticles.slice(0, 6);
---
<BaseLayout
  title="Team Parent"
  description="Practical resources for being the team parent. Templates, scripts, communication norms, fundraising, fair lineups, snack signups that actually fill."
>
  <!-- Hero -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Team Parent</p>
      <h1 class="font-display text-ink text-[2rem] md:text-[4rem] leading-[1.05] max-w-3xl font-medium">
        For the parent doing <em class="text-rust">everything off the field</em>.
      </h1>
      <p class="font-display text-ink-soft text-lg md:text-2xl mt-5 max-w-2xl leading-snug">
        Articles, templates, and scripts for managing logistics, communication, money, photos, conflict, and the operational stuff that makes a season work.
      </p>
      <figure class="mt-10 max-w-4xl">
        <img
          src="/illustrations/pillar-team-parent.webp"
          alt="A team-parent binder open on a wooden table, surrounded by snack-rotation post-its, a jersey-numbers list, three sharpies, an April calendar, and a mug. Editorial flat-lay."
          class="w-full border border-bone"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <!-- Quick explainer -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-8 md:py-10 max-w-3xl">
      <p class="font-display italic text-rust mb-3 text-sm font-medium">How this works</p>
      <p class="font-display text-ink leading-relaxed text-base md:text-lg">
        Pick a topic to see the articles for it. Or browse the toolkit categories below. Pre-built templates and scripts you can copy-paste. Most are designed to be sent straight from your phone.
      </p>
    </div>
  </section>

  <!-- Quick anchor nav -->
  <section class="border-b border-bone">
    <div class="container-px py-5">
      <p class="font-display italic text-ink-soft text-xs mb-3 font-medium">Jump to</p>
      <div class="flex flex-wrap gap-2">
        <a href="#topics"   class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper-warm transition-colors text-sm font-medium">Topics</a>
        <a href="#recent"   class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper-warm transition-colors text-sm font-medium">Recent articles</a>
        <a href="#toolkit"  class="font-display italic text-ink hover:text-rust border border-bone px-4 py-2 hover:bg-paper-warm transition-colors text-sm font-medium">Toolkit</a>
      </div>
    </div>
  </section>

  <!-- Topics: scannable text-link grid -->
  <section id="topics" class="border-b border-bone scroll-mt-16">
    <div class="container-px py-8 md:py-10">
      <p class="font-display italic text-rust mb-4 font-medium" style="font-size: 1.05rem">Browse by topic</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1">
        {topicData.map((t) => (
          <li>
            <a href={`/team-parent/${t.slug}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
              <div class="flex items-baseline justify-between gap-3">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium">{t.label}</span>
                <span class="font-display italic text-ink-soft text-xs whitespace-nowrap font-medium">{t.count} {t.count === 1 ? 'piece' : 'pieces'}</span>
              </div>
              <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{t.blurb}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Recent articles -->
  {recentArticles.length > 0 && (
    <section id="recent" class="border-b border-bone scroll-mt-16">
      <div class="container-px py-8 md:py-10">
        <p class="font-display italic text-rust mb-4 font-medium" style="font-size: 1.05rem">Recent articles</p>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {recentArticles.map((a) => (
            <li>
              <a href={`/team-parent/${a.id}/`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <span class="font-display text-ink text-base block group-hover:text-rust font-medium" set:html={renderTitle(a.data.title)} />
                {a.data.dek && <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{a.data.dek}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Toolkit: compact category list -->
  <section id="toolkit" class="border-b border-bone scroll-mt-16">
    <div class="container-px py-8 md:py-10">
      <p class="font-display italic text-rust mb-4 font-medium" style="font-size: 1.05rem">Toolkit by category</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1">
        {TEAM_PARENT_CATEGORIES.map((c) => {
          const items = resources.filter(r => r.data.category === c.slug);
          return (
            <li>
              <a href={`#${c.slug}`} class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="font-display text-ink text-base block group-hover:text-rust font-medium">{c.label}</span>
                  <span class="font-display italic text-ink-soft text-xs whitespace-nowrap font-medium">{items.length} {items.length === 1 ? 'item' : 'items'}</span>
                </div>
                <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{c.blurb}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Toolkit detail sections (anchored from above) -->
  {TEAM_PARENT_CATEGORIES.map((c) => {
    const items = resources.filter(r => r.data.category === c.slug);
    return items.length > 0 ? (
      <section id={c.slug} class="border-b border-bone scroll-mt-16">
        <div class="container-px py-8 md:py-10">
          <p class="font-display italic mb-3 text-sm" style={`color: ${c.accent}; font-weight: 500;`}>{c.label}</p>
          <h2 class="font-display text-ink text-xl md:text-2xl leading-tight max-w-2xl mb-4 font-medium">{c.blurb}</h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
            {items.map((r) => (
              <li>
                <a
                  href={r.data.type === 'external' && r.data.externalUrl
                    ? r.data.externalUrl
                    : `/team-parent/${r.id}/`}
                  class="font-display block py-3 border-b border-bone hover:text-rust transition-colors group"
                  rel={r.data.type === 'external' ? 'noopener' : undefined}
                  target={r.data.type === 'external' ? '_blank' : undefined}
                >
                  <div class="flex items-baseline justify-between gap-3">
                    <span class="font-display text-ink text-base block group-hover:text-rust font-medium">
                      <span set:html={renderTitle(r.data.title)} />
                      {r.data.type === 'external' && <span aria-hidden="true"> ↗</span>}
                    </span>
                    <span class="font-display italic text-ink-soft text-xs whitespace-nowrap font-medium">
                      {r.data.type === 'template' ? 'template' : r.data.type === 'external' ? 'external' : 'read'}
                    </span>
                  </div>
                  <span class="font-display italic text-ink-soft text-xs block mt-1 leading-snug font-medium">{r.data.summary}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    ) : null;
  })}

  <NewsletterSignup
    headline="More tools every week"
    blurb="When we add new templates and scripts to the toolkit, you'll see it in the Friday note."
  />
</BaseLayout>

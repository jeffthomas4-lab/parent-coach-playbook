---
import BaseLayout from '../layouts/BaseLayout.astro';

// Newsletter archive. Will list actual Friday Letter issues once they ship.
// Until then, the archive is empty and the page leads with the signup CTA.
// When real issues exist, replace the empty-state block with a list pulled
// from a future `newsletter` content collection. The site's article posts
// (which are the body of the blog, not newsletter issues) intentionally
// do not appear here.
const issues: Array<{ slug: string; title: string; publishedAt: Date; dek?: string }> = [];
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---
<BaseLayout
  title="The Friday Letter"
  description="One short read every Friday from the Parent Coach Desk. Sideline notes for parents who coach. Free, no spam."
>
  <!-- Lead -->
  <section class="border-b border-ink bg-ink text-paper relative overflow-hidden">
    {/* Mailbox-at-sunset cover sits at 25% opacity behind a near-opaque dark wash. */}
    <img
      src="/illustrations/newsletter-mailbox-cta.webp"
      alt="A suburban mailbox at sunset with a Parent Coach Desk envelope sticking out."
      class="absolute inset-0 w-full h-full object-cover opacity-25"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgba(26,22,19,0.85) 0%, rgba(26,22,19,0.65) 60%, rgba(26,22,19,0.4) 100%);"
      aria-hidden="true"
    ></div>
    <div class="container-px py-16 md:py-20 grid md:grid-cols-12 gap-10 items-end relative">
      <div class="md:col-span-7">
        <p class="font-display italic text-trophy mb-3 font-medium">The Friday Letter</p>
        <h1 class="font-display text-paper text-[2.5rem] md:text-[4.25rem] leading-[1.0] font-medium">
          One short read every Friday. <em class="text-rust">No spam.</em>
        </h1>
        <p class="font-display text-paper-warm text-xl mt-6 max-w-xl leading-snug">
          A letter from the Parent Coach Desk lands in your inbox every Friday. Sometimes it's about a hard parent conversation. Sometimes a drill. Sometimes a piece of gear that finally got the kid to stop complaining. Always under five minutes to read.
        </p>
      </div>
      <div class="md:col-span-5">
        <aside class="bg-paper p-6 md:p-7 border border-bone">
          <p class="font-display italic text-rust mb-2 font-medium">Get the Friday Letter</p>
          <h3 class="font-display text-ink text-2xl leading-tight font-medium">
            Friday morning, free, no list-share.
          </h3>
          <a
            href="https://parent-coach-playbook.kit.com/4b28f916b5"
            class="btn mt-5 w-full inline-block text-center"
          >
            Get the Friday Letter
          </a>
          <p class="font-display italic text-ink-soft text-xs mt-3 font-medium">
            Unsubscribe in one click. We don't share or sell your address.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- Past issues / empty state -->
  <section class="border-b border-bone">
    <div class="container-px py-12">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-8">
        <p class="font-display italic text-rust font-medium">Past issues</p>
      </div>
      {issues.length === 0 ? (
        <div class="max-w-2xl">
          <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">
            The first letter is on the way.
          </h2>
          <p class="font-display text-ink-soft text-base mt-4 leading-snug">
            We haven't sent an issue yet. Subscribe and you'll be there for the first one. Past issues will live here once we have them.
          </p>
          <a
            href="https://parent-coach-playbook.kit.com/4b28f916b5"
            class="btn mt-6 inline-block"
          >
            Subscribe
          </a>
        </div>
      ) : (
        <ul class="grid gap-px bg-bone">
          {issues.map((a) => (
            <li class="bg-paper p-5 hover:bg-paper-warm transition-colors">
              <a href={`/newsletter/${a.slug}/`} class="grid md:grid-cols-[140px_1fr] gap-4 group items-baseline">
                <span class="font-display italic text-ink-soft text-sm font-medium">
                  {fmt(a.publishedAt)}
                </span>
                <div>
                  <h3
                    class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium"
                    set:html={a.title.replace(/\*([^*]+)\*/g, '<em>$1</em>')}
                  />
                  {a.dek && (
                    <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                      {a.dek}
                    </p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- What you get -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-12">
      <p class="font-display italic text-rust mb-3 font-medium">What you get</p>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl">
        <div>
          <h3 class="font-display text-ink text-xl leading-tight font-medium">A short read every Friday.</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">Five minutes or less. Topical to the season your kid is in.</p>
        </div>
        <div>
          <h3 class="font-display text-ink text-xl leading-tight font-medium">Free PDFs as we ship them.</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">What to Say When, the Practice Plan Template, the Pre-Game Pocket Card. Subscribers get them first.</p>
        </div>
        <div>
          <h3 class="font-display text-ink text-xl leading-tight font-medium">Reply, real people read it.</h3>
          <p class="font-display text-ink-soft text-sm mt-2 leading-snug">Hit reply on any issue. The Parent Coach Desk writes back.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

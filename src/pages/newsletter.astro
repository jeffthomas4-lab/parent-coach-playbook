---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
import { SPORTS, AGE_BANDS } from '../data/site';

const issues = (await getCollection('articles', ({ data }) => !data.draft && !!data.issue))
  .sort((a, b) => (b.data.issue ?? 0) - (a.data.issue ?? 0));
---
<BaseLayout title="Newsletter" description="One short read a week. Sideline notes for parents who coach.">
  <!-- Lead magnet hero -->
  <section class="border-b border-ink bg-ink text-paper">
    <div class="container-px py-20 grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-7">
        <p class="font-display italic text-trophy mb-3" style="font-weight: 500;">The newsletter</p>
        <h1 class="font-display text-paper text-[2.5rem] md:text-[4.25rem] leading-[1.0]" style="font-weight: 500;">
          One short read a week. <em class="text-rust">From three of us.</em>
        </h1>
        <p class="font-display text-paper-warm text-xl mt-6 max-w-xl leading-snug">
          Maren writes most weeks. Dan writes when he's been thinking about something long enough to be useful. Jeff writes the cornerstones. You get the best one of the three in your Friday inbox.
        </p>
      </div>
      <div class="md:col-span-5">
        <NewsletterSignup
          variant="card"
          headline="Subscribe"
          blurb="Plus the Drive Home Playbook and the Practice Plan Template, both free, when you sign up."
          buttonLabel="Send it all"
        />
      </div>
    </div>
  </section>

  <!-- What's coming Friday -->
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-10 md:py-12">
      <div class="grid md:grid-cols-12 gap-6 items-baseline">
        <div class="md:col-span-3">
          <p class="font-display italic text-rust" style="font-weight: 500;">Coming Friday</p>
          <p class="font-display italic text-ink-soft text-sm mt-1" style="font-weight: 500;">Issue #009</p>
        </div>
        <div class="md:col-span-9">
          <p class="font-display text-ink text-xl md:text-2xl leading-snug" style="font-weight: 500;">
            <em class="text-rust">"The post-loss locker room walk to the car."</em>
          </p>
          <p class="font-display text-ink-soft mt-2 leading-snug">
            What I've learned from watching parents handle the worst 90 seconds of a kid's week. By Maren.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Archive -->
  <section>
    <div class="container-px py-16">
      <div class="t-label text-rust mb-4">Issue archive</div>
      <div class="grid md:grid-cols-2 gap-x-10 gap-y-3">
        {issues.map((a) => {
          const sport = SPORTS.find(s => s.slug === a.data.sport)?.label ?? a.data.sport ?? '';
          const age = AGE_BANDS.find(x => x.slug === a.data.age)?.label;
          const meta = [sport, age ? `Age ${age}` : null].filter(Boolean).join(' / ');
          const date = a.data.publishedAt.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
          const titleHtml = a.data.title.replace(/\*([^*]+)\*/g, '<em>$1</em>');
          return (
            <a href={`/${a.data.phase}/${a.slug}/`} class="border-b border-bone py-3 flex flex-col gap-1 hover:bg-paper-warm">
              <span class="t-label text-ink-soft">
                #{String(a.data.issue ?? 0).padStart(3, '0')} · {date}{meta ? ' · ' + meta : ''}
              </span>
              <span class="font-display text-ink text-xl leading-snug" set:html={titleHtml} />
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <NewsletterSignup />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { PILLARS, EDITORIAL, TOPICS, SPORTS, SITE } from '../data/site';
import { isLive, freshnessDate, wasUpdated } from '../lib/publishFilter';
import { renderTitle } from '../lib/title';

// "This Season" news items — 3 most recent non-draft entries.
const newsItems = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const NEWS_CATEGORY_LABELS: Record<string, string> = {
  'rule-change':  'Rule change',
  'equipment':    'Equipment',
  'registration': 'Registration',
  'season-dates': 'Season dates',
  'safety':       'Safety',
  'general':      'General',
};

const all = (await getCollection('articles', ({ data }) => isLive(data)))
  .sort((a, b) => freshnessDate(b.data).getTime() - freshnessDate(a.data).getTime());

// "Pinned at the Desk" — three reads to surface above the fold each week.
// Update PINNED_SLUGS when the Friday Letter ships. Falls back to most recent 3.
const PINNED_SLUGS: string[] = [
  'how-to-evaluate-a-summer-camp',
  'when-your-kid-doesnt-want-to-go-to-camp',
  'three-teams-in-one-summer',
];
const pinned = PINNED_SLUGS
  .map(s => all.find(a => a.id === s))
  .filter(Boolean) as typeof all;
const pinnedFinal = pinned.length === 3 ? pinned : all.slice(0, 3);

// Featured cornerstone — first essay marked featured, fallback to most recent.
const featured = all.find(a => a.data.featured && a.data.format === 'essay') ?? all[0];

// Latest 5 for the hero right-rail — excludes featured.
const latestRail = all.filter(a => a.id !== featured?.id).slice(0, 5);

// The "three drives" homepage section is specifically about the original
// drive-there/game/drive-home phases — team-parent is a separate content
// vertical with its own section elsewhere on this page, not a fourth drive.
const drives = [PILLARS['drive-there'], PILLARS.game, PILLARS['drive-home']];

const driveImages = [
  {
    src: '/illustrations/walk-to-the-field.webp',
    alt: 'A dad and son walking together through the parking lot toward the field at twilight.',
  },
  {
    src: '/illustrations/coach-setting-cones.webp',
    alt: 'A coach kneeling on the field at golden hour, setting up orange cones for a drill.',
  },
  {
    src: '/illustrations/the-car-ride-home.webp',
    alt: 'A dad driving with his young son in the passenger seat, soccer cleats in the foreground, sunset out the windshield.',
  },
];

// Sport hub grid — top 8 by broad popularity for homepage teaser.
// Order matches what most families will recognize first.
const FEATURED_SPORTS = [
  'baseball', 'soccer', 'basketball', 'football',
  'softball', 'volleyball', 'swimming', 'lacrosse-girls',
];
const featuredSports = FEATURED_SPORTS
  .map(slug => SPORTS.find(s => s.slug === slug))
  .filter(Boolean) as typeof SPORTS[number][];

// timeZone: 'UTC' required — publishedAt parses to midnight UTC.
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });

// WebSite schema with SearchAction.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.url}/search/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---
<BaseLayout>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  {/* ── HERO ─────────────────────────────────────────────────────────────── */}
  <section class="border-b border-bone relative overflow-hidden">
    <img
      src="/illustrations/sports-family-sideline.webp"
      alt="A family of four sitting close together on the sideline at a youth game, smiling."
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgba(250,246,238,0.95) 0%, rgba(250,246,238,0.90) 55%, rgba(250,246,238,0.70) 100%);"
      aria-hidden="true"
    ></div>
    <div class="container-px py-12 md:py-20 relative">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">

        {/* Hero copy */}
        <div class="lg:col-span-8">
          <p class="font-display-soft text-rust mb-4" style="font-weight: 600; letter-spacing: 0.04em;">
            Hi. So glad you found us.
          </p>
          <h1 class="font-display-soft text-ink text-[2.1rem] md:text-[3.75rem] leading-[1.1]" style="font-weight: 700;">
            You're the coach <span class="font-display italic text-rust font-medium">whether you asked for the job or not.</span>
          </h1>
          <p class="font-display-soft text-ink-soft text-lg md:text-xl mt-6 max-w-2xl leading-relaxed" style="font-weight: 400;">
            Every kid in every activity has a parent driving them home. That's the real game. Camps to find, gear that lasts, and what to say in the car.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/start-here/" class="btn">Start here</a>
            <a href="/sports/" class="btn btn-ghost">Browse by sport</a>
            <a href="https://parent-coach-playbook.kit.com/4b28f916b5" class="btn btn-ghost">Get the Friday Letter</a>
          </div>
          <p class="font-display italic text-ink-soft text-sm mt-5 font-medium">
            Written by the <a href="/about/" class="hover:text-rust underline-offset-2 hover:underline">{EDITORIAL.byline}</a>.
          </p>
        </div>

        {/* Latest reads rail */}
        <aside class="lg:col-span-4">
          <p class="font-display italic text-rust mb-2 font-medium">Latest</p>
          <h2 class="font-display text-ink text-xl leading-tight mb-4 font-medium">
            Right off the <em class="text-rust">desk</em>
          </h2>
          <ul class="border-t border-bone">
            {latestRail.map((a) => (
              <li>
                <a href={`/${a.data.phase}/${a.id}/`} class="block py-3 border-b border-bone hover:bg-paper-warm transition-colors group">
                  <p class="font-display italic text-rust text-xs font-medium">
                    {a.data.topic ? TOPICS.find(t => t.slug === a.data.topic)?.label : 'General'} · {wasUpdated(a.data) ? 'Updated ' : ''}{fmtDate(freshnessDate(a.data))}
                  </p>
                  <h3 class="font-display text-ink text-sm leading-snug mt-1 group-hover:text-rust transition-colors font-medium" set:html={renderTitle(a.data.title)} />
                </a>
              </li>
            ))}
          </ul>
          <p class="font-display italic text-rust text-sm mt-4 font-medium">
            <a href="/reads/" class="hover:underline">→ Browse the full archive</a>
          </p>
        </aside>
      </div>
    </div>
  </section>

  {/* ── THIS SEASON (news) ───────────────────────────────────────────────── */}
  {newsItems.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 md:py-12">
        <div class="flex items-baseline justify-between mb-6 flex-wrap gap-3">
          <div>
            <p class="font-display italic text-rust mb-1 font-medium">This Season</p>
            <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight font-medium">
              What's changing <em class="text-rust">right now</em>.
            </h2>
          </div>
          <a href="/news/" class="font-display italic text-rust text-sm hover:underline font-medium whitespace-nowrap">
            All updates →
          </a>
        </div>
        <ul class="grid md:grid-cols-3 gap-px bg-bone">
          {newsItems.map((item) => (
            <li>
              <a
                href={`/news/${item.id}/`}
                class="block bg-paper p-5 hover:bg-paper-warm transition-colors group h-full"
              >
                <p class="font-display italic text-rust text-xs font-medium mb-2">
                  {NEWS_CATEGORY_LABELS[item.data.category] ?? item.data.category}
                  {item.data.sport && <span> · {item.data.sport}</span>}
                </p>
                <h3 class="font-display text-ink text-base leading-snug group-hover:text-rust transition-colors font-medium">
                  {item.data.headline}
                </h3>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ── PINNED AT THE DESK ───────────────────────────────────────────────── */}
  <section class="border-b border-bone" style="background: #F2E2D5;">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-2 font-medium">Pinned at the Desk</p>
      <h2 class="font-display text-ink text-2xl md:text-3xl leading-tight max-w-2xl font-medium">
        What we're <em class="text-rust">reaching for</em> this week.
      </h2>
      <div class="mt-7 grid md:grid-cols-3 gap-px bg-bone">
        {pinnedFinal.map((p, i) => (
          <a
            href={`/${p.data.phase}/${p.id}/`}
            class="bg-paper p-6 group block hover:bg-paper-warm transition-colors"
            style={`transform: rotate(${(i - 1) * 0.4}deg);`}
          >
            <p class="font-display italic text-rust mb-2 text-xs font-medium">Pinned</p>
            <h3
              class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium"
              set:html={renderTitle(p.data.title)}
            />
            {p.data.dek && (
              <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{p.data.dek}</p>
            )}
            <p class="font-display italic text-ink-soft text-xs mt-3 font-medium">
              {wasUpdated(p.data) ? 'Updated ' : ''}{fmtDate(freshnessDate(p.data))}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ── BY SPORT ─────────────────────────────────────────────────────────── */}
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-12 md:py-16">
      <div class="flex items-end justify-between mb-8 flex-wrap gap-3">
        <div>
          <p class="font-display italic text-rust mb-2 font-medium">26 sports and activities</p>
          <h2 class="font-display text-ink text-3xl md:text-[2.75rem] leading-[1.05] font-medium">
            Find your <em class="text-rust">sport</em>.
          </h2>
          <p class="font-display text-ink-soft mt-3 max-w-xl leading-snug">
            Every article, drill, gear guide, season calendar, and recruiting note we have — organized by sport. Pick yours and the whole site filters to what's relevant.
          </p>
        </div>
        <a href="/sports/" class="t-cta whitespace-nowrap">All 26 sports →</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-bone">
        {featuredSports.map((sport) => (
          <a
            href={`/sports/${sport.slug}/`}
            class="bg-paper px-5 py-4 group hover:bg-[#F2E2D5] transition-colors block"
          >
            <h3 class="font-display text-ink text-base leading-tight group-hover:text-rust transition-colors font-medium">
              {sport.label}
            </h3>
            <p class="font-display italic text-rust text-xs mt-1 font-medium">→ Guide</p>
          </a>
        ))}
      </div>
      <p class="font-display italic text-ink-soft text-sm mt-5 font-medium">
        Don't see yours? <a href="/sports/" class="text-rust hover:underline">All sports including dance, theater, band, gymnastics, and more →</a>
      </p>
    </div>
  </section>

  {/* ── THREE DRIVES ─────────────────────────────────────────────────────── */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <div>
        <p class="font-display italic text-rust mb-2 font-medium">What makes this site different</p>
        <h2 class="font-display text-ink text-3xl md:text-[2.75rem] leading-[1.05] font-medium">
          Every game is <em class="text-rust">three drives</em>.
        </h2>
        <p class="font-display text-ink-soft text-lg mt-3 max-w-2xl leading-snug">
          The car ride there. The game itself. The car ride home. Most of the work as a parent — whether you're their coach or not — happens before the game starts or after the final whistle.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-bone mt-8">
        {drives.map((p, i) => (
          <a
            href={`/${p.slug}/`}
            class="group block transition-colors overflow-hidden"
            style={`background: ${p.accentBg};`}
          >
            <div class="aspect-[3/2] overflow-hidden bg-bone">
              <img
                src={driveImages[i].src}
                alt={driveImages[i].alt}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6 md:p-8">
              <div class="flex items-baseline gap-3 mb-3">
                <span class="font-display italic text-sm" style={`color: ${p.accent}; font-weight: 500;`}>
                  Drive {String(i + 1).padStart(2, '0')}
                </span>
                <span class="font-display italic text-ink-soft text-xs font-medium">
                  {p.eyebrow}
                </span>
              </div>
              <h3 class="font-display text-ink text-2xl md:text-3xl leading-tight group-hover:text-rust transition-colors font-medium">
                {p.label}
              </h3>
              <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
                {p.blurb}
              </p>
              <p class="font-display italic text-sm mt-5" style={`color: ${p.accent}; font-weight: 500;`}>
                → Read the {p.label.toLowerCase()} pieces
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ── PARENT-COACH ─────────────────────────────────────────────────────── */}
  <section class="border-b border-bone relative overflow-hidden" style="background: #2D2520; color: #FAF6EE;">
    <img
      src="/illustrations/empty-gym-after-practice.webp"
      alt="An empty high school gym in late afternoon light: basketball on the floor near the bench, Teamwork Respect Integrity banner on the wall."
      class="absolute inset-0 w-full h-full object-cover opacity-40"
      loading="lazy"
      decoding="async"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgba(45,37,32,0.94) 0%, rgba(45,37,32,0.82) 55%, rgba(45,37,32,0.55) 100%);"
      aria-hidden="true"
    ></div>
    <div class="container-px py-14 md:py-20 relative">
      <div class="grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-7">
          <p class="font-display italic mb-3 font-medium" style="color: #D4AB6A;">If you're also on the bench</p>
          <h2 class="font-display text-3xl md:text-[2.75rem] leading-[1.05] font-medium" style="color: #FAF6EE;">
            Coaching your kid's team is its <em class="italic" style="color: #C5713D;">own job</em>.
          </h2>
          <p class="font-display text-lg mt-4 max-w-xl leading-snug" style="color: #DDD2BD;">
            Most clinics don't cover the part where it's also your kid. The lineup at midnight. The walk to the dugout. The drive home, knowing they're not getting the truth from anyone else either. This is where those pieces live.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/parent-coach/" class="btn" style="background: #9E5228; border-color: #9E5228; color: #FAF6EE;">
              The parent-coach pieces
            </a>
            <a href="/coaching-tips/" class="btn btn-ghost" style="color: #FAF6EE; border-color: #DDD2BD;">
              Drills you can run
            </a>
          </div>
        </div>
        <ul class="lg:col-span-5 grid gap-1">
          <li>
            <a href="/game/coaching-your-own-kid-in-front-of-the-team/" class="block py-4 border-b group transition-colors" style="border-color: #5F5448;">
              <span class="font-display italic text-xs" style="color: #D4AB6A;">Essay</span>
              <h3 class="font-display text-xl leading-tight mt-1 font-medium" style="color: #FAF6EE;">
                Coaching your own kid <em class="italic" style="color: #D4AB6A;">in front of the team</em>
              </h3>
              <p class="font-display text-sm mt-1 leading-snug" style="color: #DDD2BD;">
                I made the lineup at midnight. Five seasons later, I think I have it figured out. Sort of.
              </p>
            </a>
          </li>
          <li>
            <a href="/drive-home/three-drives-one-relationship/" class="block py-4 border-b group transition-colors" style="border-color: #5F5448;">
              <span class="font-display italic text-xs" style="color: #D4AB6A;">Framework</span>
              <h3 class="font-display text-xl leading-tight mt-1 font-medium" style="color: #FAF6EE;">
                Three drives. <em class="italic" style="color: #D4AB6A;">One relationship.</em>
              </h3>
              <p class="font-display text-sm mt-1 leading-snug" style="color: #DDD2BD;">
                Why what happens in the car matters more than what happens on the field.
              </p>
            </a>
          </li>
          <li>
            <a href="/drive-home/the-you-should-be-assistant-coaching-pressure/" class="block py-4 group transition-colors">
              <span class="font-display italic text-xs" style="color: #D4AB6A;">Decision</span>
              <h3 class="font-display text-xl leading-tight mt-1 font-medium" style="color: #FAF6EE;">
                The <em class="italic" style="color: #D4AB6A;">"you should be assistant coaching"</em> pressure
              </h3>
              <p class="font-display text-sm mt-1 leading-snug" style="color: #DDD2BD;">
                Coach asked. Two parents asked. You're considering it. Read this first.
              </p>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* ── TOOLS GRID ───────────────────────────────────────────────────────── */}
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-2 font-medium">For the moment you're in</p>
      <h2 class="font-display text-ink text-3xl md:text-4xl leading-[1.07] max-w-3xl font-medium">
        Tools, not <em class="text-rust">advice columns</em>.
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-bone mt-8">
        <a href="/scripts/" class="bg-paper p-5 md:p-6 group block hover:bg-[#F5E9D2] transition-colors" style="border-top: 3px solid #D4AB6A;">
          <p class="font-display italic text-sm font-medium" style="color: #D4AB6A">Scripts</p>
          <h3 class="font-display text-ink text-lg md:text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            What to <em>actually</em> say.
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug hidden md:block">
            The first 90 seconds after a bad game. The night before tryouts. The post-cut text.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #D4AB6A">→ Scripts</p>
        </a>

        <a href="/decisions/" class="bg-paper p-5 md:p-6 group block hover:bg-[#F2E2D5] transition-colors" style="border-top: 3px solid #C5713D;">
          <p class="font-display italic text-rust text-sm font-medium">Decisions</p>
          <h3 class="font-display text-ink text-lg md:text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            The big calls, walked through.
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug hidden md:block">
            Travel ball or rec. Specialize or stay multi-sport. Quit or push through.
          </p>
          <p class="font-display italic text-rust text-sm mt-4 font-medium">→ Decisions</p>
        </a>

        <a href="/youth-sports-pendulum/" class="bg-paper p-5 md:p-6 group block hover:bg-[#EAEFE7] transition-colors" style="border-top: 3px solid #5C7459;">
          <p class="font-display italic text-sm font-medium" style="color: #5C7459">Pendulum</p>
          <h3 class="font-display text-ink text-lg md:text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            Where is your family right now?
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug hidden md:block">
            Fun-to-performance spectrum. The check-in that pulls families back from the edge.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #5C7459">→ Take the check-in</p>
        </a>

        <a href="/cost-calculator/" class="bg-paper p-5 md:p-6 group block hover:bg-paper-warm transition-colors" style="border-top: 3px solid #B0894A;">
          <p class="font-display italic text-sm font-medium" style="color: #B0894A">Cost calculator</p>
          <h3 class="font-display text-ink text-lg md:text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            What does a year <em>actually</em> cost?
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug hidden md:block">
            Pre-filled with national medians at every tier. Edit any line. Honest math either way.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #B0894A">→ Run your numbers</p>
        </a>
      </div>
    </div>
  </section>

  {/* ── FEATURED LONG READ ───────────────────────────────────────────────── */}
  {featured && (
    <section class="border-b border-bone">
      <div class="container-px py-14 md:py-16">
        <p class="font-display italic text-rust mb-3 font-medium">If you only read one thing</p>
        <a href={`/${featured.data.phase}/${featured.id}/`} class="block group max-w-3xl">
          <h2
            class="font-display text-ink text-4xl md:text-[3.5rem] leading-[1.05] group-hover:text-rust transition-colors font-medium"
            set:html={renderTitle(featured.data.title)}
          />
          {featured.data.dek && (
            <p class="font-display text-ink-soft text-xl mt-5 leading-snug max-w-2xl">
              {featured.data.dek}
            </p>
          )}
          <div class="t-cta mt-6">Read it →</div>
        </a>
      </div>
    </section>
  )}

  {/* ── NEWSLETTER ───────────────────────────────────────────────────────── */}
  <LeadMagnetCTA />

  <NewsletterSignup
    headline="One short note a week"
    blurb="The Friday Letter lands every Friday morning. One read, one idea, one thing worth passing on to the parent next to you in the bleachers. Free, always."
    buttonLabel="Get the Friday Letter"
  />
</BaseLayout>

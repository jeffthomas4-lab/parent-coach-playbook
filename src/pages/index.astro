---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { PILLARS, EDITORIAL } from '../data/site';
import { isLive } from '../lib/publishFilter';
import { renderTitle } from '../lib/title';

const all = (await getCollection('articles', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Featured cornerstone (the long read). Pick the first essay marked featured.
const featured = all.find(a => a.data.featured && a.data.format === 'essay') ?? all[0];
// The rest of the feed: most recent, excluding the featured. Six cards.
const feed = all.filter(a => a.slug !== featured?.slug).slice(0, 6);

const drives = Object.values(PILLARS);
---
<BaseLayout>
  {/* SECTION 1 of 6: HERO */}
  <section class="border-b border-bone">
    <div class="container-px py-14 md:py-20">
      <p class="font-display-soft text-rust mb-5" style="font-weight: 600; letter-spacing: 0.04em;">
        Hi. So glad you found us.
      </p>
      <h1 class="font-display-soft text-ink text-[2.25rem] md:text-[4rem] leading-[1.1] max-w-4xl" style="font-weight: 700;">
        Every parent is a coach. Some on the field. <span class="font-display italic text-rust font-medium">All at the dinner table after.</span>
      </h1>
      <p class="font-display-soft text-ink-soft text-xl md:text-2xl mt-7 max-w-2xl leading-relaxed" style="font-weight: 400;">
        A warm, honest place for parents in the middle of it. Youth sports, dance, theater, band, ballet, choir, whatever your kid is into this season. Short reads, kind voice, real moments.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/start-here/" class="btn">Start here</a>
        <a href="/about/" class="btn btn-ghost">About this site</a>
        <a href="/resources/drive-home-playbook/" class="btn btn-ghost">Get the free playbook</a>
      </div>
      <p class="font-display italic text-ink-soft text-sm mt-6 font-medium">
        Written by the <a href="/about/" class="hover:text-rust underline-offset-2 hover:underline">{EDITORIAL.byline}</a>.
      </p>
    </div>
  </section>

  {/* SECTION 2 of 6: THE THREE DRIVES (lead visual) */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <div>
        <p class="font-display italic text-rust mb-2 font-medium">The frame</p>
        <h2 class="font-display text-ink text-3xl md:text-[2.75rem] leading-[1.05] font-medium">
          Every game is <em class="text-rust">three drives</em>.
        </h2>
        <p class="font-display text-ink-soft text-lg mt-3 max-w-2xl leading-snug">
          The car ride there. The game itself. The car ride home. Most of the work as a parent, whether you're their coach or not, happens on the way there or back.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-px bg-bone mt-8">
        {drives.map((p, i) => (
          <a
            href={`/${p.slug}/`}
            class="group block p-7 md:p-8 transition-colors"
            style={`background: ${p.accentBg};`}
          >
            <div class="flex items-baseline gap-3 mb-4">
              <span class="font-display italic text-sm" style={`color: ${p.accent}; font-weight: 500;`}>
                Drive {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-display italic text-ink-soft text-xs font-medium">
                {p.eyebrow}
              </span>
            </div>
            <h3 class="font-display text-ink text-2xl md:text-3xl leading-tight group-hover:text-rust transition-colors font-medium">
              {p.label}
            </h3>
            <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
              {p.blurb}
            </p>
            <p class="font-display italic text-sm mt-5" style={`color: ${p.accent}; font-weight: 500;`}>
              → Read the {p.label.toLowerCase()} pieces
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* SECTION 3 of 6: FOUR-TILE ENTRY GRID. The four situations that send parents to the site. */}
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-2 font-medium">For the moment you're in</p>
      <h2 class="font-display text-ink text-3xl md:text-4xl leading-[1.07] max-w-3xl font-medium">
        Tools, not <em class="text-rust">advice columns</em>.
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-bone mt-8">
        <a href="/scripts/" class="bg-paper p-6 group block hover:bg-[#F5E9D2] transition-colors" style="border-top: 3px solid #D4AB6A;">
          <p class="font-display italic text-sm font-medium" style="color: #D4AB6A">Scripts</p>
          <h3 class="font-display text-ink text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            What to <em>actually</em> say.
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
            The first 90 seconds after a bad game. The night before tryouts. The post-cut text.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #D4AB6A">→ Browse the scripts</p>
        </a>

        <a href="/decisions/" class="bg-paper p-6 group block hover:bg-[#F2E2D5] transition-colors" style="border-top: 3px solid #C5713D;">
          <p class="font-display italic text-rust text-sm font-medium">Decisions</p>
          <h3 class="font-display text-ink text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            The big calls, walked through.
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
            Travel ball or rec. Specialize or stay multi-sport. Quit or push through.
          </p>
          <p class="font-display italic text-rust text-sm mt-4 font-medium">→ Walk through a decision</p>
        </a>

        <a href="/youth-sports-pendulum/" class="bg-paper p-6 group block hover:bg-[#EAEFE7] transition-colors" style="border-top: 3px solid #5C7459;">
          <p class="font-display italic text-sm font-medium" style="color: #5C7459">Pendulum</p>
          <h3 class="font-display text-ink text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            Where is your family, right now?
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
            Fun-to-performance spectrum. The check-in that pulls families back from the edge.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #5C7459">→ Take the check-in</p>
        </a>

        <a href="/cost-calculator/" class="bg-paper p-6 group block hover:bg-paper-warm transition-colors" style="border-top: 3px solid #B0894A;">
          <p class="font-display italic text-sm font-medium" style="color: #B0894A">Cost calculator</p>
          <h3 class="font-display text-ink text-xl leading-tight mt-2 group-hover:text-rust transition-colors font-medium">
            What does a year <em>actually</em> cost?
          </h3>
          <p class="font-display text-ink-soft text-sm mt-3 leading-snug">
            Pre-filled with national medians at every tier. Edit any line. Honest math either way.
          </p>
          <p class="font-display italic text-sm mt-4 font-medium" style="color: #B0894A">→ Run your numbers</p>
        </a>
      </div>
    </div>
  </section>

  {/* SECTION 4 of 6: FEATURED LONG READ */}
  {featured && (
    <section class="border-b border-bone">
      <div class="container-px py-14 md:py-16">
        <p class="font-display italic text-rust mb-3 font-medium">If you only read one thing</p>
        <a href={`/${featured.data.phase}/${featured.slug}/`} class="block group max-w-3xl">
          <h2
            class="font-display text-ink text-4xl md:text-[3.5rem] leading-[1.05] group-hover:text-rust transition-colors font-medium"
            set:html={renderTitle(featured.data.title)}
          />
          {featured.data.dek && (
            <p class="font-display text-ink-soft text-xl mt-5 leading-snug max-w-2xl">
              {featured.data.dek}
            </p>
          )}
          <div class="t-cta mt-6">Read it →</div>
        </a>
      </div>
    </section>
  )}

  {/* SECTION 5 of 6: LATEST FEED with age filter */}
  <section class="border-b border-bone">
    <div class="container-px py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 flex-wrap gap-3">
        <div>
          <p class="font-display italic text-rust mb-2 font-medium">Fresh off the desk</p>
          <h2 class="font-display text-ink text-3xl md:text-[2.75rem] leading-[1.05] font-medium">
            What's <em class="text-rust">new</em> this week.
          </h2>
        </div>
        <a href="/reads/" class="t-cta">See the archive →</a>
      </div>

      <div class="flex flex-wrap items-center gap-2 mb-6" data-age-filter>
        <span class="font-display italic text-ink-soft text-sm font-medium">Filter by your kid's age:</span>
        <button data-age="" class="font-display italic px-3 py-1 border border-ink bg-ink text-paper text-sm font-medium">All</button>
        <button data-age="5-7" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">5–7</button>
        <button data-age="8-10" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">8–10</button>
        <button data-age="11-12" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">11–12</button>
        <button data-age="13-14" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">13–14</button>
        <button data-age="15-plus" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">15+</button>
      </div>

      <div class="grid md:grid-cols-2 gap-x-10" data-feed>
        {feed.map((a) => (
          <div data-age-tag={a.data.age ?? 'all-ages'}>
            <ArticleCard
              href={`/${a.data.phase}/${a.slug}/`}
              format={a.data.format}
              sport={a.data.sport}
              age={a.data.age}
              phase={a.data.phase}
              title={a.data.title}
              dek={a.data.dek}
              publishedAt={a.data.publishedAt}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const bar = document.querySelector('[data-age-filter]');
    const feedEl = document.querySelector('[data-feed]');
    if (bar && feedEl) {
      bar.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.tagName !== 'BUTTON') return;
        bar.querySelectorAll('button').forEach(b => {
          b.classList.remove('bg-ink', 'text-paper', 'border-ink');
          b.classList.add('border-bone', 'text-ink-soft');
        });
        target.classList.remove('border-bone', 'text-ink-soft');
        target.classList.add('bg-ink', 'text-paper', 'border-ink');
        const age = target.getAttribute('data-age') ?? '';
        feedEl.querySelectorAll<HTMLElement>('[data-age-tag]').forEach((row) => {
          const tag = row.dataset.ageTag ?? '';
          if (!age || tag === age || tag === 'all-ages') {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  </script>

  {/* SECTION 6 of 6: LEAD MAGNET (component handles the layout) */}
  <LeadMagnetCTA />
</BaseLayout>

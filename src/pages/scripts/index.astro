---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';

export const prerender = true;

const scripts = (await getCollection('scripts', ({ data }) => isLive(data)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group scripts by moment phase for the hub layout.
const moments = [
  { group: 'After the game', slugs: ['after-a-bad-game','after-a-loss','after-a-win','after-no-playing-time','after-a-mistake','kid-upset','kid-silent','after-the-last-game'] },
  { group: 'Before the game', slugs: ['before-game-nerves','before-a-game','before-a-game-5-7','tryouts-week'] },
  { group: 'During the game', slugs: ['during-a-game'] },
  { group: 'Hard moments',    slugs: ['coach-conflict','teammate-conflict','injury'] },
];

// Several scripts share the same `moment` value (e.g. sport-specific
// "after a bad game" variants). Prefer an exact slug match first so a
// curated slug that is also a real filename (after-a-win, after-a-bad-game,
// before-a-game-5-7) always resolves to that specific page, not whichever
// same-moment script happens to sort first alphabetically.
const grouped = moments.map(g => ({
  ...g,
  items: g.slugs
    .map(s => scripts.find(x => x.slug === s) ?? scripts.find(x => x.data.moment === s))
    .filter(Boolean) as typeof scripts,
})).filter(g => g.items.length > 0);
---
<BaseLayout
  title="Scripts: what to say in the moments that matter"
  description="Short, scriptable pages for parents in real moments. The exact words to say after a bad game, after a win, after no playing time, after a mistake. Built for the car ride."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Parent-Coach Scripts',
    url: 'https://parentcoachdesk.com/scripts/',
    applicationCategory: 'EducationalApplication',
    operatingSystem: 'Web',
    description: 'A library of short, scriptable conversation guides for parents in real youth sports moments — what to say after a bad game, a loss, no playing time, a mistake, before nerves, and more.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  })} />
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Scripts</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] max-w-3xl font-medium">
        What to say in the <em class="text-rust">moments that matter</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Short pages for the car ride home. What they're feeling. What to say. What not to say. The one rule. Built to be read in 30 seconds and saved for the next time.
      </p>
      <p class="font-display italic text-ink-soft text-sm mt-6 max-w-2xl leading-snug font-medium">
        Pick the moment you're in. Or download <a href="/resources/what-to-say-when/" class="text-rust hover:underline">What to Say When</a>, our free field guide, to keep all of these in your glove box.
      </p>
    </div>
  </section>

  {grouped.length === 0 ? (
    <section><div class="container-px py-12">
      <p class="font-display italic text-ink-soft font-medium">Scripts ship this week.</p>
    </div></section>
  ) : (
    grouped.map((g) => (
      <section class="border-b border-bone">
        <div class="container-px py-10 md:py-12">
          <p class="font-display italic text-rust mb-4 font-medium">{g.group}</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-bone">
            {g.items.map((s) => (
              <a href={`/scripts/${s.slug}/`} class="bg-paper p-6 group block hover:bg-paper-warm transition-colors">
                <h2 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium" set:html={renderTitle(s.data.title)} />
                <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{s.data.summary}</p>
                <p class="t-cta mt-3">30-second read →</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))
  )}

  <!-- The big idea -->
  <section class="border-b border-bone bg-ink text-paper">
    <div class="container-px py-14 max-w-3xl">
      <p class="font-display italic mb-3 text-sm font-medium" style="color: #D4AB6A">The rule under all of this</p>
      <p class="font-display text-paper text-2xl md:text-3xl leading-snug font-medium">
        The car ride is not for coaching. It's for connection.
      </p>
      <p class="font-display text-paper-warm mt-4 leading-relaxed">
        These scripts are tools, not formulas. The point isn't to say the perfect line. The point is to make the car a place your kid wants to be after a hard day.
      </p>
    </div>
  </section>
</BaseLayout>

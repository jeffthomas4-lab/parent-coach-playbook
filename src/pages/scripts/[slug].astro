---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadMagnetCTA from '../../components/LeadMagnetCTA.astro';
import HowToSchema from '../../components/HowToSchema.astro';
import { SITE, EDITORIAL, authorEntity } from '../../data/site';
import { serializeJsonLd } from '../../lib/jsonld';
import { isLive } from '../../lib/publishFilter';
import { renderTitle, stripTitle } from '../../lib/title';

export async function getStaticPaths() {
  const scripts = await getCollection('scripts', ({ data }) => isLive(data));
  return scripts.map((s) => ({ params: { slug: s.id }, props: { script: s } }));
}

const { script } = Astro.props;
const { Content } = await render(script);

// Pull the related scripts the author flagged.
const allScripts = await getCollection('scripts', ({ data }) => isLive(data));
const related = (script.data.relatedScripts ?? [])
  .map(slug => allScripts.find(s => s.id === slug))
  .filter(Boolean) as typeof allScripts;

// Article + Breadcrumb schema for SERP visibility. Author entity is resolved
// via authorEntity() — Organization until November, Person after the flip.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: stripTitle(script.data.title),
  description: script.data.summary,
  author: authorEntity(),
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  datePublished: script.data.publishedAt.toISOString(),
  mainEntityOfPage: `${SITE.url}/scripts/${script.id}/`,
};

// HowTo schema models the conversation playbook as ordered steps:
// recognize the feeling → say one of these → stop talking → respond if they
// bring it up. Steps come from the structured frontmatter, not the body.
const howToSteps: { name: string; text: string }[] = [];
if (script.data.whatTheyAreFeeling.length > 0) {
  howToSteps.push({
    name: 'Notice what they are feeling',
    text: script.data.whatTheyAreFeeling.join(' '),
  });
}
if (script.data.whatToSay.length > 0) {
  howToSteps.push({
    name: 'Say one of these',
    text: script.data.whatToSay.map(line => `"${line}"`).join(' Or: '),
  });
}
howToSteps.push({
  name: 'Then stop talking',
  text: 'Let the silence sit. Do not fill it with more words.',
});
if (script.data.ifTheyBringItUp.length > 0) {
  howToSteps.push({
    name: 'If they bring it up',
    text: script.data.ifTheyBringItUp.join(' '),
  });
}
if (script.data.theRule) {
  howToSteps.push({ name: 'The rule', text: script.data.theRule });
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Scripts', item: `${SITE.url}/scripts/` },
    { '@type': 'ListItem', position: 3, name: stripTitle(script.data.title) },
  ],
};
---
<BaseLayout
  title={script.data.seoTitle ?? stripTitle(script.data.title)}
  description={script.data.seoDescription ?? script.data.summary}
>
  <script slot="head" type="application/ld+json" set:html={serializeJsonLd(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={serializeJsonLd(breadcrumbSchema)} />
  {howToSteps.length >= 2 && (
    <HowToSchema
      slot="head"
      name={`How to: ${stripTitle(script.data.title)}`}
      description={script.data.summary}
      steps={howToSteps}
    />
  )}
  <!-- Hero -->
  <section class="border-b border-bone">
    <div class="container-px py-10 md:py-14">
      <p class="font-display italic text-rust mb-3 font-medium">
        <a href="/scripts/" class="hover:underline">Scripts</a>
      </p>
      <h1 class="font-display text-ink text-[2.25rem] md:text-[3.25rem] leading-[1.05] max-w-3xl font-medium" set:html={renderTitle(script.data.title)} />
      <p class="font-display text-ink-soft text-xl mt-5 max-w-2xl leading-snug">
        {script.data.summary}
      </p>
    </div>
  </section>

  <!-- Section 1: What they're feeling -->
  {script.data.whatTheyAreFeeling.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 max-w-3xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">What they're feeling</p>
        <ul class="grid gap-2">
          {script.data.whatTheyAreFeeling.map((f) => (
            <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {f}</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Section 2: What to say -->
  {script.data.whatToSay.length > 0 && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-10 max-w-3xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">What to say (pick one)</p>
        <ul class="grid gap-3">
          {script.data.whatToSay.map((line) => (
            <li class="font-display text-ink text-lg italic leading-snug pl-4 border-l-2 border-rust" style="font-weight: 400;">"{line}"</li>
          ))}
        </ul>
        <p class="font-display italic text-ink-soft text-sm mt-5 font-medium">
          Then stop talking.
        </p>
      </div>
    </section>
  )}

  <!-- Section 3: What NOT to say -->
  {script.data.whatNotToSay.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 max-w-3xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">What not to say</p>
        <ul class="grid gap-2">
          {script.data.whatNotToSay.map((line) => (
            <li class="font-display text-ink-soft leading-snug line-through" style="font-weight: 400;">"{line}"</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Section 4: The rule -->
  <section class="border-b border-bone bg-ink text-paper">
    <div class="container-px py-12 max-w-3xl">
      <p class="font-display italic mb-3 text-sm font-medium" style="color: #D4AB6A">The rule</p>
      <p class="font-display text-paper text-2xl md:text-3xl leading-snug font-medium">
        {script.data.theRule}
      </p>
    </div>
  </section>

  <!-- Section 5: If they bring it up -->
  {script.data.ifTheyBringItUp.length > 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-10 max-w-3xl">
        <p class="font-display italic text-rust mb-3 text-sm font-medium">If they bring it up</p>
        <ul class="grid gap-2">
          {script.data.ifTheyBringItUp.map((line) => (
            <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {line}</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Section 6: Save block -->
  {script.data.saveBlockBullets.length > 0 && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-10 max-w-3xl">
        <div class="border-2 border-ink p-6 bg-paper">
          <p class="font-display italic text-rust mb-2 text-sm font-medium">Pin this</p>
          <h2 class="font-display text-ink text-xl mb-4 font-medium">
            {script.data.saveBlockTitle ?? stripTitle(script.data.title)}
          </h2>
          <ul class="grid gap-2">
            {script.data.saveBlockBullets.map((b) => (
              <li class="font-display text-ink leading-snug" style="font-weight: 400;">· {b}</li>
            ))}
          </ul>
          <p class="font-display italic text-ink-soft text-xs mt-5 font-medium">
            parentcoachdesk.com/scripts
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Optional markdown body -->
  {script.body && script.body.trim().length > 0 && (
    <article class="container-px py-10 md:py-12">
      <div class="article-body max-w-prose mx-auto">
        <Content />
      </div>
    </article>
  )}

  <!-- Related scripts (You might also need) -->
  {related.length > 0 && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-10">
        <p class="font-display italic text-rust mb-4 font-medium">You might also need</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-bone">
          {related.map((r) => (
            <a href={`/scripts/${r.id}/`} class="bg-paper p-5 group block hover:bg-paper-warm transition-colors">
              <h3 class="font-display text-ink text-lg leading-tight group-hover:text-rust transition-colors font-medium" set:html={renderTitle(r.data.title)} />
              <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{r.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <LeadMagnetCTA />
</BaseLayout>

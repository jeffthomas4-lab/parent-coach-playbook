---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS } from '../../data/site';
import TopicIcon from '../../components/TopicIcon.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';

// Get all published articles
const all = (await getCollection('articles', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Latest 6 articles across all topics
const latest = all.slice(0, 6);

// For each topic, get the count and most recent article
const topicData = TOPICS.map(topic => {
  const articles = all.filter(a => a.data.topic === topic.slug);
  return {
    ...topic,
    count: articles.length,
    recent: articles[0] || null,
  };
});

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout
  title="Reads"
  description="The full archive of articles, organized by topic. Browse the latest pieces, then dive into your topic."
>
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3" style="font-weight: 500;">Reads</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0]" style="font-weight: 500;">
        Articles, organized by <em class="text-rust">topic</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Start with what's new, then pick a topic. Each section has everything we've written on that subject, filterable by age.
      </p>
    </div>
  </section>

  {/* Latest 6 */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-14">
      <p class="font-display italic text-rust mb-6" style="font-weight: 500;">Latest</p>
      <div class="grid md:grid-cols-3 gap-px bg-bone" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
        {latest.map((a) => (
          <a
            href={`/${a.data.phase}/${a.slug}/`}
            class="bg-paper p-6 group block hover:bg-paper-warm transition-colors"
          >
            {a.data.hero && (
              <img
                src={a.data.hero}
                alt={a.data.heroAlt || a.data.title}
                class="w-full h-40 object-cover rounded mb-4 group-hover:opacity-90 transition-opacity"
              />
            )}
            <p class="font-display italic text-rust text-xs mb-2" style="font-weight: 500;">
              {a.data.topic ? TOPICS.find(t => t.slug === a.data.topic)?.label : 'General'}
            </p>
            <h3 class="font-display text-ink text-lg leading-tight group-hover:text-rust transition-colors" style="font-weight: 500;" set:html={renderTitle(a.data.title)} />
            {a.data.dek && (
              <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{a.data.dek}</p>
            )}
            <p class="font-display italic text-ink-soft text-xs mt-3" style="font-weight: 500;">
              {fmtDate(a.data.publishedAt)}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Topic grid 3x3 */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-14">
      <p class="font-display italic text-rust mb-6" style="font-weight: 500;">Browse by topic</p>
      <div class="grid md:grid-cols-3 gap-4">
        {topicData.map((t) => (
          <a
            href={`/reads/${t.slug}/`}
            class="border border-bone bg-paper p-6 hover:bg-paper-warm transition-colors group"
          >
            <TopicIcon topic={t.slug} size={48} class="mb-4" />
            <h2 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors" style="font-weight: 500;">
              {t.label}
            </h2>
            <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{t.blurb}</p>
            <div class="mt-4 pt-4 border-t border-bone">
              <p class="font-display italic text-ink-soft text-xs mb-2" style="font-weight: 500;">
                {t.count} {t.count === 1 ? 'piece' : 'pieces'}
              </p>
              {t.recent && (
                <p class="font-display text-ink text-sm leading-snug group-hover:text-rust transition-colors">
                  <span class="font-semibold">Latest:</span> <span set:html={renderTitle(t.recent.data.title)} />
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

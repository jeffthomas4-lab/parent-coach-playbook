---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS } from '../../data/site';
import TopicIcon from '../../components/TopicIcon.astro';
import { isLive } from '../../lib/publishFilter';
import { renderTitle } from '../../lib/title';

// Get all published articles
const all = (await getCollection('articles', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Body & Safety hub. Top-line tile on /reads/, sits with the topic grid as a
// peer entry point even though /body/ is its own URL space and collection.
const bodyAll = (await getCollection('body', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const bodyTile = {
  slug: 'body',
  label: 'Body & Safety',
  blurb: 'Concussion, arm care, sleep, heat, growth plates. Plus the safety canon coming online: equipment certs, lightning, league vetting.',
  count: bodyAll.length,
  recent: bodyAll[0] || null,
};

// Latest 8 for the right rail (slim list)
const latest = all.slice(0, 8);

// For each topic, get the count and most recent article
const topicData = TOPICS.map(topic => {
  const articles = all.filter(a => a.data.topic === topic.slug);
  return {
    ...topic,
    count: articles.length,
    recent: articles[0] || null,
  };
});

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---
<BaseLayout
  title="Reads"
  description="The full archive, organized by topic. Browse by what's on your mind, or scan the latest pieces."
>
  {/* Hero + inline search */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <p class="font-display italic text-rust mb-3 font-medium">Reads</p>
      <h1 class="font-display text-ink text-[2.5rem] md:text-[4rem] leading-[1.0] font-medium">
        Articles, organized by <em class="text-rust">topic</em>.
      </h1>
      <p class="font-display text-ink-soft text-xl md:text-2xl mt-6 max-w-2xl leading-snug">
        Pick a topic. Each section has everything we've written on that subject, filterable by age. Or scan what's new in the right rail.
      </p>

      <p class="font-display italic mt-5 max-w-2xl text-ink" style="font-size: 1.05rem;">
        Are you the parent-coach? <a href="/parent-coach/" class="text-rust hover:text-ink underline-offset-2 hover:underline">More for you here →</a>
      </p>

      {/* Inline search — submits to /search/ with the query in the URL */}
      <form action="/search/" method="get" class="mt-8 max-w-2xl">
        <label for="reads-search" class="font-display italic text-ink-soft text-sm font-medium block mb-2">
          Looking for something specific? Search the whole site.
        </label>
        <div class="flex gap-0">
          <input
            id="reads-search"
            type="search"
            name="q"
            placeholder="Try: tryouts, recruiting, concussion, AAU, gear, cost..."
            class="flex-1 px-4 py-3 font-body bg-paper border border-ink focus:border-rust focus:outline-none"
          />
          <button type="submit" class="btn" style="border-radius: 0;">
            Search
          </button>
        </div>
        <p class="font-display italic text-ink-soft text-xs mt-2 font-medium">
          Searches every read, drill, gear guide, body topic, pathway, calendar, recruiting page, rule, script, and decision on the site.
        </p>
      </form>
    </div>
  </section>

  {/* Two-column: topics on the left, latest on the right rail */}
  <section class="border-b border-bone">
    <div class="container-px py-12 md:py-16">
      <div class="grid lg:grid-cols-12 gap-10">
        {/* LEFT: Browse by topic grid */}
        <div class="lg:col-span-8">
          <p class="font-display italic text-rust mb-2 font-medium">Browse by topic</p>
          <h2 class="font-display text-ink text-3xl md:text-[2.5rem] leading-[1.05] font-medium mb-7">
            Pick what's <em class="text-rust">on your mind</em>.
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {/* Body & Safety hub — top-line tile, leads the grid. Same shape as the topic tiles below so the grid reads as one set. */}
            <a
              href="/body/"
              class="border border-bone bg-paper p-6 hover:bg-paper-warm transition-colors group"
            >
              <TopicIcon topic="body" size={48} class="mb-4" />
              <h3 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium">
                {bodyTile.label}
              </h3>
              <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{bodyTile.blurb}</p>
              <div class="mt-4 pt-4 border-t border-bone">
                <p class="font-display italic text-ink-soft text-xs mb-2 font-medium">
                  {bodyTile.count} {bodyTile.count === 1 ? 'piece' : 'pieces'}
                </p>
                {bodyTile.recent && (
                  <p class="font-display text-ink text-sm leading-snug group-hover:text-rust transition-colors">
                    <span class="font-semibold">Latest:</span> <span set:html={renderTitle(bodyTile.recent.data.title)} />
                  </p>
                )}
              </div>
            </a>

            {topicData.map((t) => (
              <a
                href={`/reads/${t.slug}/`}
                class="border border-bone bg-paper p-6 hover:bg-paper-warm transition-colors group"
              >
                <TopicIcon topic={t.slug} size={48} class="mb-4" />
                <h3 class="font-display text-ink text-xl leading-tight group-hover:text-rust transition-colors font-medium">
                  {t.label}
                </h3>
                <p class="font-display text-ink-soft text-sm mt-2 leading-snug">{t.blurb}</p>
                <div class="mt-4 pt-4 border-t border-bone">
                  <p class="font-display italic text-ink-soft text-xs mb-2 font-medium">
                    {t.count} {t.count === 1 ? 'piece' : 'pieces'}
                  </p>
                  {t.recent && (
                    <p class="font-display text-ink text-sm leading-snug group-hover:text-rust transition-colors">
                      <span class="font-semibold">Latest:</span> <span set:html={renderTitle(t.recent.data.title)} />
                    </p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* RIGHT RAIL: Latest reads */}
        <aside class="lg:col-span-4">
          <div class="lg:sticky lg:top-6">
            <p class="font-display italic text-rust mb-2 font-medium">Latest</p>
            <h2 class="font-display text-ink text-2xl md:text-[1.75rem] leading-[1.1] font-medium mb-5">
              What's <em class="text-rust">new</em>.
            </h2>
            <ul class="border-t border-bone">
              {latest.map((a) => (
                <li>
                  <a
                    href={`/${a.data.phase}/${a.slug}/`}
                    class="block py-4 border-b border-bone hover:bg-paper-warm transition-colors group"
                  >
                    <p class="font-display italic text-rust text-xs font-medium">
                      {a.data.topic ? TOPICS.find(t => t.slug === a.data.topic)?.label : 'General'} · {fmtDate(a.data.publishedAt)}
                    </p>
                    <h3 class="font-display text-ink text-base leading-snug mt-1 group-hover:text-rust transition-colors font-medium" set:html={renderTitle(a.data.title)} />
                  </a>
                </li>
              ))}
            </ul>
            <p class="font-display italic text-rust text-sm mt-4 font-medium">
              <a href="/rss.xml" class="hover:underline">→ RSS feed</a>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

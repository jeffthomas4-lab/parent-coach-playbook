---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listApprovedUnverifiedCamps, setVerified, rejectCamp, type Camp } from '../../../lib/camps-db';
import { requireAdmin, requireSameOrigin } from '../../../lib/admin-auth';
import {
  formatCampDateRange,
  formatImportedAt,
  formatCampLocation,
  formatCampDescription,
} from '../../../lib/camps-display';
import { env as cfEnv } from 'cloudflare:workers';

// SSR. Pulls live from D1 each request. Behind Cloudflare Access.
export const prerender = false;

const env = cfEnv as { DB: D1Database; ADMIN_EMAILS?: string } | undefined;

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;
const adminEmail = auth.email;

// Handle verify/reject POSTs in-page. Form posts to this same URL with a
// hidden `action` field. requireAdmin() above already gates both GET and
// POST on the same ADMIN_EMAILS allowlist the API routes use; the
// same-origin check below is additional CSRF defense, not the primary gate.
let actionBanner: { ok: boolean; text: string } | null = null;
if (Astro.request.method === 'POST') {
  const originErr = requireSameOrigin(Astro.request);
  if (originErr) {
    actionBanner = { ok: false, text: 'Cross-origin request blocked.' };
  } else if (!env?.DB) {
    actionBanner = { ok: false, text: 'Database not bound; action ignored.' };
  } else {
    try {
      const fd = await Astro.request.formData();
      const action = String(fd.get('action') ?? '').trim();
      const id = String(fd.get('camp_id') ?? '').trim();
      const reviewer = adminEmail || 'spot-check (cookie auth)';
      if (!id) {
        actionBanner = { ok: false, text: 'Missing camp id.' };
      } else if (action === 'verify') {
        await setVerified(env.DB, id, true);
        actionBanner = { ok: true, text: 'Verified.' };
      } else if (action === 'reject') {
        await rejectCamp(env.DB, id, reviewer, null);
        actionBanner = { ok: true, text: 'Rejected.' };
      } else {
        actionBanner = { ok: false, text: `Unknown action: ${action}` };
      }
    } catch (e) {
      console.error('spot-check action failed', e);
      actionBanner = { ok: false, text: 'Action failed; check the server logs.' };
    }
  }
}

let camps: Camp[] = [];
let dbAvailable = !!env?.DB;
// Distinguish "the query failed" from "the queue is genuinely empty". The
// existing catch is preserved (a query error must never take the route down),
// but a failure now surfaces a visible operator notice instead of silently
// rendering the all-caught-up state, which would hide a real outage.
let queryError = false;
if (env?.DB) {
  try {
    camps = await listApprovedUnverifiedCamps(env.DB);
  } catch (e) {
    console.error('listApprovedUnverifiedCamps failed', e);
    queryError = true;
  }
}

// Build a null-safe view model per camp up front, so the template never calls
// .split / .length / Date parsing on a nullable legacy directory row. Legacy
// rows migrated from the shared activity-radar D1 can have NULL start_date,
// end_date, description, address, and submitted_at even though the Camp type
// says otherwise; the helpers in camps-display.ts absorb that.
const campViews = camps.map((c) => ({
  camp: c,
  dateRange: formatCampDateRange(c.start_date, c.end_date),
  importedAt: formatImportedAt(c.submitted_at),
  location: formatCampLocation(c),
  description: formatCampDescription(c.description),
}));
---
<AdminLayout title="Spot check" description="Approved-but-unverified camps awaiting personal review" email={adminEmail} detail={queryError ? 'Queue query failed — see notice below.' : `${campViews.length} camps awaiting spot check.`}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        Admin · <a href="/admin/camps/" class="hover:underline">Pending</a> · <a href="/admin/camps/queue" class="hover:underline">Queue</a> · Spot check
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Spot check queue
      </h1>
      <p class="font-display text-ink-soft mt-3 max-w-2xl leading-snug">
        Camps that are live on the site but haven't been personally verified yet. Click each one's website link, confirm the details still match, then mark verified. Once verified the camp drops off this list and gets the Verified ✓ badge on the public page.
      </p>
      {actionBanner && (
        <p class={`font-display text-sm mt-2 font-medium ${actionBanner.ok ? 'text-sage' : 'text-rust'}`}>
          {actionBanner.text}
        </p>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      {!dbAvailable ? (
        <p class="font-display italic text-ink-soft font-medium">Database is not bound. Confirm D1 binding in wrangler.jsonc.</p>
      ) : queryError ? (
        <p class="font-display italic text-rust font-medium">
          Couldn't load the spot-check queue — the camps query failed. This is a server-side error, not an empty queue; check the server logs and retry. Nothing has been changed.
        </p>
      ) : campViews.length === 0 ? (
        <p class="font-display italic text-ink-soft font-medium">All caught up. Every approved camp has been spot-checked.</p>
      ) : (
        <ul class="grid gap-4">
          {campViews.map((v) => (
            <li class="border border-bone p-5 bg-paper">
              <div class="flex items-baseline justify-between flex-wrap gap-3">
                <div class="flex-1 min-w-0">
                  <p class="font-display italic text-rust text-xs font-medium">
                    {v.camp.sport} · ages {v.camp.age_min}–{v.camp.age_max} · {v.dateRange}{v.camp.program_type === 'league' ? ' · league' : ''}{v.camp.spots_status === 'full' ? ' · full' : v.camp.spots_status === 'waitlist' ? ' · waitlist' : ''}
                  </p>
                  <h3 class="font-display text-ink text-xl leading-tight mt-0.5 font-medium">{v.camp.name}</h3>
                  <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                    {v.location} · imported {v.importedAt}
                  </p>
                  {v.camp.website_url && (
                    <p class="font-display text-sm mt-1">
                      <a href={v.camp.website_url} target="_blank" rel="noopener noreferrer" class="text-rust hover:underline font-medium">{v.camp.website_url} ↗</a>
                    </p>
                  )}
                  {v.camp.price_text && (
                    <p class="font-display italic text-rust text-xs mt-1 font-medium">{v.camp.price_text}</p>
                  )}
                  {v.description.empty ? (
                    <p class="font-display italic text-ink-soft text-sm mt-2 leading-snug font-medium">No description provided.</p>
                  ) : (
                    <p class="font-display text-ink-soft text-sm mt-2 leading-snug max-w-3xl" style="white-space: pre-wrap;">
                      {v.description.text}
                    </p>
                  )}
                </div>
                <div class="flex flex-col gap-2 items-end">
                  <a href={`/camps/${v.camp.slug}/`} target="_blank" rel="noopener noreferrer" class="font-display italic text-rust text-sm hover:underline font-medium">View on site ↗</a>
                  <a href={`/admin/camps/${v.camp.id}/`} class="t-cta">Edit →</a>
                  <form method="POST" action="/admin/camps/spot-check" class="inline">
                    <input type="hidden" name="action" value="verify" />
                    <input type="hidden" name="camp_id" value={v.camp.id} />
                    <button type="submit" class="font-display italic px-3 py-1 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium">Mark verified ✓</button>
                  </form>
                  <form method="POST" action="/admin/camps/spot-check" class="inline">
                    <input type="hidden" name="action" value="reject" />
                    <input type="hidden" name="camp_id" value={v.camp.id} />
                    <button type="submit" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium">Reject</button>
                  </form>
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</AdminLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  listPendingCamps,
  listPendingReviews,
  listPendingClaims,
  getCampById,
  findFuzzyCampMatches,
  REJECT_REASON_CODES,
  type Camp,
  type CampReview,
  type CampClaim,
  type FuzzyMatchResult,
} from '../../../lib/camps-db';
import { getAdminEmailFromRequest } from '../../../lib/admin-auth';

export const prerender = false;

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
const adminEmail = getAdminEmailFromRequest(Astro.request);

let pendingCamps: Camp[] = [];
let pendingReviews: CampReview[] = [];
let pendingClaims: CampClaim[] = [];
const campLookup = new Map<string, Camp>();
const fuzzyByCamp = new Map<string, FuzzyMatchResult[]>();
let dbAvailable = !!env?.DB;

if (env?.DB) {
  try {
    pendingCamps = await listPendingCamps(env.DB);
    pendingReviews = await listPendingReviews(env.DB);
    pendingClaims = await listPendingClaims(env.DB);

    const allCampIds = new Set<string>();
    pendingReviews.forEach((r) => allCampIds.add(r.camp_id));
    pendingClaims.forEach((c) => allCampIds.add(c.camp_id));

    for (const campId of allCampIds) {
      const camp = await getCampById(env.DB, campId);
      if (camp) campLookup.set(campId, camp);
    }

    for (const camp of pendingCamps) {
      const matches = await findFuzzyCampMatches(env.DB, {
        name: camp.name,
        city: camp.city,
        state: camp.state,
        zip: camp.zip,
        address: camp.address,
        website_url: camp.website_url,
      });
      fuzzyByCamp.set(
        camp.id,
        matches.filter((m) => m.camp.id !== camp.id),
      );
    }
  } catch (e) {
    console.error('admin queue fetch failed', e);
  }
}

const confidenceTone: Record<string, string> = {
  high: 'border-sage bg-sage-bg text-sage',
  medium: 'border-bone bg-paper-warm text-ink-soft',
  low: 'border-rust bg-paper-warm text-rust',
};

const urlHealthTone: Record<string, string> = {
  live: 'border-sage bg-sage-bg text-sage',
  redirect: 'border-bone bg-paper-warm text-ink-soft',
  unchecked: 'border-bone bg-paper-warm text-ink-soft',
  dead: 'border-rust bg-paper-warm text-rust',
  timeout: 'border-rust bg-paper-warm text-rust',
};

const fmt = (s: string) =>
  new Date(s).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const fmtRange = (start: string, end: string) => {
  const [, sm, sd] = start.split('-').map(Number);
  const [ey, em, ed] = end.split('-').map(Number);
  return `${MONTHS[sm - 1]} ${sd}–${MONTHS[em - 1]} ${ed}, ${ey}`;
};
---

<BaseLayout title="Admin queue" description="Unified moderation dashboard" noindex={true}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        <a href="/admin/camps/" class="hover:underline">Pending</a> · Queue · <a href="/admin/camps/spot-check" class="hover:underline">Spot check</a> · <a href="/admin/source-quality" class="hover:underline">Source quality</a>
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Moderation queue
      </h1>
      {!adminEmail && (
        <p class="font-display italic text-rust text-sm mt-2 font-medium">
          Cloudflare Access header not detected. Actions will fail until /admin/* is wired through Access.
        </p>
      )}
    </div>
  </section>

  {!dbAvailable ? (
    <section>
      <div class="container-px py-10">
        <p class="font-display italic text-ink-soft font-medium">Database not bound.</p>
      </div>
    </section>
  ) : (
    <>
      <section class="border-b border-bone">
        <div class="container-px py-10">
          <div class="flex items-baseline justify-between gap-4 mb-6">
            <h2 class="font-display text-ink text-2xl font-medium">
              Pending camp submissions
            </h2>
            <span class="font-display italic text-rust text-sm bg-paper-warm px-2 py-1 border border-bone font-medium">
              {pendingCamps.length}
            </span>
          </div>

          {pendingCamps.length === 0 ? (
            <p class="font-display italic text-ink-soft font-medium">All clear, no camps awaiting review.</p>
          ) : (
            <ul class="grid gap-4">
              {pendingCamps.map((camp) => {
                const fuzzy = fuzzyByCamp.get(camp.id) ?? [];
                return (
                <li class="border border-bone p-5 bg-paper camp-row" data-id={camp.id}>
                  <div class="grid gap-4">
                    <div>
                      <p class="font-display italic text-rust text-xs font-medium">
                        {camp.sport} · ages {camp.age_min}–{camp.age_max} · {camp.day_or_overnight}
                      </p>
                      <h3 class="font-display text-ink text-lg leading-tight mt-0.5 font-medium">
                        {camp.name}
                      </h3>
                      <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                        {camp.city}, {camp.state} · {fmtRange(camp.start_date, camp.end_date)}
                      </p>

                      <div class="flex flex-wrap items-center gap-2 mt-2 text-xs font-display font-medium">
                        <span class={`px-2 py-0.5 border ${confidenceTone[camp.confidence] ?? confidenceTone.medium}`}>
                          confidence: {camp.confidence}
                        </span>
                        {camp.source_domain && (
                          <span class="px-2 py-0.5 border border-bone bg-paper-warm text-ink-soft">
                            source: {camp.source_domain}
                          </span>
                        )}
                        <span class={`px-2 py-0.5 border ${urlHealthTone[camp.url_health_status] ?? urlHealthTone.unchecked}`}>
                          url: {camp.url_health_status}{camp.url_last_status_code ? ` (${camp.url_last_status_code})` : ''}
                        </span>
                        {camp.awaiting_review === 1 && (
                          <span class="px-2 py-0.5 border border-rust bg-paper-warm text-rust">
                            live · awaiting review
                          </span>
                        )}
                      </div>

                      {fuzzy.length > 0 && (
                        <div class="mt-3 p-3 border border-rust bg-paper-warm">
                          <p class="font-display italic text-rust text-xs font-medium mb-1">
                            Possible duplicate{fuzzy.length === 1 ? '' : 's'} ({fuzzy.length}):
                          </p>
                          <ul class="text-xs text-ink-soft font-body grid gap-1">
                            {fuzzy.slice(0, 5).map((m) => (
                              <li>
                                <a href={`/camps/${m.camp.slug}/`} target="_blank" rel="noopener" class="underline">
                                  {m.camp.name}
                                </a>{' '}
                                <span class="text-ink-soft">
                                  ({m.camp.city}, {m.camp.state} · {m.camp.status} · matched: {m.reason})
                                </span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>

                    <div class="grid gap-3 text-sm">
                      <div class="grid gap-1">
                        <label class="font-display text-ink-soft italic text-xs font-medium">Website</label>
                        <input type="url" class="px-2 py-1 font-body bg-paper border border-bone text-sm" value={camp.website_url || ''} placeholder="https://..." data-field="website_url" />
                      </div>

                      <div class="grid gap-1">
                        <label class="font-display text-ink-soft italic text-xs font-medium">Contact email</label>
                        <input type="email" class="px-2 py-1 font-body bg-paper border border-bone text-sm" value={camp.contact_email || ''} placeholder="email@example.com" data-field="contact_email" />
                      </div>

                      <div class="grid gap-1">
                        <label class="font-display text-ink-soft italic text-xs font-medium">Description</label>
                        <textarea class="px-2 py-1 font-body bg-paper border border-bone text-sm" rows="3" data-field="description">{camp.description}</textarea>
                      </div>

                      <div class="grid gap-1">
                        <label class="font-display text-ink-soft italic text-xs font-medium">Submitted by</label>
                        <p class="text-ink-soft">{camp.submitted_by_email}</p>
                      </div>

                      <div class="grid gap-1">
                        <label class="font-display text-ink-soft italic text-xs font-medium">Submitted {fmt(camp.submitted_at)}</label>
                      </div>
                    </div>

                    <div class="reject-reason-row gap-2 p-3 border border-bone bg-paper-warm" style="display: none;">
                      <label class="font-display italic text-ink-soft text-xs font-medium">
                        Reject reason (recorded for source-quality stats)
                      </label>
                      <select class="px-2 py-1 font-body bg-paper border border-bone text-sm" data-field="reason_code">
                        <option value="">— pick a reason —</option>
                        {REJECT_REASON_CODES.map((r) => (
                          <option value={r.code}>{r.label}</option>
                        ))}
                      </select>
                      <input type="text" class="px-2 py-1 font-body bg-paper border border-bone text-sm" placeholder="optional notes" data-field="reject_notes" />
                      <div class="flex gap-2">
                        <button type="button" class="font-display italic px-3 py-1 border border-rust bg-paper text-rust text-sm hover:bg-rust hover:text-paper transition-colors font-medium" data-action="reject-confirm">
                          Confirm reject
                        </button>
                        <button type="button" class="font-display italic px-3 py-1 border border-bone bg-paper text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium" data-action="reject-cancel">
                          Cancel
                        </button>
                      </div>
                    </div>

                    <div class="grid gap-2 sm:grid-cols-4">
                      <div class="col-span-1">
                        <button type="button" class="w-full font-display italic px-3 py-2 border border-bone bg-paper-warm text-sm hover:bg-paper transition-colors font-medium" data-action="approve-verified">
                          Approve & verify
                        </button>
                      </div>
                      <div class="col-span-1">
                        <button type="button" class="w-full font-display italic px-3 py-2 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium" data-action="approve">
                          Approve
                        </button>
                      </div>
                      <div class="col-span-1">
                        <button type="button" class="w-full font-display italic px-3 py-2 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium" data-action="reject">
                          Reject
                        </button>
                      </div>
                      <div class="col-span-1">
                        <label class="font-display italic px-3 py-2 border border-bone bg-paper text-sm text-center cursor-pointer hover:bg-paper-warm transition-colors block font-medium">
                          Photo
                          <input type="file" class="hidden" accept="image/*" data-action="upload-photo" />
                        </label>
                      </div>
                    </div>

                    <div class="status-message text-xs text-rust font-display italic" style="display: none;"></div>
                  </div>
                </li>
                );
              })}
            </ul>
          )}
        </div>
      </section>

      <section class="border-b border-bone">
        <div class="container-px py-10">
          <div class="flex items-baseline justify-between gap-4 mb-6">
            <h2 class="font-display text-ink text-2xl font-medium">
              Pending camp reviews
            </h2>
            <span class="font-display italic text-rust text-sm bg-paper-warm px-2 py-1 border border-bone font-medium">
              {pendingReviews.length}
            </span>
          </div>

          {pendingReviews.length === 0 ? (
            <p class="font-display italic text-ink-soft font-medium">All clear, no reviews awaiting action.</p>
          ) : (
            <ul class="grid gap-4">
              {pendingReviews.map((review) => {
                const camp = campLookup.get(review.camp_id);
                return (
                  <li class="border border-bone p-5 bg-paper review-row" data-id={review.id}>
                    <div class="grid gap-3">
                      <div>
                        <p class="font-display text-ink-soft text-sm font-medium">
                          {camp ? camp.name : 'Unknown camp'} · Rating: <strong>{review.rating}/5</strong>
                        </p>
                        <p class="font-display italic text-ink-soft text-xs mt-1 font-medium">
                          By {review.reviewer_email} {review.reviewer_display_name ? `(${review.reviewer_display_name})` : ''} · {fmt(review.submitted_at)}
                        </p>
                      </div>

                      <p class="font-body text-ink text-sm leading-snug" style="white-space: pre-wrap; max-height: 120px; overflow-y: auto;">
                        {review.body}
                      </p>

                      <div class="grid gap-2 sm:grid-cols-2">
                        <button type="button" class="font-display italic px-3 py-2 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium" data-action="approve">
                          Approve
                        </button>
                        <button type="button" class="font-display italic px-3 py-2 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium" data-action="reject">
                          Reject
                        </button>
                      </div>

                      <div class="status-message text-xs text-rust font-display italic" style="display: none;"></div>
                    </div>
                  </li>
                );
              })}
            </ul>
          )}
        </div>
      </section>

      <section>
        <div class="container-px py-10">
          <div class="flex items-baseline justify-between gap-4 mb-6">
            <h2 class="font-display text-ink text-2xl font-medium">
              Pending claim requests
            </h2>
            <span class="font-display italic text-rust text-sm bg-paper-warm px-2 py-1 border border-bone font-medium">
              {pendingClaims.length}
            </span>
          </div>

          {pendingClaims.length === 0 ? (
            <p class="font-display italic text-ink-soft font-medium">All clear, no claims awaiting action.</p>
          ) : (
            <ul class="grid gap-4">
              {pendingClaims.map((claim) => {
                const camp = campLookup.get(claim.camp_id);
                return (
                  <li class="border border-bone p-5 bg-paper claim-row" data-id={claim.id}>
                    <div class="grid gap-3">
                      <div>
                        <p class="font-display italic text-rust text-xs font-medium">
                          Status: {claim.status}
                        </p>
                        <p class="font-display text-ink text-lg leading-tight mt-1 font-medium">
                          {camp ? camp.name : 'Unknown camp'}
                        </p>
                        <p class="font-display text-ink-soft text-sm mt-2 leading-snug">
                          Claimant: <strong>{claim.claimant_email}</strong>
                          {claim.claimant_name && <> · {claim.claimant_name}</>}
                          {claim.organization && <> · {claim.organization}</>}
                          {claim.phone && <> · {claim.phone}</>}
                        </p>
                        {claim.notes && (
                          <p class="font-body text-ink text-sm mt-2 leading-snug" style="white-space: pre-wrap;">
                            <strong>Notes:</strong> {claim.notes}
                          </p>
                        )}
                        <p class="font-display italic text-ink-soft text-xs mt-2 font-medium">
                          Submitted {fmt(claim.submitted_at)}
                        </p>
                      </div>

                      <div class="grid gap-2 sm:grid-cols-3">
                        <button type="button" class="font-display italic px-3 py-2 border border-paper-warm bg-paper-warm text-sm hover:bg-paper transition-colors font-medium" data-action="mark-verified">
                          Mark verified
                        </button>
                        <button type="button" class="font-display italic px-3 py-2 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium" data-action="mark-paid">
                          Mark paid
                        </button>
                        <button type="button" class="font-display italic px-3 py-2 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium" data-action="reject">
                          Reject
                        </button>
                      </div>

                      <div class="status-message text-xs text-rust font-display italic" style="display: none;"></div>
                    </div>
                  </li>
                );
              })}
            </ul>
          )}
        </div>
      </section>
    </>
  )}
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.camp-row').forEach(function (row) {
      const campId = row.getAttribute('data-id');
      const statusDiv = row.querySelector('.status-message');
      const rejectRow = row.querySelector('.reject-reason-row');

      row.querySelectorAll('[data-action]').forEach(function (btn) {
        if (btn.type === 'file') return;

        btn.addEventListener('click', async function (e) {
          e.preventDefault();
          const action = this.getAttribute('data-action');

          if (action === 'reject') {
            if (rejectRow) rejectRow.style.display = 'grid';
            return;
          }
          if (action === 'reject-cancel') {
            if (rejectRow) rejectRow.style.display = 'none';
            return;
          }

          let endpoint, body;

          if (action === 'approve-verified') {
            endpoint = '/api/admin/camps/' + campId + '/approve';
            body = JSON.stringify({ notes: null });
            await fetch('/api/admin/camps/' + campId + '/verify', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ verified: true }),
            });
          } else if (action === 'approve') {
            endpoint = '/api/admin/camps/' + campId + '/approve';
            body = JSON.stringify({ notes: null });
          } else if (action === 'reject-confirm') {
            const reasonSelect = row.querySelector('select[data-field="reason_code"]');
            const notesInput = row.querySelector('input[data-field="reject_notes"]');
            const reasonCode = reasonSelect && reasonSelect.value ? reasonSelect.value : null;
            const notes = notesInput && notesInput.value.trim() ? notesInput.value.trim() : null;
            if (!reasonCode) {
              statusDiv.textContent = 'Pick a reject reason first.';
              statusDiv.style.display = 'block';
              return;
            }
            endpoint = '/api/admin/camps/' + campId + '/reject';
            body = JSON.stringify({ notes: notes, reason_code: reasonCode });
          } else {
            return;
          }

          try {
            const resp = await fetch(endpoint, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: body,
            });
            const data = await resp.json();

            if (data.ok) {
              statusDiv.textContent = action === 'reject-confirm' ? 'Rejected' : 'Approved';
              statusDiv.style.display = 'block';
              setTimeout(function () {
                row.style.opacity = '0.5';
                setTimeout(function () { row.remove(); }, 300);
              }, 500);
            } else {
              statusDiv.textContent = 'Error: ' + (data.error || 'unknown');
              statusDiv.style.display = 'block';
            }
          } catch (err) {
            statusDiv.textContent = 'Error: ' + (err instanceof Error ? err.message : 'network error');
            statusDiv.style.display = 'block';
          }
        });
      });

      const photoInput = row.querySelector('input[type="file"]');
      if (photoInput) {
        photoInput.addEventListener('change', async function () {
          if (this.files && this.files.length > 0) {
            const fd = new FormData();
            fd.append('file', this.files[0]);

            try {
              const resp = await fetch('/api/admin/camps/' + campId + '/photo', {
                method: 'POST',
                body: fd,
              });
              const data = await resp.json();

              if (data.ok) {
                statusDiv.textContent = 'Photo uploaded';
              } else {
                statusDiv.textContent = 'Photo error: ' + (data.error || 'unknown');
              }
              statusDiv.style.display = 'block';
            } catch (err) {
              statusDiv.textContent = 'Photo error: ' + (err instanceof Error ? err.message : 'network error');
              statusDiv.style.display = 'block';
            }
          }
        });
      }
    });

    document.querySelectorAll('.review-row').forEach(function (row) {
      const reviewId = row.getAttribute('data-id');
      const statusDiv = row.querySelector('.status-message');

      row.querySelectorAll('[data-action]').forEach(function (btn) {
        btn.addEventListener('click', async function (e) {
          e.preventDefault();
          const action = this.getAttribute('data-action');
          const endpoint = action === 'approve' ? '/api/admin/reviews/' + reviewId + '/approve' : '/api/admin/reviews/' + reviewId + '/reject';

          try {
            const resp = await fetch(endpoint, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ notes: null }),
            });
            const data = await resp.json();

            if (data.ok) {
              statusDiv.textContent = action === 'approve' ? 'Approved' : 'Rejected';
              statusDiv.style.display = 'block';
              setTimeout(function () {
                row.style.opacity = '0.5';
                setTimeout(function () { row.remove(); }, 300);
              }, 500);
            } else {
              statusDiv.textContent = 'Error: ' + (data.error || 'unknown');
              statusDiv.style.display = 'block';
            }
          } catch (err) {
            statusDiv.textContent = 'Error: ' + (err instanceof Error ? err.message : 'network error');
            statusDiv.style.display = 'block';
          }
        });
      });
    });

    document.querySelectorAll('.claim-row').forEach(function (row) {
      const claimId = row.getAttribute('data-id');
      const statusDiv = row.querySelector('.status-message');

      row.querySelectorAll('[data-action]').forEach(function (btn) {
        btn.addEventListener('click', async function (e) {
          e.preventDefault();
          const action = this.getAttribute('data-action');
          let status;

          if (action === 'mark-verified') status = 'verified';
          else if (action === 'mark-paid') status = 'paid';
          else if (action === 'reject') status = 'rejected';
          else return;

          try {
            const resp = await fetch('/api/admin/claims/' + claimId + '/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ status: status, notes: null }),
            });
            const data = await resp.json();

            if (data.ok) {
              statusDiv.textContent = 'Updated: ' + status;
              statusDiv.style.display = 'block';
              setTimeout(function () {
                row.style.opacity = '0.5';
                setTimeout(function () { row.remove(); }, 300);
              }, 500);
            } else {
              statusDiv.textContent = 'Error: ' + (data.error || 'unknown');
              statusDiv.style.display = 'block';
            }
          } catch (err) {
            statusDiv.textContent = 'Error: ' + (err instanceof Error ? err.message : 'network error');
            statusDiv.style.display = 'block';
          }
        });
      });
    });
  });
</script>

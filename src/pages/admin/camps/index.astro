---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { listPendingCamps, type Camp } from '../../../lib/camps-db';
import { getAdminEmailFromRequest } from '../../../lib/admin-auth';

// SSR. Pulls live from D1 each request. Wrap in Cloudflare Access policy.
export const prerender = false;

const env = (Astro.locals as any).runtime?.env as { DB: D1Database } | undefined;
const adminEmail = getAdminEmailFromRequest(Astro.request);

// If Access is not configured (dev mode), still render the queue but warn.
let camps: Camp[] = [];
let dbAvailable = !!env?.DB;
if (env?.DB) {
  try {
    camps = await listPendingCamps(env.DB);
  } catch (e) {
    console.error('listPendingCamps failed', e);
  }
}

const fmtDateTime = (s: string) =>
  new Date(s).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });

const fmtRange = (start: string, end: string) => {
  const s = new Date(start);
  const e = new Date(end);
  return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
};
---
<BaseLayout title="Camps moderation" description="Admin queue" noindex={true}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2" style="font-weight: 500;">Admin · Camps</p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight" style="font-weight: 500;">
        Moderation queue
      </h1>
      {adminEmail ? (
        <p class="font-display italic text-ink-soft text-sm mt-2" style="font-weight: 500;">
          Logged in as {adminEmail}.
        </p>
      ) : (
        <p class="font-display italic text-rust text-sm mt-2" style="font-weight: 500;">
          Cloudflare Access header not detected. Approve/reject will fail. Configure /admin/* behind Access before deploying.
        </p>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      {!dbAvailable ? (
        <p class="font-display italic text-ink-soft" style="font-weight: 500;">Database is not bound. Confirm D1 binding in wrangler.jsonc.</p>
      ) : camps.length === 0 ? (
        <p class="font-display italic text-ink-soft" style="font-weight: 500;">Queue is empty. No camps awaiting review.</p>
      ) : (
        <ul class="grid gap-4">
          {camps.map((c) => (
            <li class="border border-bone p-5 bg-paper">
              <div class="flex items-baseline justify-between flex-wrap gap-3">
                <div>
                  <p class="font-display italic text-rust text-xs" style="font-weight: 500;">
                    {c.sport} · ages {c.age_min}–{c.age_max} · {fmtRange(c.start_date, c.end_date)}
                  </p>
                  <h3 class="font-display text-ink text-xl leading-tight mt-0.5" style="font-weight: 500;">{c.name}</h3>
                  <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                    {c.city}, {c.state} · submitted by {c.submitted_by_email} · {fmtDateTime(c.submitted_at)}
                  </p>
                  <p class="font-display text-ink-soft text-sm mt-2 leading-snug max-w-2xl" style="white-space: pre-wrap;">
                    {c.description.length > 280 ? c.description.slice(0, 280) + '…' : c.description}
                  </p>
                </div>
                <div class="flex flex-col gap-2 items-end">
                  <a href={`/admin/camps/${c.id}/`} class="t-cta">Review →</a>
                  <form method="POST" action={`/api/admin/camps/${c.id}/approve`} class="inline">
                    <button type="submit" class="font-display italic px-3 py-1 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors" style="font-weight: 500;">Approve</button>
                  </form>
                  <form method="POST" action={`/api/admin/camps/${c.id}/reject`} class="inline">
                    <button type="submit" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors" style="font-weight: 500;">Reject</button>
                  </form>
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

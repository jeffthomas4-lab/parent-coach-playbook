---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listPendingCamps, type Camp } from '../../../lib/camps-db';
import { formatCampDateRange, formatCampDescription, formatImportedAt } from '../../../lib/camps-display';
import { requireAdmin } from '../../../lib/admin-auth';
import { env as cfEnv } from 'cloudflare:workers';

// SSR. Pulls live from D1 each request. Wrap in Cloudflare Access policy.
export const prerender = false;

const env = cfEnv as { DB: D1Database; ADMIN_EMAILS?: string } | undefined;

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;
const adminEmail = auth.email;

let camps: Camp[] = [];
let dbAvailable = !!env?.DB;
if (env?.DB) {
  try {
    camps = (await listPendingCamps(env.DB)).map((camp) => ({
      ...camp,
      description: formatCampDescription(camp.description, Number.POSITIVE_INFINITY).text,
    }));
  } catch (e) {
    console.error('listPendingCamps failed', e);
  }
}

const fmtDateTime = (s: string) =>
  formatImportedAt(s);

// start_date / end_date are nullable on the live Camp type (296 approved
// programs carry a null session_start_date or session_end_date); formatCampDateRange
// is already null-safe, so fmtRange just passes the nullable values through.
const fmtRange = (start: string | null, end: string | null) => formatCampDateRange(start, end);
---
<AdminLayout title="Camps moderation" description="Admin queue" email={adminEmail}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        Admin · Pending · <a href="/admin/camps/queue" class="hover:underline">Queue</a> · <a href="/admin/camps/spot-check" class="hover:underline">Spot check</a> · <a href="/admin/source-quality" class="hover:underline">Source quality</a> · <a href="/admin/claims/" class="hover:underline">Claims</a> · <a href="/admin/suggestions/" class="hover:underline">Suggestions</a>
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Pending camps
      </h1>
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      {!dbAvailable ? (
        <p class="font-display italic text-ink-soft font-medium">Database is not bound. Confirm D1 binding in wrangler.jsonc.</p>
      ) : camps.length === 0 ? (
        <p class="font-display italic text-ink-soft font-medium">Queue is empty. No camps awaiting review.</p>
      ) : (
        <ul class="grid gap-4">
          {camps.map((c) => (
            <li class="border border-bone p-5 bg-paper">
              <div class="flex items-baseline justify-between flex-wrap gap-3">
                <div>
                  <p class="font-display italic text-rust text-xs font-medium">
                    {c.sport} · ages {c.age_min}–{c.age_max} · {fmtRange(c.start_date, c.end_date)}
                  </p>
                  <h3 class="font-display text-ink text-xl leading-tight mt-0.5 font-medium">{c.name}</h3>
                  <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                    {c.city}, {c.state} · submitted by {c.submitted_by_email} · {fmtDateTime(c.submitted_at)}
                  </p>
                  <p class="font-display text-ink-soft text-sm mt-2 leading-snug max-w-2xl" style="white-space: pre-wrap;">
                    {c.description.length > 280 ? c.description.slice(0, 280) + '…' : c.description}
                  </p>
                </div>
                <div class="flex flex-col gap-2 items-end">
                  <a href={`/admin/camps/${c.id}/`} class="t-cta">Review →</a>
                  <form method="POST" action={`/api/admin/camps/${c.id}/approve`} class="inline">
                    <button type="submit" class="font-display italic px-3 py-1 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium">Approve</button>
                  </form>
                  <form method="POST" action={`/api/admin/camps/${c.id}/reject`} class="inline">
                    <button type="submit" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm transition-colors font-medium">Reject</button>
                  </form>
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</AdminLayout>

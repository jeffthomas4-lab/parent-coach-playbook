---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { isLive } from '../../../lib/publishFilter';
import refreshQueue from '../../../../reports/editorial/editorial-refresh-queue.json';

export const prerender = true;

// Pull every reviewable collection. Each row gets normalized to a common shape so the
// table can render without per-collection branching.
const articles    = await getCollection('articles');
const body        = await getCollection('body');
const pathways    = await getCollection('pathways');
const calendars   = await getCollection('seasonCalendars');
const guides      = await getCollection('guides');
const resources   = await getCollection('resources');
const tips        = await getCollection('coachingTips');
const recruiting  = await getCollection('recruiting');
const adaptive    = await getCollection('adaptive');
const rules       = await getCollection('rules');
const scripts     = await getCollection('scripts');
const decisions   = await getCollection('decisions');

type Row = {
  collection: string;
  slug: string;
  title: string;
  url: string;
  publishedAt: Date;
  draft: boolean;
  editorial?: any;
};

const urlFor = (collection: string, item: any): string => {
  switch (collection) {
    case 'articles':       return `/${item.data.phase}/${item.id}/`;
    case 'body':           return `/body/${item.id}/`;
    case 'pathways':       return `/pathways/${item.data.sport}/`;
    case 'seasonCalendars':return `/season-calendar/${item.id}/`;
    case 'guides':         return `/what-to-buy/${item.id}/`;
    case 'resources':      return `/team-parent/${item.id}/`;
    case 'coachingTips':   return `/coaching-tips/${item.id}/`;
    case 'recruiting':     return `/recruiting/${item.id}/`;
    case 'adaptive':       return `/adaptive/${item.id}/`;
    case 'rules':          return `/rules/${item.data.sport}/`;
    case 'scripts':        return `/scripts/${item.id}/`;
    case 'decisions':      return `/decisions/${item.id}/`;
    default:               return `/${item.id}/`;
  }
};

const titleFor = (item: any): string => item.data.title || item.data.activity || item.id;

// If the piece is live, link to its public URL. Otherwise, link to the
// admin preview route so Jeff can read drafts and queued pieces.
const linkFor = (collection: string, item: any): string => {
  if (isLive(item.data)) return urlFor(collection, item);
  return `/admin/preview/${collection}/${item.id}/`;
};

const rows: Row[] = [
  ...articles.map(i =>   ({ collection: 'articles',       slug: i.id, title: titleFor(i), url: linkFor('articles', i),       publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...body.map(i =>       ({ collection: 'body',           slug: i.id, title: titleFor(i), url: linkFor('body', i),           publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...pathways.map(i =>   ({ collection: 'pathways',       slug: i.id, title: titleFor(i), url: linkFor('pathways', i),       publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...calendars.map(i =>  ({ collection: 'seasonCalendars',slug: i.id, title: titleFor(i), url: linkFor('seasonCalendars', i),publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...guides.map(i =>     ({ collection: 'guides',         slug: i.id, title: titleFor(i), url: linkFor('guides', i),         publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...resources.map(i =>  ({ collection: 'resources',      slug: i.id, title: titleFor(i), url: linkFor('resources', i),      publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...tips.map(i =>       ({ collection: 'coachingTips',   slug: i.id, title: titleFor(i), url: linkFor('coachingTips', i),   publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...recruiting.map(i => ({ collection: 'recruiting',     slug: i.id, title: titleFor(i), url: linkFor('recruiting', i),     publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...adaptive.map(i =>   ({ collection: 'adaptive',       slug: i.id, title: titleFor(i), url: linkFor('adaptive', i),       publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...rules.map(i =>      ({ collection: 'rules',          slug: i.id, title: titleFor(i), url: linkFor('rules', i),          publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...scripts.map(i =>    ({ collection: 'scripts',        slug: i.id, title: titleFor(i), url: linkFor('scripts', i),        publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
  ...decisions.map(i =>  ({ collection: 'decisions',      slug: i.id, title: titleFor(i), url: linkFor('decisions', i),      publishedAt: i.data.publishedAt, draft: !!i.data.draft, editorial: (i.data as any).editorial })),
].sort((a, b) => b.publishedAt.getTime() - a.publishedAt.getTime());

// Top-line stats
const total = rows.length;
const claudeReviewed = rows.filter(r => r.editorial?.status === 'claude-reviewed' || r.editorial?.status === 'jeff-approved' || r.editorial?.status === 'published').length;
const jeffApproved   = rows.filter(r => r.editorial?.status === 'jeff-approved' || r.editorial?.status === 'published').length;
const flagged        = rows.filter(r => r.editorial?.flagInappropriateness || r.editorial?.flagIpRisk).length;
const needsRevision  = rows.filter(r => r.editorial?.status === 'needs-revision').length;
const pctClaude = Math.round((claudeReviewed / total) * 100) || 0;
const pctJeff   = Math.round((jeffApproved / total) * 100) || 0;

const fmtDate = (d: Date | undefined) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';
const fmtGrade = (n: number | undefined) => n === undefined ? '—' : `${n}/10`;

const statusColor: Record<string, string> = {
  'draft':            '#B8908F',
  'claude-reviewed':  '#D4AB6A',
  'jeff-approved':    '#5C7459',
  'published':        '#5C7459',
  'needs-revision':   '#9E5228',
};
---
<BaseLayout title="Editorial dashboard" description="Per-piece editorial state across the site.">
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">Admin · Editorial</p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Editorial review board
      </h1>
      <p class="font-display text-ink-soft mt-3 max-w-2xl leading-snug">
        Every URL on the site, with its current editorial state. Filter, sort, and click through to read the piece.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-bone mt-6">
        <div class="bg-paper p-4">
          <p class="font-display italic text-ink-soft text-xs font-medium">Total</p>
          <p class="font-display text-ink text-2xl mt-1 font-medium">{total}</p>
        </div>
        <div class="bg-paper p-4">
          <p class="font-display italic text-ink-soft text-xs font-medium">Claude-reviewed</p>
          <p class="font-display text-ink text-2xl mt-1 font-medium">{claudeReviewed} <span class="font-display italic text-ink-soft text-sm">({pctClaude}%)</span></p>
        </div>
        <div class="bg-paper p-4">
          <p class="font-display italic text-ink-soft text-xs font-medium">Jeff-approved</p>
          <p class="font-display text-ink text-2xl mt-1 font-medium">{jeffApproved} <span class="font-display italic text-ink-soft text-sm">({pctJeff}%)</span></p>
        </div>
        <div class="bg-paper p-4">
          <p class="font-display italic text-ink-soft text-xs font-medium">Flagged</p>
          <p class="font-display text-ink text-2xl mt-1 font-medium">{flagged}</p>
        </div>
        <div class="bg-paper p-4">
          <p class="font-display italic text-ink-soft text-xs font-medium">Needs revision</p>
          <p class="font-display text-ink text-2xl mt-1 font-medium">{needsRevision}</p>
        </div>
      </div>

      <div class="mt-6 border border-bone bg-paper-warm p-4" data-refresh-summary>
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="font-display text-ink text-lg font-medium">18-month refresh queue</h2>
          <p class="font-display italic text-ink-soft text-xs font-medium">Snapshot {refreshQueue.as_of}</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-3">
          <div><p class="font-display italic text-ink-soft text-xs font-medium">Live articles</p><p class="font-display text-ink text-xl font-medium">{refreshQueue.summary.live_articles}</p></div>
          <div><p class="font-display italic text-ink-soft text-xs font-medium">Refresh due</p><p class="font-display text-ink text-xl font-medium">{refreshQueue.summary.refresh_due}</p></div>
          <div><p class="font-display italic text-ink-soft text-xs font-medium">Fact check due</p><p class="font-display text-ink text-xl font-medium">{refreshQueue.summary.fact_check_due}</p></div>
          <div><p class="font-display italic text-ink-soft text-xs font-medium">Affiliate review set</p><p class="font-display text-ink text-xl font-medium">{refreshQueue.summary.affiliate_link_review}</p></div>
        </div>
        <p class="font-display text-ink-soft text-xs mt-3 leading-relaxed">
          This queue never redirects or deletes content. Decommissioning still requires reviewed live traffic, an emitted-link audit, supersession evidence, and a human decision.
        </p>
      </div>

      <!-- Filter bar -->
      <div class="mt-6 flex flex-wrap gap-2 text-sm font-display italic font-medium" data-filter-bar>
        <button data-filter="all"             class="px-3 py-1 border border-ink bg-ink text-paper">All</button>
        <button data-filter="needs-review"    class="px-3 py-1 border border-bone text-ink-soft hover:bg-paper-warm">Needs review</button>
        <button data-filter="claude-reviewed" class="px-3 py-1 border border-bone text-ink-soft hover:bg-paper-warm">Claude reviewed</button>
        <button data-filter="jeff-approved"   class="px-3 py-1 border border-bone text-ink-soft hover:bg-paper-warm">Jeff approved</button>
        <button data-filter="flagged"         class="px-3 py-1 border border-bone text-ink-soft hover:bg-paper-warm">Flagged</button>
        <button data-filter="needs-revision"  class="px-3 py-1 border border-bone text-ink-soft hover:bg-paper-warm">Needs revision</button>
      </div>
    </div>
  </section>

  <section>
    <div class="container-px py-6">
      <table class="w-full text-sm" data-editorial-table>
        <thead>
          <tr class="border-b border-bone">
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Title</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Section</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Status</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Q</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">O</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">V</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Flags</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Claude</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Jeff</th>
            <th scope="col" class="text-left py-2 pr-3 font-display italic text-rust font-medium">Action</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => {
            const status = r.editorial?.status || 'draft';
            const flags = [
              r.editorial?.flagInappropriateness ? 'INAPPROP' : null,
              r.editorial?.flagIpRisk ? 'IP' : null,
              r.editorial?.flagSensitiveTopic ? 'SENS' : null,
              r.editorial?.citationCheckPassed ? null : 'NOCITE',
            ].filter(Boolean).join(' ');
            const flagged = !!(r.editorial?.flagInappropriateness || r.editorial?.flagIpRisk);
            return (
              <tr class="border-b border-bone hover:bg-paper-warm" data-status={status} data-flagged={flagged}>
                <td class="py-2 pr-3">
                  <a href={r.url} class="font-display text-ink hover:text-rust font-medium">{r.title}</a>
                  {r.draft && <span class="ml-2 font-display italic text-ink-soft text-xs font-medium">[draft]</span>}
                </td>
                <td class="py-2 pr-3 font-display italic text-ink-soft text-xs font-medium">{r.collection}</td>
                <td class="py-2 pr-3">
                  <span class="font-display italic px-2 py-0.5 text-xs text-paper" style={`background: ${statusColor[status]}; font-weight: 500;`}>{status}</span>
                </td>
                <td class="py-2 pr-3 font-display text-ink font-medium">{fmtGrade(r.editorial?.qualityGrade)}</td>
                <td class="py-2 pr-3 font-display text-ink font-medium">{fmtGrade(r.editorial?.originalityGrade)}</td>
                <td class="py-2 pr-3 font-display text-ink font-medium">{fmtGrade(r.editorial?.voiceGrade)}</td>
                <td class="py-2 pr-3 font-display text-ink-soft text-xs font-medium">{flags}</td>
                <td class="py-2 pr-3 font-display italic text-ink-soft text-xs font-medium">{fmtDate(r.editorial?.claudeReviewedAt)}</td>
                <td class="py-2 pr-3 font-display italic text-ink-soft text-xs font-medium">{fmtDate(r.editorial?.jeffReviewedAt)}</td>
                <td class="py-2 pr-3" data-action-cell>
                  {(status === 'claude-reviewed' || status === 'draft' || status === 'ready-for-jeff') ? (
                    <button
                      type="button"
                      class="approve-btn px-3 py-1 border border-ink bg-ink text-paper text-xs font-display italic font-medium hover:bg-rust hover:border-rust"
                      data-collection={r.collection}
                      data-slug={r.slug}
                    >Approve</button>
                  ) : (status === 'jeff-approved' || status === 'published') ? (
                    <span class="font-display italic text-pine text-xs font-medium">approved</span>
                  ) : (
                    <span class="font-display italic text-ink-soft text-xs font-medium">—</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const bar = document.querySelector('[data-filter-bar]');
    const table = document.querySelector('[data-editorial-table]');
    if (bar && table) {
      bar.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (t.tagName !== 'BUTTON') return;
        bar.querySelectorAll('button').forEach((b) => {
          b.classList.remove('bg-ink', 'text-paper', 'border-ink');
          b.classList.add('border-bone', 'text-ink-soft');
        });
        t.classList.remove('border-bone', 'text-ink-soft');
        t.classList.add('bg-ink', 'text-paper', 'border-ink');

        const filter = t.getAttribute('data-filter') || 'all';
        const rows = table.querySelectorAll('tbody tr');
        rows.forEach((row) => {
          const status = row.getAttribute('data-status');
          const flagged = row.getAttribute('data-flagged') === 'true';
          let show = false;
          if (filter === 'all') show = true;
          else if (filter === 'needs-review') show = status === 'draft' || status === 'needs-revision';
          else if (filter === 'flagged') show = flagged;
          else show = status === filter;
          (row as HTMLElement).style.display = show ? '' : 'none';
        });
      });
    }

    // Approve button: POST to /api/admin/editorial/approve, then update the
    // row optimistically. The committed change shows up after the next build.
    if (table) {
      table.addEventListener('click', async (e) => {
        const btn = (e.target as Element).closest<HTMLButtonElement>('.approve-btn');
        if (!btn) return;
        const collection = btn.getAttribute('data-collection');
        const slug = btn.getAttribute('data-slug');
        if (!collection || !slug) return;

        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = 'Approving…';

        try {
          const res = await fetch('/api/admin/editorial/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ collection, slug }),
          });
          const data = await res.json() as { ok: boolean; error?: string; jeffReviewedAt?: string };
          if (!res.ok || !data.ok) {
            throw new Error(data.error || `HTTP ${res.status}`);
          }

          const row = btn.closest('tr');
          if (row) {
            row.setAttribute('data-status', 'jeff-approved');

            const actionCell = btn.closest('[data-action-cell]');
            if (actionCell) {
              actionCell.innerHTML =
                '<span class="font-display italic text-pine text-xs font-medium">approved (pending build)</span>';
            }

            const statusPill = row.querySelector('td:nth-child(3) span');
            if (statusPill) {
              statusPill.textContent = 'jeff-approved';
              (statusPill as HTMLElement).style.background = '#5C7459';
            }

            if (data.jeffReviewedAt) {
              const jeffCell = row.querySelector('td:nth-child(9)');
              if (jeffCell) {
                const d = new Date(data.jeffReviewedAt);
                jeffCell.textContent = d.toLocaleDateString('en-US', {
                  month: 'short', day: 'numeric', year: 'numeric',
                });
              }
            }
          }
        } catch (err) {
          btn.disabled = false;
          btn.textContent = originalText;
          alert('Approve failed: ' + ((err as Error).message || 'unknown error'));
        }
      });
    }
  </script>
</BaseLayout>

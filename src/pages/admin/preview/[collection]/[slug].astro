---
// Admin preview route. Renders any content entry — including drafts and
// future-dated posts — without going through the public site's isLive() filter.
//
// Behind Cloudflare Access on /admin/* (same as the editorial dashboard).
//
// URL: /admin/preview/<collection>/<slug>
// Used by the editorial dashboard when a piece's public URL would 404
// (because draft: true or publishedAt is in the future).

// Prerendered (static): paths are enumerated at build time via getStaticPaths
// so the content collections are NOT bundled into the SSR Worker. Importing
// astro:content from an SSR (prerender=false) page pulled every content chunk
// into the Worker and pushed it past Cloudflare's 25 MiB limit, breaking
// deploys. Trade-off: a brand-new draft is previewable only after the next
// build/deploy (scheduled/future-dated posts already in the repo are fine).
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export const prerender = true;

const COLLECTIONS = [
  'articles',
  'body',
  'pathways',
  'seasonCalendars',
  'guides',
  'resources',
  'coachingTips',
  'recruiting',
  'adaptive',
  'rules',
  'scripts',
  'decisions',
] as const;

export async function getStaticPaths() {
  const paths: any[] = [];
  for (const col of COLLECTIONS) {
    // No isLive() filter — previews must include drafts and future-dated posts.
    const entries = await getCollection(col as any);
    for (const entry of entries) {
      paths.push({ params: { collection: col, slug: entry.slug }, props: { entry, collection: col } });
    }
  }
  return paths;
}

const { entry, collection } = Astro.props as { entry: any; collection: string };
const slug = entry.slug as string;

const data = entry.data as any;
const { Content } = await entry.render();

const fmt = (d: any) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';

const title = data.title || data.activity || slug;
const dek = data.dek || data.summary || data.lede || '';
const editorial = data.editorial as any;

// Public URL the piece will live at once it's live.
const publicUrlFor = (col: string, item: any): string => {
  switch (col) {
    case 'articles':        return `/${item.data.phase}/${item.slug}/`;
    case 'body':            return `/body/${item.slug}/`;
    case 'pathways':        return `/pathways/${item.data.sport}/`;
    case 'seasonCalendars': return `/season-calendar/${item.slug}/`;
    case 'guides':          return `/what-to-buy/${item.slug}/`;
    case 'resources':       return `/team-parent/${item.slug}/`;
    case 'coachingTips':    return `/coaching-tips/${item.slug}/`;
    case 'recruiting':      return `/recruiting/${item.slug}/`;
    case 'adaptive':        return `/adaptive/${item.slug}/`;
    case 'rules':           return `/rules/${item.data.sport}/`;
    case 'scripts':         return `/scripts/${item.slug}/`;
    case 'decisions':       return `/decisions/${item.slug}/`;
    default:                return `/${item.slug}/`;
  }
};
const publicUrl = publicUrlFor(collection, entry);
---
<BaseLayout title={`Preview · ${title}`} description="Editorial preview (admin only).">
  <section class="border-b border-bone bg-paper-warm">
    <div class="container-px py-6">
      <div class="flex flex-wrap items-baseline justify-between gap-4">
        <div>
          <p class="font-display italic text-rust mb-1 font-medium">Admin · Editorial preview</p>
          <p class="font-display italic text-ink-soft text-xs font-medium">
            This is a preview. The public page is{' '}
            <a href={publicUrl} class="underline hover:text-rust">{publicUrl}</a>
            {data.draft && ' (currently hidden — draft: true)'}
            {!data.draft && data.publishedAt && new Date(data.publishedAt) > new Date() &&
              ` (queued for ${fmt(data.publishedAt)})`}
          </p>
        </div>
        <a
          href="/admin/editorial/"
          class="font-display italic text-xs px-3 py-1 border border-ink text-ink hover:bg-ink hover:text-paper font-medium"
        >← Back to dashboard</a>
      </div>

      <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1 text-xs font-display italic font-medium">
        <div><span class="text-ink-soft">Collection:</span> <span class="text-ink">{collection}</span></div>
        <div><span class="text-ink-soft">Slug:</span> <span class="text-ink">{slug}</span></div>
        <div><span class="text-ink-soft">Published:</span> <span class="text-ink">{fmt(data.publishedAt)}</span></div>
        <div><span class="text-ink-soft">Draft flag:</span> <span class="text-ink">{data.draft ? 'true' : 'false'}</span></div>
        {editorial && (
          <>
            <div><span class="text-ink-soft">Status:</span> <span class="text-ink">{editorial.status || '—'}</span></div>
            <div><span class="text-ink-soft">Quality:</span> <span class="text-ink">{editorial.qualityGrade ?? '—'}</span></div>
            <div><span class="text-ink-soft">Originality:</span> <span class="text-ink">{editorial.originalityGrade ?? '—'}</span></div>
            <div><span class="text-ink-soft">Voice:</span> <span class="text-ink">{editorial.voiceGrade ?? '—'}</span></div>
          </>
        )}
      </div>

      {editorial?.reviewerNotes && (
        <p class="mt-3 text-xs font-display italic text-ink-soft font-medium">
          <span class="text-ink-soft">Reviewer notes:</span> <span class="text-ink">{editorial.reviewerNotes}</span>
        </p>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-8 max-w-3xl">
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium" set:html={title.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></h1>
      {dek && <p class="font-display text-ink-soft mt-3 leading-snug max-w-2xl">{dek}</p>}

      <article class="mt-6 prose prose-ink max-w-none">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

---
// /admin/search-signals
//
// Shows aggregate search signals only. Individual events can contain sensitive
// free text, including legacy rows collected before redaction was added.
// Uses the isolated PCD operations database. Raw event rows never render.
// Wrap this route behind Cloudflare Access in production.

export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { env as cfEnv } from 'cloudflare:workers';
import { annotateDemandCoverage, listDemandOpportunities, type GovernedDemandOpportunity } from '../../lib/demand-reporting';
import coverageSnapshot from '../../../artifacts/content-coverage-v1.snapshot.json';

const env = cfEnv as { PCD_OPS_DB?: D1Database; ADMIN_EMAILS?: string } | undefined;

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;

let topQueries: GovernedDemandOpportunity[] = [];
let dbAvailable = !!env?.PCD_OPS_DB;
let tableReady = false;

if (env?.PCD_OPS_DB) {
  try {
    const demand = await listDemandOpportunities(env.PCD_OPS_DB, new Date().toISOString());
    topQueries = annotateDemandCoverage(demand, coverageSnapshot.contentItems as Array<{ query: string; status: 'current' | 'stale'; route: string }>);
    tableReady = true;
  } catch (e) {
    // The governed v1 table may not exist until its reviewed migration lands.
    console.error('[search-signals] D1 query failed:', e);
    tableReady = false;
  }
}

---
<AdminLayout title="Search signals" description="Admin: search event log" email={auth.email}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        Admin · <a href="/admin/camps/" class="hover:underline">Camps</a> · <a href="/admin/editorial/" class="hover:underline">Editorial</a> · Search signals
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Search signals
      </h1>
      <p class="font-display italic text-ink-soft text-sm mt-2 font-medium">
        Aggregate demand signals from sanitized searches. Telemetry remains default-off until its retention and disclosure gates are approved.
      </p>
    </div>
  </section>

  {!dbAvailable && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-8">
        <p class="font-display italic text-rust font-medium">Database not available. Run locally with <code>npm run dev</code> to access the Worker runtime and local D1 binding.</p>
      </div>
    </section>
  )}

  {dbAvailable && !tableReady && (
    <section class="border-b border-bone bg-paper-warm">
      <div class="container-px py-8">
        <p class="font-display italic text-rust font-medium">
          Search telemetry storage is not ready. Use the reviewed release runbook; do not apply a production migration from this page.
        </p>
      </div>
    </section>
  )}

  {tableReady && topQueries.length === 0 && (
    <section class="border-b border-bone">
      <div class="container-px py-8">
        <p class="font-display italic text-ink-soft font-medium">No search events logged yet.</p>
      </div>
    </section>
  )}

  {tableReady && topQueries.length > 0 && (
    <>
      <section class="border-b border-bone">
        <div class="container-px py-10">
          <p class="font-display italic text-rust mb-4 font-medium">Top 20 queries</p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm font-display">
              <thead>
                <tr class="border-b border-bone text-left text-ink-soft font-medium italic">
                  <th scope="col" class="pb-2 pr-6">#</th>
                  <th scope="col" class="pb-2 pr-6">Query</th>
                  <th scope="col" class="pb-2 pr-6">Searches</th>
                  <th scope="col" class="pb-2 pr-6">No results</th>
                  <th scope="col" class="pb-2 pr-6">Coverage</th>
                  <th scope="col" class="pb-2 pr-6">Score</th>
                  <th scope="col" class="pb-2 pr-6">Last seen</th>
                  <th scope="col" class="pb-2">Action</th>
                </tr>
              </thead>
              <tbody>
                {topQueries.map((row, i) => (
                  <tr
                    class="border-b border-bone hover:bg-paper-warm transition-colors"
                    data-signal-row
                    data-query={row.query}
                    data-searches={row.searches}
                    data-zero-result-searches={row.zero_result_searches}
                    data-last-seen-at={row.last_seen_at}
                    data-coverage-status={row.coverage_status}
                  >
                    <td class="py-2 pr-6 text-ink-soft">{i + 1}</td>
                    <td class="py-2 pr-6 text-ink font-medium">{row.query}</td>
                    <td class="py-2 pr-6 text-ink">{row.searches}</td>
                    <td class="py-2 pr-6 text-ink">{row.zero_result_searches}</td>
                    <td class="py-2 pr-6 text-ink-soft">
                      {row.coverage_route ? <a href={row.coverage_route} class="text-rust hover:underline">{row.coverage_status}</a> : 'unknown'}
                    </td>
                    <td class="py-2 pr-6 text-ink">{row.opportunity_score}</td>
                    <td class="py-2 pr-6 text-ink-soft">{row.last_seen_at.slice(0, 10)}</td>
                    <td class="py-2">
                      {row.coverage_status !== 'current' && (
                        <>
                          <button
                            type="button"
                            class="send-opportunity-btn font-display italic px-2 py-1 border border-bone text-ink-soft text-xs hover:bg-paper-warm font-medium"
                            data-action="send-opportunity"
                          >
                            Send to editorial opportunities
                          </button>
                          <p class="signal-status font-display italic text-xs text-ink-soft mt-1" style="display: none;" aria-live="polite"></p>
                        </>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </>
  )}
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-signal-row]').forEach(function (row) {
      var btn = row.querySelector('[data-action="send-opportunity"]');
      var statusEl = row.querySelector('.signal-status');
      if (!btn || !statusEl) return;

      btn.addEventListener('click', function () {
        var query = row.getAttribute('data-query') || '';
        var searches = parseInt(row.getAttribute('data-searches') || '0', 10);
        var zeroResults = parseInt(row.getAttribute('data-zero-result-searches') || '0', 10);
        var lastSeenAt = row.getAttribute('data-last-seen-at') || '';
        var coverageStatus = row.getAttribute('data-coverage-status') || 'unknown';

        var source = zeroResults > 0 ? 'no_result' : 'search';
        var summary = '"' + query + '" -- ' + searches + ' searches, ' + zeroResults + ' zero-result, last seen ' + lastSeenAt + ', coverage ' + coverageStatus;

        btn.disabled = true;
        var original = btn.textContent;
        btn.textContent = 'Sending…';

        fetch('/api/admin/editorial/opportunities/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: source,
            summary: summary,
            ref: 'demand_events_v1:' + query,
            target_keyword: query,
          }),
        }).then(function (res) {
          return res.json().then(function (data) { return { ok: res.ok, status: res.status, data: data }; });
        }).then(function (r) {
          if (!r.ok || !r.data.ok) {
            btn.disabled = false;
            btn.textContent = original;
            var msg = (r.data && r.data.error) || ('HTTP ' + r.status);
            statusEl.textContent = 'Not queued: ' + msg;
            statusEl.style.display = 'block';
            return;
          }
          btn.textContent = 'Queued ✓';
          statusEl.textContent = 'Sent to editorial opportunities.';
          statusEl.style.display = 'block';
        }).catch(function () {
          btn.disabled = false;
          btn.textContent = original;
          statusEl.textContent = 'Not queued: network error';
          statusEl.style.display = 'block';
        });
      });
    });
  });
</script>

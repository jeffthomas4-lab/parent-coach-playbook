---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import affiliateReport from '../../../reports/affiliate/inventory.json';
import { env as cfEnv } from 'cloudflare:workers';

// SSR so the desk landing can show the signed-in Access identity and offer a
// Log out control. Access already gates every /admin route; requireAdmin also
// enforces the ADMIN_EMAILS allowlist and fails closed when unconfigured.
export const prerender = false;

const env = cfEnv as { ADMIN_EMAILS?: string } | undefined;

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;
const adminEmail = auth.email;

const sections = [
  {
    href: '/admin/operations',
    title: 'Operational status',
    description: 'Read-only directory, scheduler, monitor, and agent-runtime evidence.',
  },
  {
    href: '/admin/data-quality',
    title: 'Data quality',
    description: 'Drill into the offending rows behind each directory quality metric and fix them inline.',
  },
  {
    href: '/admin/agents',
    title: 'PCD agents',
    description: 'Registered Forge Command agents and recent runs; pause, resume, or acknowledge.',
  },
  {
    href: '/admin/retention',
    title: 'Retention aging',
    description: 'Read-only review horizons for personal-data domains; never authorizes deletion.',
  },
  {
    href: '/admin/trust/',
    title: 'Trust cases',
    description: 'Review corrections, removals, privacy, copyright, accessibility, and content-safety requests.',
  },
  {
    href: '/admin/editorial/',
    title: 'Editorial review',
    description: 'Review content status, flags, scores, previews, and approvals.',
  },
  {
    href: '/admin/camps/',
    title: 'Camps moderation',
    description: 'Review pending camp submissions and moderation queues.',
  },
  {
    href: '/admin/claims/',
    title: 'Claims',
    description: 'Review organization ownership claims.',
  },
  {
    href: '/admin/suggestions/',
    title: 'Suggestions',
    description: 'Review proposed corrections and listing changes.',
  },
  {
    href: '/admin/link-health/',
    title: 'Link health',
    description: 'Inspect external-link checks and broken-link candidates.',
  },
  {
    href: '/admin/affiliates',
    title: 'Affiliate clicks',
    description: 'Read-only first-party click analytics by slug, campaign, and retailer.',
  },
  {
    href: '/admin/source-quality',
    title: 'Source quality',
    description: 'Inspect source reliability and verification status.',
  },
  {
    href: '/admin/search-signals',
    title: 'Search signals',
    description: 'Review search activity and unmet reader needs.',
  },
];
---

<AdminLayout title="Admin desk" description="Parent Coach Desk administration" email={adminEmail}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">Admin</p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Desk operations
      </h1>
      <p class="font-display text-ink-soft mt-3 max-w-2xl leading-snug">
        Choose a workspace. Cloudflare Access protects this page and every linked administrative route.
      </p>
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      <ul class="grid gap-4 md:grid-cols-2">
        {sections.map((section) => (
          <li>
            <a
              href={section.href}
              class="block h-full border border-bone bg-paper p-5 transition-colors hover:bg-paper-warm"
            >
              <h2 class="font-display text-ink text-xl font-medium">{section.title}</h2>
              <p class="font-display text-ink-soft mt-2 text-sm leading-snug">{section.description}</p>
              <p class="font-display italic text-rust mt-4 text-sm font-medium">Open workspace →</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-t border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">Affiliate inventory reconciliation</p>
      <h2 class="font-display text-ink text-2xl leading-tight font-medium">Governed snapshot</h2>
      <p class="font-display text-ink-soft mt-3 max-w-2xl leading-snug">
        Read-only report generated from the committed inventory: this desk cannot activate an account, change a destination, or publish a link.
        Fix entries in <code>src/data/affiliates.json</code> and regenerate the report.
      </p>
      <dl class="mt-6 grid gap-4 sm:grid-cols-4">
        <div class="border border-bone bg-paper p-4">
          <dt class="font-display text-ink-soft text-sm">Inventory</dt>
          <dd class="font-display text-ink text-2xl font-medium">{affiliateReport.inventoryCount}</dd>
        </div>
        <div class="border border-bone bg-paper p-4">
          <dt class="font-display text-ink-soft text-sm">Referenced</dt>
          <dd class="font-display text-ink text-2xl font-medium">{affiliateReport.referencedCount}</dd>
        </div>
        <div class="border border-bone bg-paper p-4">
          <dt class="font-display text-ink-soft text-sm">Unreferenced</dt>
          <dd class="font-display text-ink text-2xl font-medium">{affiliateReport.unreferencedCount}</dd>
        </div>
        <div class="border border-bone bg-paper p-4">
          <dt class="font-display text-ink-soft text-sm">Errors</dt>
          <dd class="font-display text-ink text-2xl font-medium">{affiliateReport.errorCount}</dd>
        </div>
      </dl>

      <h3 class="font-display text-ink text-xl mt-8 font-medium">Unreferenced inventory candidates</h3>
      <p class="font-display text-ink-soft mt-2 text-sm leading-snug">
        Inventory entries no committed content references. Retire them from the inventory or link them from content.
      </p>
      {affiliateReport.links.filter((link) => link.sources.length === 0).length === 0 ? (
        <p class="font-display text-ink-soft mt-4 text-sm">None. Every inventory entry is referenced by committed content.</p>
      ) : (
        <ul class="mt-4 grid gap-2">
          {affiliateReport.links.filter((link) => link.sources.length === 0).map((link) => (
            <li class="border border-bone bg-paper-warm p-3">
              <span class="font-display text-ink font-medium">{link.slug}</span>
              <span class="font-display text-ink-soft text-sm"> · {link.retailer} · {link.campaign}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</AdminLayout>

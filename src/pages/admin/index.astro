---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { env as cfEnv } from 'cloudflare:workers';
import affiliateReport from '../../../reports/affiliate/inventory.json';
import affiliateLifecycle from '../../../reports/affiliate/lifecycle.json';

// SSR so the desk landing can show the signed-in Access identity and offer a
// Log out control. Access already gates every /admin route; requireAdmin also
// enforces the ADMIN_EMAILS allowlist and fails closed when unconfigured.
export const prerender = false;

const env = cfEnv as { ADMIN_EMAILS?: string } | undefined;

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;
const adminEmail = auth.email;
const unreferencedAffiliateLinks = affiliateReport.links.filter((link) => link.sources.length === 0);

const sections = [
  {
    href: '/admin/operations',
    title: 'Operational status',
    description: 'Read-only directory, scheduler, monitor, and agent-runtime evidence.',
  },
  {
    href: '/admin/retention',
    title: 'Retention aging',
    description: 'Read-only review horizons for personal-data domains; never authorizes deletion.',
  },
  {
    href: '/admin/relationships',
    title: 'Trusted relationships',
    description: 'Review research candidates, evidence, human-review status, and outreach gates.',
  },
  {
    href: '/admin/trust/',
    title: 'Trust cases',
    description: 'Review corrections, removals, privacy, copyright, accessibility, and content-safety requests.',
  },
  {
    href: '/admin/editorial/',
    title: 'Editorial review',
    description: 'Review content status, flags, scores, previews, and approvals.',
  },
  {
    href: '/admin/camps/',
    title: 'Camps moderation',
    description: 'Review pending camp submissions and moderation queues.',
  },
  {
    href: '/admin/claims/',
    title: 'Claims',
    description: 'Review organization ownership claims.',
  },
  {
    href: '/admin/suggestions/',
    title: 'Suggestions',
    description: 'Review proposed corrections and listing changes.',
  },
  {
    href: '/admin/link-health/',
    title: 'Link health',
    description: 'Inspect external-link checks and broken-link candidates.',
  },
  {
    href: '/admin/source-quality',
    title: 'Source quality',
    description: 'Inspect source reliability and verification status.',
  },
  {
    href: '/admin/search-signals',
    title: 'Search signals',
    description: 'Review search activity and unmet reader needs.',
  },
];
---

<AdminLayout title="Admin desk" description="Parent Coach Desk administration" email={adminEmail}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">Admin</p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">
        Desk operations
      </h1>
      <p class="font-display text-ink-soft mt-3 max-w-2xl leading-snug">
        Choose a workspace. Cloudflare Access protects this page and every linked administrative route.
      </p>
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      <ul class="grid gap-4 md:grid-cols-2">
        {sections.map((section) => (
          <li>
            <a
              href={section.href}
              class="block h-full border border-bone bg-paper p-5 transition-colors hover:bg-paper-warm"
            >
              <h2 class="font-display text-ink text-xl font-medium">{section.title}</h2>
              <p class="font-display text-ink-soft mt-2 text-sm leading-snug">{section.description}</p>
              <p class="font-display italic text-rust mt-4 text-sm font-medium">Open workspace →</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-t border-bone bg-paper-warm">
    <div class="container-px py-10">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="font-display italic text-rust font-medium">Affiliate editorial inventory</p>
          <h2 class="font-display text-ink text-2xl mt-1 font-medium">Destination coverage snapshot</h2>
          <p class="font-display text-ink-soft mt-2 max-w-3xl text-sm leading-snug">Read-only build evidence from the release-gated inventory. Update destinations in <code>src/data/affiliates.json</code> and placements in reviewed content; this desk cannot activate an account, change a destination, or publish a link.</p>
        </div>
        <p class="font-mono text-xs text-ink-soft">{affiliateReport.errorCount === 0 ? 'Inventory contract passing' : `${affiliateReport.errorCount} blocking errors`}</p>
      </div>
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-6">
        <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Destinations</dt><dd class="font-display text-2xl">{affiliateReport.inventoryCount}</dd></div>
        <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Referenced</dt><dd class="font-display text-2xl">{affiliateReport.referencedCount}</dd></div>
        <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Unreferenced</dt><dd class="font-display text-2xl">{affiliateReport.unreferencedCount}</dd></div>
        <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Errors</dt><dd class="font-display text-2xl">{affiliateReport.errorCount}</dd></div>
      </dl>
      <div class="border-t border-bone mt-8 pt-8">
        <h3 class="font-display text-xl font-medium">Recommendation lifecycle baseline</h3>
        <p class="text-sm text-ink-soft mt-1">Legacy destinations are not treated as vetted products. They remain queued until product evidence, weaknesses, alternatives, audience fit, and human editorial approval exist.</p>
        <dl class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
          <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Product mapping queue</dt><dd class="font-display text-2xl">{affiliateLifecycle.queues.researchAndProductMapping.length}</dd></div>
          <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Need review first</dt><dd class="font-display text-2xl">{affiliateLifecycle.queues.needReviewBeforeResearch.length}</dd></div>
          <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Approved recommendations</dt><dd class="font-display text-2xl">{affiliateLifecycle.counts.approvedRecommendations}</dd></div>
          <div class="border border-bone bg-paper p-4"><dt class="font-mono text-xs text-ink-soft">Account verification</dt><dd class="font-display text-2xl">{affiliateLifecycle.queues.ownerAccountVerification.length}</dd></div>
        </dl>
        <div class="overflow-x-auto mt-5"><table class="w-full border-collapse text-left text-sm">
          <thead><tr class="border-b border-bone"><th class="p-3">Merchant</th><th class="p-3">Account evidence</th><th class="p-3">Offers</th><th class="p-3">Gate</th></tr></thead>
          <tbody>{affiliateLifecycle.merchantRollup.map((merchant) => <tr class="border-b border-bone"><td class="p-3 font-medium">{merchant.merchantName}</td><td class="p-3 font-mono text-xs">{merchant.accountState}</td><td class="p-3">{merchant.offerCount}</td><td class="p-3">{merchant.ownerActionRequired ? 'Owner verification required' : 'Existing-link evidence only'}</td></tr>)}</tbody>
        </table></div>
      </div>
      {unreferencedAffiliateLinks.length > 0 && (
        <div class="mt-6">
          <h3 class="font-display text-lg font-medium">Unreferenced inventory candidates</h3>
          <p class="text-sm text-ink-soft mt-1">These are not automatically approved for placement. Confirm reader need, disclosure position, destination accuracy, and editorial fit first.</p>
          <ul class="grid md:grid-cols-2 gap-2 mt-3">
            {unreferencedAffiliateLinks.map((link) => (
              <li class="border border-bone bg-paper px-4 py-3">
                <p class="font-mono text-sm text-ink">{link.slug}</p>
                <p class="font-mono text-xs text-ink-soft mt-1">{link.retailer} · {link.destinationHost} · {link.campaign}</p>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</AdminLayout>

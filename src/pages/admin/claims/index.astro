---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listPendingClaims, getCampById, type CampClaim, type Camp } from '../../../lib/camps-db';
import { requireAdmin } from '../../../lib/admin-auth';
import { featureEnabled } from '../../../lib/feature-flags';
import { env as cfEnv } from 'cloudflare:workers';

export const prerender = false;

const env = cfEnv as { DB: D1Database; ADMIN_EMAILS?: string; CAMP_CLAIMS_ENABLED?: string } | undefined;
const claimsEnabled = featureEnabled(env?.CAMP_CLAIMS_ENABLED);

const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;
const adminEmail = auth.email;

let claims: CampClaim[] = [];
const campLookup = new Map<string, Camp>();
let dbAvailable = !!env?.DB;
if (claimsEnabled && env?.DB) {
  try {
    claims = await listPendingClaims(env.DB);
    for (const c of claims) {
      if (!campLookup.has(c.camp_id)) {
        const camp = await getCampById(env.DB, c.camp_id);
        if (camp) campLookup.set(c.camp_id, camp);
      }
    }
  } catch (e) {
    console.error('listPendingClaims failed', e);
  }
}

const fmt = (s: string) =>
  new Date(s).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
---
<AdminLayout title="Claims moderation" description="Admin queue for camp claims" email={adminEmail}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        <a href="/admin/camps/" class="hover:underline">Admin · Camps</a> · Claims
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">Pending claims</h1>
      <p class="font-display italic text-ink-soft text-sm mt-2 max-w-2xl font-medium">
        {claimsEnabled
          ? 'Claim operations are enabled for this environment. Follow the approved ownership and entitlement procedures.'
          : 'Camp claims are disabled for the public-directory stage. The queue is read-suppressed and mutation endpoints fail closed until the owner product passes its launch gate.'}
      </p>
      {!adminEmail && (
        <p class="font-display italic text-rust text-sm mt-2 font-medium">
          Cloudflare Access header not detected. Action endpoints will fail until /admin/* is wired through Access.
        </p>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      {!claimsEnabled ? (
        <p class="font-display italic text-ink-soft font-medium">Claims workflow disabled.</p>
      ) : !dbAvailable ? (
        <p class="font-display italic text-ink-soft font-medium">Database not bound.</p>
      ) : claims.length === 0 ? (
        <p class="font-display italic text-ink-soft font-medium">No claims awaiting action.</p>
      ) : (
        <ul class="grid gap-4">
          {claims.map((cl) => {
            const camp = campLookup.get(cl.camp_id);
            return (
              <li class="border border-bone p-5 bg-paper">
                <p class="font-display italic text-rust text-xs font-medium">
                  {cl.status} · {fmt(cl.submitted_at)}
                </p>
                <h3 class="font-display text-ink text-lg leading-tight mt-1 font-medium">
                  {camp ? <a href={`/camps/${camp.slug}/`} class="hover:text-rust" target="_blank" rel="noopener">{camp.name}</a> : 'Unknown camp'}
                </h3>
                <p class="font-display text-ink-soft text-sm mt-1 leading-snug">
                  Claimant: <strong>{cl.claimant_email}</strong>
                  {cl.claimant_name && <> · {cl.claimant_name}</>}
                  {cl.organization && <> · {cl.organization}</>}
                  {cl.phone && <> · {cl.phone}</>}
                </p>
                <p class="font-display text-ink text-sm mt-3 leading-snug" style="white-space: pre-wrap;"><strong>Notes:</strong> {cl.notes}</p>

                <div class="mt-4 grid gap-2 sm:grid-cols-2">
                  <form method="POST" action={`/api/admin/claims/${cl.id}/update`} class="grid gap-2">
                    <input type="hidden" name="status" value="verified" />
                    <textarea name="notes" rows="2" placeholder="Verification notes (called school, confirmed role)" class="px-2 py-1 font-body bg-paper border border-bone text-xs"></textarea>
                    <button type="submit" class="font-display italic px-3 py-1 border border-bone bg-paper-warm text-sm hover:bg-paper font-medium">Mark verified</button>
                  </form>
                  <form method="POST" action={`/api/admin/claims/${cl.id}/update`} class="grid gap-2">
                    <input type="hidden" name="status" value="rejected" />
                    <textarea name="notes" rows="2" placeholder="Reject reason" class="px-2 py-1 font-body bg-paper border border-bone text-xs"></textarea>
                    <button type="submit" class="font-display italic px-3 py-1 border border-bone text-ink-soft text-sm hover:bg-paper-warm font-medium">Reject</button>
                  </form>
                </div>
                <p class="font-display italic text-ink-soft text-xs mt-3 font-medium">Payment and account activation are unavailable until customer identity, entitlement, reconciliation, and paid-product launch gates pass.</p>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</AdminLayout>

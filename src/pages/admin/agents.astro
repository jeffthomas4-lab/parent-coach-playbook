---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { env as cfEnv } from 'cloudflare:workers';

export const prerender = false;

const env = cfEnv as { FORGE_DB?: D1Database; ADMIN_EMAILS?: string; ACCESS_TEAM_DOMAIN?: string; ACCESS_AUD?: string } | undefined;
const auth = await requireAdmin(Astro.request, env);
if (auth instanceof Response) return auth;

interface AgentRegistryRow {
  agent: string;
  status?: string | null;
  last_run_at?: string | null;
  [key: string]: unknown;
}

interface AgentRunRow {
  run_id: string;
  agent: string;
  venture: string;
  status: string;
  needs_you: number;
  started_at: string;
  finished_at: string | null;
  summary?: string | null;
  error?: string | null;
  [key: string]: unknown;
}

const FORGE_UNAVAILABLE = 'FORGE_DB binding missing or query failed';

let agents: AgentRegistryRow[] = [];
let runs: AgentRunRow[] = [];
let agentsError: string | null = null;
let runsError: string | null = null;

if (!env?.FORGE_DB) {
  agentsError = FORGE_UNAVAILABLE;
  runsError = FORGE_UNAVAILABLE;
} else {
  try {
    const res = await env.FORGE_DB.prepare(`SELECT * FROM agent_registry WHERE venture = 'pcd' ORDER BY agent`).all<AgentRegistryRow>();
    agents = res.results ?? [];
  } catch (e) {
    console.error('[admin/agents] agent_registry query failed', e);
    agentsError = FORGE_UNAVAILABLE;
  }
  try {
    const res = await env.FORGE_DB.prepare(
      `SELECT * FROM agent_runs WHERE venture = 'pcd' ORDER BY COALESCE(finished_at, started_at) DESC LIMIT 20`,
    ).all<AgentRunRow>();
    runs = res.results ?? [];
  } catch (e) {
    console.error('[admin/agents] agent_runs query failed', e);
    runsError = FORGE_UNAVAILABLE;
  }
}

const STUCK_AFTER_MS = 60 * 60 * 1000;
const isStuck = (run: AgentRunRow) => !run.finished_at && Date.now() - Date.parse(run.started_at) > STUCK_AFTER_MS;

const fmt = (s: string | null | undefined) =>
  s ? new Date(s).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '—';
---
<AdminLayout title="PCD agents" description="Agent runtime status and controls" email={auth.email}>
  <section class="border-b border-bone">
    <div class="container-px py-10">
      <p class="font-display italic text-rust mb-2 font-medium">
        <a href="/admin/operations" class="hover:underline">Admin · Operations</a> · Agents
      </p>
      <h1 class="font-display text-ink text-3xl md:text-4xl leading-tight font-medium">PCD agents</h1>
      <p class="font-display text-ink-soft mt-3 max-w-2xl">
        Registered agents from Forge Command's <code>agent_registry</code>, and the last 20 recorded runs for this
        venture. Pause, resume, or acknowledge directly from here.
      </p>
    </div>
  </section>

  <section class="border-b border-bone">
    <div class="container-px py-10">
      <h2 class="font-display text-ink text-2xl font-medium mb-6">Registered agents</h2>
      {agentsError ? (
        <p class="font-display italic text-ink-soft font-medium">{agentsError}</p>
      ) : agents.length === 0 ? (
        <p class="font-display italic text-ink-soft font-medium">No PCD agents are registered.</p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {agents.map((agent) => {
            const paused = agent.status === 'paused';
            return (
              <li class:list={['border p-5 bg-paper agent-row', paused ? 'border-rust bg-paper-warm' : 'border-bone']} data-agent={agent.agent}>
                <div class="flex flex-wrap justify-between gap-3">
                  <h3 class="font-display text-ink text-lg font-medium">{agent.agent}</h3>
                  <p class:list={['font-mono text-xs uppercase', paused ? 'text-rust' : 'text-ink-soft']}>{agent.status ?? 'unknown'}</p>
                </div>
                <p class="font-display text-ink-soft text-sm mt-1">Last run: {fmt(agent.last_run_at)}</p>
                <div class="mt-3 flex gap-2">
                  {paused ? (
                    <button type="button" class="font-display italic px-3 py-2 border border-sage bg-sage-bg text-sm hover:bg-sage hover:text-paper transition-colors font-medium" data-agent-action="resume">
                      Resume
                    </button>
                  ) : (
                    <button type="button" class="font-display italic px-3 py-2 border border-bone bg-paper-warm text-sm hover:bg-paper transition-colors font-medium" data-agent-action="pause">
                      Pause
                    </button>
                  )}
                </div>
                <div class="status-message text-xs font-display italic mt-2" style="display: none;" aria-live="polite"></div>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  <section>
    <div class="container-px py-10">
      <h2 class="font-display text-ink text-2xl font-medium mb-6">Last 20 runs</h2>
      {runsError ? (
        <p class="font-display italic text-ink-soft font-medium">{runsError}</p>
      ) : runs.length === 0 ? (
        <p class="font-display italic text-ink-soft font-medium">No recorded runs.</p>
      ) : (
        <ul class="grid gap-4">
          {runs.map((run) => {
            const stuck = isStuck(run);
            const flagged = run.status === 'failed' || stuck;
            return (
              <li class:list={['border p-5 bg-paper run-row', flagged ? 'border-rust bg-paper-warm' : 'border-bone']} data-run-id={run.run_id}>
                <div class="flex flex-wrap justify-between gap-3">
                  <h3 class="font-display text-ink text-lg font-medium">{run.agent}</h3>
                  <p class:list={['font-mono text-xs uppercase', flagged ? 'text-rust' : 'text-ink-soft']}>
                    {run.status}{stuck ? ' · stuck' : ''}
                  </p>
                </div>
                <p class="font-display text-ink-soft text-sm mt-1">Started {fmt(run.started_at)} · Finished {fmt(run.finished_at)}</p>
                {run.summary && <p class="font-body text-ink text-sm mt-2 leading-snug">{run.summary}</p>}
                {run.error && <p class="font-mono text-xs text-rust mt-2">{run.error}</p>}
                {Number(run.needs_you) === 1 && (
                  <div class="mt-3 flex gap-2 items-center">
                    <span class="font-display italic text-rust text-xs font-medium px-2 py-1 border border-rust bg-paper-warm">needs you</span>
                    <button type="button" class="font-display italic px-3 py-2 border border-bone bg-paper-warm text-sm hover:bg-paper transition-colors font-medium" data-run-action="acknowledge">
                      Acknowledge
                    </button>
                  </div>
                )}
                <div class="status-message text-xs font-display italic mt-2" style="display: none;" aria-live="polite"></div>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.agent-row').forEach(function (row) {
      var agentId = row.getAttribute('data-agent');
      var statusEl = row.querySelector('.status-message');
      row.querySelectorAll('[data-agent-action]').forEach(function (btn) {
        btn.addEventListener('click', async function () {
          var action = btn.getAttribute('data-agent-action');
          btn.disabled = true;
          try {
            var resp = await fetch('/api/admin/agents/' + encodeURIComponent(agentId) + '/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: action }),
            });
            var data = await resp.json();
            if (data.ok) {
              statusEl.textContent = action === 'pause' ? 'Paused' : 'Resumed';
              statusEl.style.display = 'block';
              setTimeout(function () { window.location.reload(); }, 600);
            } else {
              statusEl.textContent = 'Error: ' + (data.error || 'unknown');
              statusEl.style.display = 'block';
              btn.disabled = false;
            }
          } catch (err) {
            statusEl.textContent = 'Error: ' + (err && err.message ? err.message : 'network error');
            statusEl.style.display = 'block';
            btn.disabled = false;
          }
        });
      });
    });

    document.querySelectorAll('.run-row').forEach(function (row) {
      var runId = row.getAttribute('data-run-id');
      var statusEl = row.querySelector('.status-message');
      row.querySelectorAll('[data-run-action]').forEach(function (btn) {
        btn.addEventListener('click', async function () {
          btn.disabled = true;
          try {
            var resp = await fetch('/api/admin/agents/' + encodeURIComponent(runId) + '/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'acknowledge' }),
            });
            var data = await resp.json();
            if (data.ok) {
              statusEl.textContent = 'Acknowledged';
              statusEl.style.display = 'block';
              setTimeout(function () {
                row.style.opacity = '0.5';
                setTimeout(function () { row.remove(); }, 300);
              }, 500);
            } else {
              statusEl.textContent = 'Error: ' + (data.error || 'unknown');
              statusEl.style.display = 'block';
              btn.disabled = false;
            }
          } catch (err) {
            statusEl.textContent = 'Error: ' + (err && err.message ? err.message : 'network error');
            statusEl.style.display = 'block';
            btn.disabled = false;
          }
        });
      });
    });
  });
</script>

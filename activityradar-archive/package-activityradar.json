{
  "name": "activityradar",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "ActivityRadar. Structured search and discovery over the shared youth-activity database.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate:local": "wrangler d1 migrations apply activity-radar --local",
    "db:migrate:remote": "wrangler d1 migrations apply activity-radar --remote",
    "migrate:camps": "python scripts/migrate_camps.py camps_export.json --out migrations/0005_seed_from_camps.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/tailwind": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^4.16.0",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "wrangler": "^4.88.0"
  }
}

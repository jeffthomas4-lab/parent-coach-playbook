---
// Suggest success page.
// Route: /suggest/success
export const prerender = false;

import Base from '../../layouts/Base.astro';
---

<Base
  title="Thanks for the tip — ActivityRadar"
  description="We received your organization suggestion and will review it this week."
>
  <div class="max-w-xl mx-auto px-4 py-20 text-center">

    <!-- Icon mark -->
    <div class="w-12 h-12 bg-navy flex items-center justify-center mx-auto mb-8">
      <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#faf5f1" stroke-width="2.5" stroke-linecap="square">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-navy mb-4">Thanks.</h1>

    <p class="text-navy/70 leading-relaxed mb-3">
      We review suggestions every week. If we add this organization, we will update the listing.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mt-10">
      <a href="/search" class="btn-primary no-underline">
        Back to search
      </a>
      <a href="/" class="btn-secondary no-underline">
        Home
      </a>
    </div>

  </div>
</Base>

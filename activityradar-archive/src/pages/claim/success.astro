---
// D5b: Claim success page.
// Route: /claim/success?name={claimant_name}
export const prerender = false;

import Base from '../../layouts/Base.astro';

const name = Astro.url.searchParams.get('name') ?? '';
---

<Base
  title="Claim Submitted — ActivityRadar"
  description="Your listing claim has been submitted. We will review and reach out within two business days."
>
  <div class="max-w-xl mx-auto px-4 py-20 text-center">

    <!-- Icon mark -->
    <div class="w-12 h-12 bg-navy flex items-center justify-center mx-auto mb-8">
      <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#faf5f1" stroke-width="2.5" stroke-linecap="square">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-navy mb-4">
      {name ? `Got it, ${name.split(' ')[0]}.` : 'Claim submitted.'}
    </h1>

    <p class="text-navy/70 leading-relaxed mb-3">
      We received your claim request and will review it within two business days.
    </p>
    <p class="text-navy/70 leading-relaxed mb-10">
      If we need anything else, we will reach out to the email you provided.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/search" class="btn-primary no-underline">
        Back to search
      </a>
      <a href="/" class="btn-secondary no-underline">
        ActivityRadar home
      </a>
    </div>

  </div>
</Base>

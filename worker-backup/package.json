{
  "name": "pcd-backup-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Weekly Cloudflare Cron Worker: exports the activity-radar D1 to R2, verifies row counts, alerts on failure.",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy --config ./wrangler.toml",
    "tail": "wrangler tail   --config ./wrangler.toml",
    "dev": "wrangler dev    --config ./wrangler.toml",
    "build": "wrangler deploy --dry-run --outdir ./dist --config ./wrangler.toml",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "secret:webhook": "wrangler secret put SLACK_WEBHOOK_URL --config ./wrangler.toml",
    "secret:list": "wrangler secret list --config ./wrangler.toml"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.88.0"
  }
}
